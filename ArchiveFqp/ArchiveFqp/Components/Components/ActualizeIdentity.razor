@using System.Security.Claims
@using ArchiveFqp.Interfaces.ReferenceData
@using ArchiveFqp.Models.DTO.User
@using Microsoft.AspNetCore.Authentication.Cookies
@inject IReferenceDataService RefDataService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

@code {

    protected override async Task OnInitializedAsync()
    {
        await CheckRoles();
    }

    private async Task CheckRoles()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        ClaimsPrincipal? user = authState!.User;
        if (user == null || !user.Identity!.IsAuthenticated) return;
        int idUser = int.Parse(user.Claims.First(x => x.Type == ClaimTypes.NameIdentifier).Value);
        UserDisplayDto account = (await RefDataService.GetAsync<UserDisplayDto>()).First(a => a.Пользователь.IdПользователя == idUser);
        
        // TODO: сделать авто перезаход
        if (user.Claims.Where(c => c.Type == ClaimTypes.Role).Any(c => !account.Роли.Contains(c.Value)))
        {
            Navigation.NavigateTo("/logout", true);
        }
    }
}
