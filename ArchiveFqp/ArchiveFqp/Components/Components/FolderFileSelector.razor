@using ArchiveFqp.Models.FileUpload
@using ArchiveFqp.Models.Settings
@using ArchiveFqp.Models.Settings.Department
@using ArchiveFqp.Services.FileUpload
@inject IJSRuntime JSRuntime
@inject WorkFileUploadService WorkFileUploadService
@implements IDisposable
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div class="card mb-3">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bi bi-folder2-open me-2"></i>Загрузка файлов работы
        </h5>
        <span class="badge bg-light text-dark">
            Выбрано файлов: @selectedFiles.Count
        </span>
    </div>
    <div class="card-body">
        <!-- Кнопка выбора папки -->
        <div class="mb-3">
            <label class="form-label fw-bold">Выберите папку с файлами работы</label>
            <InputFile OnChange="@OnFolderSelected"
                       webkitdirectory
                       directory
                       multiple
                       class="form-control"
                       disabled="@Disabled" />
            <small class="text-muted">
                <i class="bi bi-info-circle"></i>
                Выберите папку, содержащую все файлы работы. Типы файлов будут определены автоматически.
            </small>
        </div>

        <!-- Индикатор загрузки -->
        @if (isProcessing)
        {
            <div class="text-center my-3">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Обработка файлов...</span>
                </div>
                <p class="mt-2">Обработка файлов...</p>
            </div>
        }

        <!-- Таблица файлов -->
        @if (selectedFiles.Any() && !isProcessing)
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 5%"></th>
                            <th style="width: 35%">Файл</th>
                            <th style="width: 10%">Размер</th>
                            <th style="width: 25%">Определенный тип</th>
                            <th style="width: 25%">Тип файла</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            List<SelectedFileInfo> files = selectedFiles.OrderBy(f => f.Name).ToList();
                            for (int index = 0; index < files.Count(); index++)
                            {
                                int i = index;
                                SelectedFileInfo file = files[i];

                                <tr>
                                    <td>
                                        <button type="button" class="btn btn-close" onclick="@(() => { selectedFiles.Remove(file); StateHasChanged(); })"></button>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi @GetFileIconClass(file) me-2 fs-5"></i>
                                            <div>
                                                <div>@file.Name</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@ToFileSize(file.Size)</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(file.DetectedTypeKey))
                                        {
                                            <span class="badge bg-success">@file.DisplayDetectedType</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Не определен</span>
                                        }
                                    </td>
                                    <td>
                                        <select class="form-select form-select-sm"
                                                @onchange="@(e => OnFileTypeChanged(file, e.Value?.ToString()))"
                                                disabled="@Disabled">
                                            <option value="">Не определен</option>
                                            @foreach (var fileType in availableFileTypes)
                                            {
                                                var isSelected = file.SelectedTypeKey == fileType.Key;
                                                <option value="@fileType.Key" selected="@isSelected">
                                                    @fileType.DisplayName
                                                    @(fileType.IsRequired ? " *" : "")
                                                </option>
                                            }
                                        </select>
                                    </td>
                                </tr>
                            }
                    
                        }
                    </tbody>
                </table>
            </div>

            <!-- Кнопки действий -->
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div>
                    <span class="text-muted">
                        <i class="bi bi-files"></i>
                        Всего файлов: @selectedFiles.Count
                    </span>
                </div>
                <div>
                    <button type="button" class="btn btn-secondary me-2" @onclick="ClearSelection">
                        <i class="bi bi-x-circle"></i> Очистить
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmSelection" disabled="@(selectedFiles.Count == 0 || @Disabled)">
                        <i class="bi bi-check-circle"></i> Подтвердить выбор
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public EventCallback<List<SelectedFileInfo>> OnFilesConfirmed { get; set; }
    [Parameter] public BaseSettings SettingsFiles { get; set; } = null!;
    [Parameter] public string WorkType { get; set; } = null!;
    [Parameter] public bool Disabled { get; set; }

    private List<SelectedFileInfo> selectedFiles = new();
    private bool isProcessing;
    private List<FileTypeConfig> availableFileTypes = new();

    private Dictionary<string, List<string>> typePatterns = new();

    public class SelectedFileInfo
    {
        public string Name { get; set; } = "";
        public long Size { get; set; }
        public string Extension { get; set; } = "";
        public string RelativePath { get; set; } = "";
        public string? DetectedTypeKey { get; set; }
        public string? SelectedTypeKey { get; set; }
        public IBrowserFile? BrowserFile { get; set; }

        public string DisplayDetectedType => DetectedTypeKey ?? "Не определен";
        public string DisplaySelectedType => SelectedTypeKey ?? "Не выбран";
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadFileTypesFromSettings();
    }

    private async Task LoadFileTypesFromSettings()
    {
        try
        {
            // Получаем типы файлов из настроек кафедры
            if (SettingsFiles.AllowedFiles.Count != 0)
            {
                availableFileTypes = SettingsFiles.AllowedFiles
                    .Select(kvp => new FileTypeConfig
                    {
                        Key = GenerateKey(kvp.Key),
                        DisplayName = kvp.Key,
                        AllowedExtensions = kvp.Value,
                        FilePrefix = GenerateFilePrefix(kvp.Key),
                        IsRequired = SettingsFiles.RequiredFiles[WorkType].Contains(kvp.Key)
                    })
                    .ToList();
            }

            // Строим паттерны для определения типов
            BuildTypePatterns();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки типов файлов: {ex.Message}");
        }
    }

    private string GenerateKey(string displayName)
    {
        return displayName;
        // .Replace(" ", "")
            // .Replace("(", "")
            // .Replace(")", "");
    }

    private string GenerateFilePrefix(string displayName)
    {
        return displayName switch
        {
            var name when name.Contains("Word") => "explanation_word",
            var name when name.Contains("Pdf") || name.Contains("PDF") => "explanation_pdf",
            var name when name.Contains("Презентация") => "presentation",
            var name when name.Contains("Исходный код") => "source",
            var name when name.Contains("База данных") => "database",
            var name when name.Contains("Пароли") => "passwords",
            _ => GenerateKey(displayName).ToLower()
        };
    }

    private void BuildTypePatterns()
    {
        typePatterns.Clear();

        foreach (var fileType in availableFileTypes)
        {
            typePatterns[fileType.Key] = new List<string>();

            // Добавляем расширения
            foreach (var ext in fileType.AllowedExtensions)
            {
                typePatterns[fileType.Key].Add(ext);
            }

            // Добавляем ключевые слова из названия
            var keywords = fileType.DisplayName
                .ToLower()
                .Split(new[] { ' ', '(', ')' }, StringSplitOptions.RemoveEmptyEntries);

            foreach (var keyword in keywords.Where(k => k.Length > 2))
            {
                typePatterns[fileType.Key].Add(keyword);
            }

            // Специфические ключевые слова для каждого типа
            switch (fileType.Key)
            {
                case var k when k.Contains("ExplanatoryNoteWord"):
                    typePatterns[fileType.Key].AddRange(new[] { "пояснительная", "записка", "word" });
                    break;
                case var k when k.Contains("ExplanatoryNotePdf"):
                    typePatterns[fileType.Key].AddRange(new[] { "пояснительная", "записка", "pdf" });
                    break;
                case var k when k.Contains("Presentation"):
                    typePatterns[fileType.Key].AddRange(new[] { "презентация", "защита" });
                    break;
                case var k when k.Contains("Database"):
                    typePatterns[fileType.Key].AddRange(new[] { "database", "backup", "бэкап", "бд" });
                    break;
                case var k when k.Contains("Password"):
                    typePatterns[fileType.Key].AddRange(new[] { "password", "пароль", "pass", "pwd", "credentials" });
                    break;
            }
        }
    }

    private async Task OnFolderSelected(InputFileChangeEventArgs e)
    {
        try
        {
            selectedFiles.Clear();
            isProcessing = true;
            StateHasChanged();

            var files = e.GetMultipleFiles(20);
            if (files == null || files.Count == 0)
            {
                return;
            }

            foreach (var file in files)
            {
                var fileInfo = new SelectedFileInfo
                {
                    Name = file.Name,
                    RelativePath = file.Name,
                    Size = file.Size,
                    Extension = Path.GetExtension(file.Name).ToLowerInvariant(),
                    BrowserFile = file
                };

                // Определяем тип файла
                fileInfo.DetectedTypeKey = DetectFileType(fileInfo);
                fileInfo.SelectedTypeKey = fileInfo.DetectedTypeKey;

                selectedFiles.Add(fileInfo);
            }

            // Группируем и показываем предупреждения о конфликтах
            CheckForConflicts();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка обработки папки: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private string? DetectFileType(SelectedFileInfo file)
    {
        var fileNameLower = file.Name.ToLowerInvariant();
        var extension = file.Extension;

        // Сначала проверяем по расширению
        foreach (var fileType in availableFileTypes)
        {
            if (fileType.AllowedExtensions.Contains(extension))
            {
                return fileType.Key;
            }
        }

        // Затем по ключевым словам в имени файла
        foreach (var fileType in availableFileTypes)
        {
            if (typePatterns.TryGetValue(fileType.Key, out var patterns))
            {
                foreach (var pattern in patterns)
                {
                    if (fileNameLower.Contains(pattern.ToLower()))
                    {
                        return fileType.Key;
                    }
                }
            }
        }

        return null;
    }

    private void CheckForConflicts()
    {
        var fileTypeConfigs = availableFileTypes.ToDictionary(ft => ft.Key);

        var conflicts = selectedFiles
            .Where(f => f.SelectedTypeKey != null)
            .GroupBy(f => f.SelectedTypeKey)
            .Where(g =>
            {
                if (!fileTypeConfigs.TryGetValue(g.Key!, out var config))
                    return false;
                return g.Count() > 1;
            })
            .ToList();

        foreach (var conflict in conflicts)
        {
            var config = fileTypeConfigs[conflict.Key!];
            JSRuntime.InvokeVoidAsync("alert",
                $"Внимание: несколько файлов типа {config.DisplayName}");
        }
    }

    private void OnFileTypeChanged(SelectedFileInfo file, string? newTypeKey)
    {
        if (string.IsNullOrEmpty(newTypeKey))
        {
            file.SelectedTypeKey = null;
        }
        else
        {
            file.SelectedTypeKey = newTypeKey;
        }

        // Проверяем конфликты после изменения
        CheckForConflicts();
        StateHasChanged();
    }

    private void ClearSelection()
    {
        selectedFiles.Clear();
        Disabled = false;
        StateHasChanged();
    }

    private async Task ConfirmSelection()
    {
        // Валидация обязательных файлов
        var requiredTypes = availableFileTypes.Where(ft => ft.IsRequired).ToList();
        var missingRequired = requiredTypes
            .Where(rt => !selectedFiles.Any(f => f.SelectedTypeKey == rt.Key))
            .ToList();

        if (missingRequired.Any())
        {
            var missingNames = string.Join(", ", missingRequired.Select(rt => rt.DisplayName));
            await JSRuntime.InvokeVoidAsync("alert",
                $"Отсутствуют обязательные файлы: {missingNames}");
            return;
        }

        await OnFilesConfirmed.InvokeAsync(selectedFiles);
    }

    private string GetFileIconClass(SelectedFileInfo file)
    {
        return GetFileIcon(file.SelectedTypeKey, file.Extension);
    }

    private string GetFileIcon(string? typeKey, string extension)
    {
        // Сначала пробуем по типу
        if (!string.IsNullOrEmpty(typeKey))
        {
            return typeKey switch
            {
                var k when k.Contains("Word") => "bi-file-word",
                var k when k.Contains("Pdf") => "bi-file-pdf",
                var k when k.Contains("Презентация") => "bi-file-ppt",
                var k when k.Contains("Исходный код") => "bi-file-zip",
                var k when k.Contains("База данных") => "bi-database",
                var k when k.Contains("Парол") => "bi-file-lock",
                _ => "bi-file-earmark"
            };
        }
    
        // Fallback по расширению
        return extension.ToLower() switch
        {
            ".pdf" => "bi-file-pdf",
            ".doc" or ".docx" => "bi-file-word",
            ".ppt" or ".pptx" => "bi-file-ppt",
            ".txt" => "bi-file-text",
            ".zip" or ".rar" or ".7z" => "bi-file-zip",
            ".sql" or ".db" => "bi-database",
            _ => "bi-file-earmark"
        };
    }

    public void Dispose()
    {
        selectedFiles.Clear();
        availableFileTypes.Clear();
        typePatterns.Clear();
    }

    private string ToFileSize(long size)
    {
        if (size < 1024) return $"{size} B";
        else if (size < 1024 * 1024) return $"{size / 1024:F1} KB";
        else if (size < 1024 * 1024 * 1024) return $"{size / 1024 / 1024:F1} MB";
        return $"{size / 1024 / 1024 / 1024:F1} GB";
    }
}
