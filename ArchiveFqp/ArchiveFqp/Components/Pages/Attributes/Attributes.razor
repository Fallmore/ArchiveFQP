@using ArchiveFqp.Models.DTO.WorkApplication
@using ArchiveFqp.Models.Settings.SettingsArchive
@using ArchiveFqp.Services.Applications
@using ArchiveFqp.Services.ReferenceData
@using ArchiveFqp.Services.Work
@inject IReferenceDataService RefDataService
@inject IApplicationsService ApplicationsService
@inject IJSRuntime JS
@implements IDisposable
@rendermode @(new InteractiveServerRenderMode())

@if (RendererInfo.IsInteractive)
{
    <div class="table-responsive">
        @if (attributeApplications.Count == 0)
        {
            <h5 class="fw-semibold mb-0 align-content-center">Заявлений пока нет</h5>
        }
        else
        {
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th style="width: 10%">Статус</th>
                        <th style="width: 50%">Атрибут</th>
                        <th style="width: 15%">Дата подачи</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (ЗаявлениеАтрибута application in attributeApplications.Skip((currentPage - 1) * pageSize).Take(pageSize))
                    {
                        string status = applicationStatuses.First(x => x.IdСтатуса == application.IdСтатуса).Название;
                        <tr role="button" @onclick="@(() => selectedAttributeApplication = application)" data-bs-toggle="modal" data-bs-target="#@modalName">
                            <td>
                                <span class="badge @GetStatusBadgeClass(status) fs-6">
                                    @(status)
                                </span>
                            </td>
                            <td>@application.Название</td>
                            <td>@application.ДатаПоступления</td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Пагинация -->
            <nav aria-label="Навигация по страницам" class="mt-4">
                <ul class="pagination justify-content-center mb-1">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="@(() => ChangePage(1))">
                            <i class="bi bi-chevron-double-left"></i>
                        </button>
                    </li>
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="@(() => ChangePage(currentPage - 1))">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </li>

                    @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                    {
                        int page = i;
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <button class="page-link" @onclick="@(() => ChangePage(page))">@i</button>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="@(() => ChangePage(currentPage + 1))">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="@(() => ChangePage(totalPages))">
                            <i class="bi bi-chevron-double-right"></i>
                        </button>
                    </li>
                </ul>

                <div class="text-center mt-0 mb-0">
                    <small class="text-muted">
                        Страница @currentPage из @totalPages
                    </small>
                </div>
            </nav>
        }

        <div class="modal fade" id="@modalName" tabindex="-1" aria-labelledby="attributeApplicationModalLabel" aria-hidden="true"
             data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="attributeApplicationModalLabel">Информация о заявлении</h5>
                        <button type="button" @onclick="@(() => selectedAttributeApplication = null)" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        @if (selectedAttributeApplication != null)
                        {
                            <Attribute AttributeApplication="selectedAttributeApplication"
                                       IsEditMode="false"
                                       IsReviewMode="@IsReviewMode" />
                        }
                        else
                        {
                            <h5><strong>Заявление удалено</strong></h5>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<script>
    window.openModal = (modalId) => {
        const modalElement = document.getElementById(modalId);
        if (modalElement) {
            const modal = new bootstrap.Modal(modalElement);
            modal.show();
        }
    };
</script>

@code {
    [Parameter] public bool IsReviewMode { get; set; } = false;
    private List<ЗаявлениеАтрибута> attributeApplications = new();
    private ЗаявлениеАтрибута? selectedAttributeApplication;
    private List<СтатусЗаявления> applicationStatuses = null!;
    private string modalName = "attributeApplicationModal";
    private int pageSize = 5;
    private int currentPage = 1;
    private int totalPages => (int)Math.Ceiling((double)attributeApplications.Count / pageSize);

    private EventHandler<List<string>>? _tablesChangedHandler;

    protected override async Task OnInitializedAsync()
    {
        applicationStatuses = await ApplicationsService.GetApplicationsStatusesAsync();
        await GetAttributeApplications();
        _tablesChangedHandler = (s, e) => InvokeAsync(() => GetAttributeApplications(s, e));
        RefDataService.TablesChanged += _tablesChangedHandler;
    }

    private async Task GetAttributeApplications()
    {
        attributeApplications = await ApplicationsService.GetAttributeApplicationsAsync();
        if (IsReviewMode)
            attributeApplications = attributeApplications.OrderBy(x => x.IdСтатуса).ThenBy(x => x.ДатаПоступления).ToList();
        else
            attributeApplications = attributeApplications.OrderByDescending(x => x.ДатаПоступления).ToList();
        
        StateHasChanged();
    }

    private async Task GetAttributeApplications(object? sender, List<string> e)
    {
        if (e.Contains(typeof(ЗаявлениеАтрибута).Name))
        {
            await GetAttributeApplications();
            if (selectedAttributeApplication != null)
            {
                ЗаявлениеАтрибута? app = attributeApplications.FirstOrDefault(x => x.IdЗаявления == selectedAttributeApplication.IdЗаявления);
                if (!selectedAttributeApplication.Equals(app))
                {
                    selectedAttributeApplication = app;
                    await JS.InvokeVoidAsync("closeModal", modalName);
                    StateHasChanged();
                    await JS.InvokeVoidAsync("openModal", modalName);
                }
            }
        }
    }

    private string GetStatusBadgeClass(string status)
    {
        return status.ToLower() switch
        {
            "на рассмотрении" => "bg-info",
            "отклонено" => "bg-danger",
            "принято" => "bg-success",
            _ => "bg-secondary"
        };
    }

    private async Task ChangePage(int page)
    {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
    }

    public void Dispose()
    {
        if (_tablesChangedHandler != null)
            RefDataService.TablesChanged -= _tablesChangedHandler;
    }
}