@page "/works/attributes/review"
@using Microsoft.AspNetCore.Authorization
@rendermode @(new InteractiveServerRenderMode())
@attribute [Authorize(Roles = $"Завкафедрой,Ответственный кафедры,Ответственный института,Администратор")]

<PageTitle>АГТУ - Проверка заявлений на добавление атрибута</PageTitle>

@if (RendererInfo.IsInteractive)
{
    <div class="container">
        <div class="row-md-12">
            <div class="card mb-1">
                <div class="card-body">
                    <div class="card-title fw-bold fs-4">Все заявления</div>
                    <Attributes IsReviewMode="true" />
                </div>
            </div>
        </div>
    </div>
}