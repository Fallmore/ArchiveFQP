@page "/login"
@using ArchiveFqp.Interfaces.Auth
@using ArchiveFqp.Models.Auth
@using ArchiveFqp.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Вход в систему</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body">
                    <h4 class="card-title text-center mb-4">
                        <i class="bi-mortarboard" style="font-size: 3rem; color: blue;"></i><br />Вход в систему
                    </h4>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <EditForm Model="@loginModel" OnValidSubmit="@HandleLogin" FormName="loginForm">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label for="login" class="form-label">Логин</label>
                            <InputText @bind-Value="loginModel.Login" class="form-control" id="login" />
                            <ValidationMessage For="() => loginModel.Login" />
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Пароль</label>
                            <div class="input-group" style="padding:0; border-right-color:transparent">
                                <InputText @bind-Value="loginModel.Password" type="password" class="form-control input-password" style="border-right-color:transparent" id="password" />
                                <div class="input-group-text" style="border-left-color:transparent; background-color:transparent;">
                                    <input id="eye" class="form-check-input checkbox-password" style="border-color:transparent" type="checkbox" onclick="ChangeVisibilityPassword('password')">
                                    <label for="eye"></label>
                                </div>
                            </div>
                            <ValidationMessage For="() => loginModel.Password" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            Войти
                        </button>
                    </EditForm>

                    <div class="mt-3 text-center">
                        <p>Нет аккаунта? <a href="/register">Зарегистрироваться</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function ChangeVisibilityPassword(name) {
      var x = document.getElementById(name);
      if (x.type === "password") {
        x.type = "text";
      } else {
        x.type = "password";
      }
    }
    
</script>

@code {
    [SupplyParameterFromForm]
    private LoginModel loginModel { get; set; } = null!;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        loginModel ??= new();
    }

    private async Task HandleLogin()
    {
        errorMessage = null;
        var result = await AuthService.LoginAsync(loginModel);
        
        if (result.Success)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }
        else
        {
            errorMessage = result.Message;
        }
    }
}