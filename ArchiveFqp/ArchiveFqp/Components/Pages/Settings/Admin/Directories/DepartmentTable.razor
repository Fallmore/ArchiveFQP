@using System.Text.RegularExpressions
@using ArchiveFqp.Factories.DisplayDto.Structure
@using ArchiveFqp.Models.DTO.Structure
@using ArchiveFqp.Models.ReferenceData
@implements IDisposable

@if (items == null || editContext == null || Snapshot == null)
{
    <div class="text-center">Загрузка...</div>
}
else
{
    <div class="table-responsive">
        <div class="mb-3">
            <button class="btn btn-success btn-sm" @onclick="OpenCreateModal">
                <i class="bi bi-plus-circle"></i> Добавить
            </button>
        </div>
        
        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Название</th>
                    <th>Институт</th>
                    <th style="width:10%">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items.OrderBy(x => x.Институт.Название).ThenBy(x => x.Кафедра.Название))
                {
                    <tr>
                        <td>@item.Кафедра.IdКафедры</td>
                        <td>@item.Кафедра.Название</td>
                        <td>@item.Институт.Название</td>
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => OpenEditModal(item.Кафедра)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="async () => await OnDelete.InvokeAsync(item.Кафедра.IdКафедры)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Модальное окно -->
    <div class="modal fade @(showModal ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">@(isEdit ? "Редактирование" : "Добавление")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <EditForm EditContext="editContext" OnValidSubmit="@SaveItem" FormName="userForm">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Название *</label>
                            <input type="text" class="form-control" @bind="selectedItem.Название" />
                            <ValidationMessage For="() => selectedItem.Название" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Институт *</label>
                            <InputSelect class="form-select" @bind-Value="selectedItem.IdИнститута">
                                <option value="0"></option>
                                @foreach (Институт institute in Snapshot.Institutes.OrderBy(x => x.Название))
                                {
                                    <option value="@institute.IdИнститута">@institute.Название</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => selectedItem.IdИнститута" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" type="button" @onclick="CloseModal">Отмена</button>
                        <button class="btn btn-primary" type="submit">Сохранить</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public List<Кафедра>? Data { get; set; }
    [Parameter] public EventCallback<Кафедра> OnSave { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }
    [Parameter] public StructureDtoFactory? Factory { get; set; }
    [Parameter] public ReferenceDataSnapshot? Snapshot { get; set; }

    private List<StructureDto>? items;
    private Кафедра selectedItem = new();
    private bool showModal = false;
    private bool isEdit = false;

    EditContext? editContext;
    ValidationMessageStore? messageStore;

    protected override void OnParametersSet()
    {
        if (Data != null && Factory != null)
        {
            items = Factory.CreateDisplayDtoAsync(Data).Result;
            editContext = new(selectedItem);
            messageStore = new(editContext);
            editContext.OnValidationStateChanged += HandleValidationRequested;
        }

        StateHasChanged();
    }

    private void OpenCreateModal()
    {
        selectedItem = new();

        isEdit = false;
        showModal = true;
        StateHasChanged();
    }

    private void OpenEditModal(Кафедра item)
    {
        selectedItem = new()
        {
            IdИнститута = item.IdИнститута,
            IdКафедры = item.IdКафедры,
            Название = item.Название
        };
        isEdit = true;
        showModal = true;

        StateHasChanged();
    }

    private void CloseModal()
    {
        showModal = false;
        StateHasChanged();
    }

    private async Task SaveItem()
    {
        if (selectedItem != null)
        {
            await OnSave.InvokeAsync(selectedItem);
            CloseModal();
        }
    }

    private void HandleValidationRequested(object? sender, ValidationStateChangedEventArgs args)
    {
        messageStore?.Clear();
        
        if (string.IsNullOrWhiteSpace(selectedItem.Название))
        {
            messageStore?.Add(() => selectedItem.Название, "Название не может быть пустым");
        }

        if (selectedItem.IdИнститута == 0)
        {
            messageStore?.Add(() => selectedItem.IdИнститута, "Выберите институт");
        }
    }

    public void Dispose()
    {
        if (editContext != null)
            editContext.OnValidationStateChanged -= HandleValidationRequested;
    }
}