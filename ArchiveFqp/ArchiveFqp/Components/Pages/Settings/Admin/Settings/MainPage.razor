@page "/admin/settings"
@using ArchiveFqp.Interfaces.ReferenceData
@using Newtonsoft.Json
@using ArchiveFqp.Models
@using ArchiveFqp.Models.Settings.SettingsArchive
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ArchiveFqpContext> DbFactory
@inject IReferenceDataService RefDataService
@inject SettingsArchive Settings
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "Администратор")]
@rendermode @(new InteractiveServerRenderMode())

<PageTitle>Админ-панель - Настройки системы</PageTitle>

@if (RendererInfo.IsInteractive)
{
    <div class="container mt-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-gear me-2"></i>Настройки системы
                    </h4>
                    <button class="btn btn-light btn-sm" @onclick="@(() => NavigationManager.NavigateTo("/admin"))">
                        <i class="bi bi-arrow-left"></i> Назад
                    </button>
                </div>
            </div>
            <div class="card-body">
                <EditForm Model="@Settings" OnValidSubmit="@SaveSettings">
                    <div class="row">
                        <!-- Основные настройки -->
                        <div class="col-md-6">
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white">
                                    <h6 class="mb-0">Основные настройки</h6>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label">Имя папки данных</label>
                                        <input type="text" class="form-control" @bind="Settings.FolderDataName" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Имя папки работ</label>
                                        <input type="text" class="form-control" @bind="Settings.FolderWorksName" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Корневой путь к файлам</label>
                                        <div class="input-group">
                                            <input type="text" class="form-control" @bind="filesRootPathDisplay" />
                                            <button type="button" class="btn btn-outline-secondary z-0" @onclick="SelectFolder">
                                                <i class="bi bi-folder2-open"></i> Обзор
                                            </button>
                                        </div>
                                        <small class="text-muted">
                                            Полный путь: @Settings.FilesRootPath
                                        </small>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Максимальный размер файла (Мбайт)</label>
                                        <input type="number" class="form-control" min="1" max="500"
                                               @bind="maxFileSize" @bind:after="() => Settings.MaxFileSize = (int)(maxFileSize * 1024 * 1024)" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <!-- Настройки уведомлений -->
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white">
                                    <h6 class="mb-0">Уведомления</h6>
                                </div>
                                <div class="card-body">
                                    <div class="form-check mb-2">
                                        <input type="checkbox" class="form-check-input" @bind="Settings.SendNotifications" />
                                        <label class="form-check-label">Отправлять уведомления в системе</label>
                                    </div>
                                    <div class="form-check mb-1">
                                        <input type="checkbox" class="form-check-input" @bind="Settings.SendNotificationsOnEmail" />
                                        <label class="form-check-label">Отправлять уведомления на email</label>
                                    </div>
                                </div>
                            </div>

                            <!-- Настройки заявлений -->
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white">
                                    <h6 class="mb-0">Заявления</h6>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label">Задержка автоматической проверки статусов заявлений (минуты   )</label>
                                        <input type="number" min="1" class="form-control" @bind="Settings.ApplicationTimeCheckMinutes" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Мин. дней рассмотрения заявления на просмотр работ</label>
                                        <input type="number" min="1" max="@Settings.MaxDayWatchWorks" class="form-control" @bind="Settings.MinDayWatchWorks" />
                                    </div>
                                    <div class="mb-1">
                                        <label class="form-label">Макс. дней рассмотрения заявления на просмотр работ</label>
                                        <input type="number" min="@Settings.MinDayWatchWorks" max="100" class="form-control" @bind="Settings.MaxDayWatchWorks" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Исключенные значения атрибутов -->
                        <div class="col-md-6">
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white">
                                    <h6 class="mb-0">Исключенные значения атрибутов</h6>
                                </div>
                                <div class="card-body">
                                    <div class="mb-2">
                                        <label class="form-label">Значения (не относящиеся к данным)</label>
                                        <div class="input-group mb-2">
                                            <input type="text" class="form-control" @bind="newAbandonedValue"
                                                   placeholder="Новое значение" @onkeypress="HandleAbandonedKeyPress" />
                                            <button type="button" class="btn btn-success z-0" @onclick="AddAbandonedValue">
                                                <i class="bi bi-plus"></i> Добавить
                                            </button>
                                        </div>
                                        <div class="list-group mt-2">
                                            @foreach (var value in Settings.AttributesAbandonedValues)
                                            {
                                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                                    <span>@value</span>
                                                    <button type="button" class="btn btn-sm btn-danger"
                                                            @onclick="() => RemoveAbandonedValue(value)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Дипломные работы -->
                        <div class="col-md-6">
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white">
                                    <h6 class="mb-0">Дипломные работы</h6>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label">Типы дипломных работ</label>
                                        <div class="input-group mb-2">
                                            <select class="form-select mb-3" @bind="newFqpWork"
                                                    @onkeypress="HandleFqpKeyPress">
                                                <option value="">Выберите тип</option>
                                                @foreach (var workType in workTypesNotFqp)
                                                {
                                                    <option value="@workType.Название">@workType.Название</option>
                                                }
                                            </select>
                                            <button type="button" class="btn btn-success z-0" style="height:38px"
                                                    @onclick="AddFqpWork">
                                                <i class="bi bi-plus"></i> Добавить
                                            </button>
                                        </div>
                                        <div class="list-group">
                                            @foreach (var work in Settings.FqpWorks)
                                            {
                                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                                    <span>@work</span>
                                                    <button type="button" class="btn btn-sm btn-danger"
                                                            @onclick="() => RemoveFqpWork(work)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Работы с консультантами и рецензентами</label>
                                        <div class="input-group mb-2">
                                            <select class="form-select mb-3" @bind="newFqpWorkCR"
                                                    @onkeypress="HandleFqpKeyPress">
                                                <option value="">Выберите тип</option>
                                                @foreach (var workType in workTypesNotFqpCR)
                                                {
                                                    <option value="@workType.Название">@workType.Название</option>
                                                }
                                            </select>
                                            <button type="button" class="btn btn-success z-0" style="height:38px"
                                                    @onclick="AddFqpWorkCR">
                                                <i class="bi bi-plus"></i> Добавить
                                            </button>
                                        </div>
                                        <div class="list-group">
                                            @foreach (var work in Settings.FqpWorksWithCR)
                                            {
                                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                                    <span>@work</span>
                                                    <button type="button" class="btn btn-sm btn-danger"
                                                            @onclick="() => RemoveFqpWorkCR(work)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Уровни образования для дипломных работ -->
                        <div class="col-md-12">
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white">
                                    <h6 class="mb-0">Уровни образования по типам работ</h6>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label class="form-label">Выберите тип работы</label>
                                            <select class="form-select mb-3" @bind="selectedWorkTypeForEducation">
                                                <option value="">Выберите тип</option>
                                                @foreach (var workType in Settings.FqpWorks)
                                                {
                                                    <option value="@workType">@workType</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            @if (!string.IsNullOrEmpty(selectedWorkTypeForEducation))
                                            {
                                                <label class="form-label">Уровни образования для @selectedWorkTypeForEducation</label>
                                                <div class="input-group mb-2">
                                                    <input type="text" class="form-control" @bind="newEducationLevel"
                                                           placeholder="Новый уровень" @onkeypress="HandleEducationKeyPress" />
                                                    <button type="button" class="btn btn-success" @onclick="AddEducationLevel">
                                                        <i class="bi bi-plus"></i> Добавить
                                                    </button>
                                                </div>
                                                <div class="list-group">
                                                    @if (Settings.FqpWorksEducationLevels.ContainsKey(selectedWorkTypeForEducation))
                                                    {
                                                        foreach (var level in Settings.FqpWorksEducationLevels[selectedWorkTypeForEducation])
                                                        {
                                                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                                                <span>@level</span>
                                                                <button type="button" class="btn btn-sm btn-danger"
                                                                        @onclick="() => RemoveEducationLevel(level)">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Время хранения физических видов работ -->
                        <div class="col-md-12">
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white">
                                    <h6 class="mb-0">Время хранения физических видов работ</h6>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label class="form-label">Выберите тип работы</label>
                                            <select class="form-select mb-3" @bind="selectedWorkTypeForStorageTime">
                                                <option value="">Выберите тип</option>
                                                @foreach (var workType in Settings.FqpWorks)
                                                {
                                                    <option value="@workType">@workType</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            @if (!string.IsNullOrEmpty(selectedWorkTypeForStorageTime))
                                            {
                                                <label class="form-label">Время хранения для @selectedWorkTypeForStorageTime</label>
                                                <div class="input-group mb-2">
                                                    <input type="number" class="form-control" @bind="Settings.StorageTimeWorks[selectedWorkTypeForStorageTime]"
                                                           min="1" max="20" />
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Расширения файлов -->
                        <div class="col-md-12">
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">Разрешенные типы файлов и их расширения</h6>
                                    <button type="button" class="btn btn-sm btn-light" @onclick="AddNewFileType">
                                        <i class="bi bi-plus-circle"></i> Добавить тип файла
                                    </button>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        @foreach (var fileType in Settings.AllowedFiles.Keys.ToList())
                                        {
                                            var fileTypeName = fileType;
                                            var extensions = Settings.AllowedFiles[fileTypeName];
                    
                                            <div class="col-md-4 col-lg-3 mb-3">
                                                <div class="card h-100">
                                                    <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                                        <span class="fw-bold small">@fileTypeName</span>
                                                        @if (fileTypeName != "Пояснительная записка (Pdf)")
                                                        {
                                                            <button type="button" class="btn btn-sm btn-link text-danger p-0"
                                                                    @onclick="() => RemoveFileType(fileTypeName)">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        }
                                                    </div>
                                                    <div class="card-body p-2">
                                                        <div class="input-group input-group-sm mb-2">
                                                            <input type="text" class="form-control"
                                                                   placeholder=".ext"
                                                                   @bind="newExtensionInputs[fileTypeName]"
                                                                   @bind:event="oninput"
                                                                   @onkeypress="(e) => HandleExtensionKeyPress(e, fileTypeName)" />
                                                            <button type="button" class="btn btn-success btn-sm"
                                                                    @onclick="() => AddExtension(fileTypeName)">
                                                                <i class="bi bi-plus"></i>
                                                            </button>
                                                        </div>
                                                        <div class="list-group list-group-flush" style="max-height: 200px; overflow-y: auto;">
                                                            @foreach (var ext in extensions)
                                                            {
                                                                <div class="list-group-item d-flex justify-content-between align-items-center p-1 ps-2">
                                                                    <span class="small">@ext</span>
                                                                    <button type="button" class="btn btn-sm btn-link text-danger p-0"
                                                                            @onclick="() => RemoveExtension(fileTypeName, ext)">
                                                                        <i class="bi bi-x"></i>
                                                                    </button>
                                                                </div>
                                                            }
                                                            @if (!extensions.Any())
                                                            {
                                                                <div class="text-muted small text-center p-2">
                                                                    Нет расширений
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Необходимые файлы для типов работ -->
                        <div class="col-md-12">
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">Необходимые файлы для типов работ</h6>
                                    <button type="button" class="btn btn-sm btn-light" @onclick="AddNewWorkTypeRequirement">
                                        <i class="bi bi-plus-circle"></i> Добавить тип работы
                                    </button>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover">
                                            <thead class="table-light">
                                                <tr>
                                                    <th style="width: 20%">Тип работы</th>
                                                    <th style="width: 70%">Необходимые файлы</th>
                                                    <th style="width: 10%">Действия</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var requiredFile in Settings.RequiredFiles.ToList())
                                                {
                                                    var workTypeName = requiredFile.Key;
                                                    var requiredFilesList = requiredFile.Value;
                            
                                                    <tr>
                                                        <td>
                                                            <select class="form-select form-select-sm"
                                                                    @bind="workTypeSelections[workTypeName]"
                                                                    @bind:after="() => OnWorkTypeChanged(workTypeName)">
                                                                <option value="">Выберите тип работы</option>
                                                                @foreach (var workType in workTypes)
                                                                {
                                                                    <option value="@workType.Название">@workType.Название</option>
                                                                }
                                                            </select>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex flex-wrap gap-1">
                                                                @foreach (var file in requiredFilesList)
                                                                {
                                                                    <span class="badge bg-primary d-inline-flex align-items-center gap-1">
                                                                        @file
                                                                        <button type="button" class="btn-close btn-close-white btn-sm"
                                                                                style="font-size: 0.5rem;"
                                                                                @onclick="() => RemoveRequiredFile(workTypeName, file)"></button>
                                                                    </span>
                                                                }
                                                                <div class="input-group input-group-sm" style="width: auto;">
                                                                    <select class="form-select form-select-sm"
                                                                            style="width: auto; min-width: 150px;"
                                                                            @bind="newRequiredFileInputs[workTypeName]">
                                                                        <option value="">Выберите файл...</option>
                                                                        @foreach (var fileType in Settings.AllowedFiles.Keys)
                                                                        {
                                                                            <option value="@fileType">@fileType</option>
                                                                        }
                                                                    </select>
                                                                    <button type="button" class="btn btn-success btn-sm"
                                                                            @onclick="() => AddRequiredFile(workTypeName)">
                                                                        <i class="bi bi-plus"></i>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td class="text-center">
                                                            <button type="button" class="btn btn-sm btn-danger"
                                                                    @onclick="() => RemoveWorkTypeRequirement(workTypeName)">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Модальное окно для добавления нового типа файла -->
                        <div class="modal fade @(showAddFileTypeModal ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5)">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Добавление типа файла</h5>
                                        <button type="button" class="btn-close" @onclick="CloseAddFileTypeModal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="mb-3">
                                            <label class="form-label">Название типа файла</label>
                                            <input type="text" class="form-control" @bind="newFileTypeName" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Начальные расширения (через запятую)</label>
                                            <input type="text" class="form-control" @bind="newFileTypeExtensions"
                                                   placeholder=".doc, .docx, .pdf" />
                                            <small class="text-muted">Пример: .doc, .docx, .pdf</small>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" @onclick="CloseAddFileTypeModal">Отмена</button>
                                        <button type="button" class="btn btn-primary" @onclick="AddNewFileTypeConfirm">Добавить</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Модальное окно для добавления нового требования к типу работы -->
                        <div class="modal fade @(showAddWorkTypeModal ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5)">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Добавление требований для типа работы</h5>
                                        <button type="button" class="btn-close" @onclick="CloseAddWorkTypeModal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="mb-3">
                                            <label class="form-label">Тип работы</label>
                                            <select class="form-select" @bind="newWorkTypeForRequirement">
                                                <option value="">Выберите тип работы</option>
                                                @foreach (var workType in workTypes)
                                                {
                                                    <option value="@workType.Название">@workType.Название</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Начальный набор файлов</label>
                                            <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                                                @foreach (var fileType in Settings.AllowedFiles.Keys)
                                                {
                                                    var currentFileType = fileType; // Локальная переменная для замыкания
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox"
                                                               value="@currentFileType"
                                                               checked="@IsFileTypeSelected(currentFileType)"
                                                               @onchange="@(e => ToggleFileTypeSelection(currentFileType, e.Value is true))" />
                                                        <label class="form-check-label">@currentFileType</label>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" @onclick="CloseAddWorkTypeModal">Отмена</button>
                                        <button type="button" class="btn btn-primary" @onclick="AddNewWorkTypeRequirementConfirm">Добавить</button>
                                    </div>
                                </div>
                            </div>
                        </div>


                        <!-- Кнопки -->
                        <div class="col-12">
                            <div class="d-flex justify-content-between">
                                <button type="button" class="btn btn-secondary" @onclick="Cancel">Отмена</button>
                                <button type="submit" class="btn btn-primary">Сохранить настройки</button>
                            </div>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}


@code {
    private double maxFileSize;
    private string filesRootPathDisplay = "";
    private string newAbandonedValue = "";
    private string newFqpWork = "";
    private string newFqpWorkCR = "";
    private string selectedWorkTypeForEducation = "";
    private string selectedWorkTypeForStorageTime = "";
    private string newEducationLevel = "";

    private List<ТипРаботы> workTypes = null!;
    private List<ТипРаботы> workTypesNotFqp = null!;
    private List<ТипРаботы> workTypesNotFqpCR = null!;

    private Dictionary<string, string> newExtensionInputs = new();
    private Dictionary<string, string> newRequiredFileInputs = new();
    private Dictionary<string, string> workTypeSelections = new();
    
    // Модальные окна
    private bool showAddFileTypeModal = false;
    private bool showAddWorkTypeModal = false;
    
    // Данные для нового типа файла
    private string newFileTypeName = "";
    private string newFileTypeExtensions = "";
    
    // Данные для нового типа работы
    private string newWorkTypeForRequirement = "";
    private List<string> selectedFilesForNewWorkType = new();

    protected override async Task OnInitializedAsync()
    {
        if (RendererInfo.IsInteractive)
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        if (!string.IsNullOrEmpty(Settings.FilesRootPath))
        {
            var relativePath = Settings.FilesRootPath;
            filesRootPathDisplay = relativePath;
        }
        Settings.FqpWorksEducationLevels ??= new Dictionary<string, List<string>>();
        maxFileSize = ((double)Settings.MaxFileSize / 1024) / 1024;

        workTypes = (await RefDataService.GetAsync<ТипРаботы>()).OrderBy(w => w.Название).ToList();
        workTypesNotFqp = workTypes
            .Where(x => !Settings.FqpWorks.Contains(x.Название)).ToList();
        workTypesNotFqpCR = workTypes
            .Where(x => !Settings.FqpWorksWithCR.Contains(x.Название)).ToList();
        InitializeDictionaries();

        StateHasChanged();
    }

    private void InitializeDictionaries()
    {
        // Инициализация словарей для ввода расширений
        foreach (var fileType in Settings.AllowedFiles.Keys)
        {
            if (!newExtensionInputs.ContainsKey(fileType))
                newExtensionInputs[fileType] = "";
        }
        
        // Инициализация словарей для выбора файлов
        foreach (var requiredFile in Settings.RequiredFiles.Keys)
        {
            if (!newRequiredFileInputs.ContainsKey(requiredFile))
                newRequiredFileInputs[requiredFile] = "";
            if (!workTypeSelections.ContainsKey(requiredFile))
                workTypeSelections[requiredFile] = requiredFile;
        }
    }

    private async Task SaveSettings()
    {
        try
        {
            if (!string.IsNullOrEmpty(filesRootPathDisplay))
            {
                Settings.FilesRootPath = filesRootPathDisplay;
            }

            using var context = DbFactory.CreateDbContext();
            var settingsEntity = await context.НастройкиУчрежденияs.FirstOrDefaultAsync();
            var settingsJson = JsonConvert.SerializeObject(Settings);

            if (settingsEntity == null)
            {
                settingsEntity = new НастройкиУчреждения { Настройки = settingsJson };
                context.НастройкиУчрежденияs.Add(settingsEntity);
            }
            else
            {
                settingsEntity.Настройки = settingsJson;
                context.НастройкиУчрежденияs.Update(settingsEntity);
            }

            await context.SaveChangesAsync();
            await JSRuntime.InvokeVoidAsync("alert", "Настройки сохранены");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/admin");
    }

    private async Task SelectFolder()
    {
        try
        {
            // Для Blazor Server можно использовать JSRuntime для выбора папки
            var selectedPath = await JSRuntime.InvokeAsync<string>("window.prompt", "Введите путь к корневой папке:", filesRootPathDisplay);
            if (!string.IsNullOrEmpty(selectedPath))
            {
                filesRootPathDisplay = selectedPath;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка выбора папки: {ex.Message}");
        }
    }

