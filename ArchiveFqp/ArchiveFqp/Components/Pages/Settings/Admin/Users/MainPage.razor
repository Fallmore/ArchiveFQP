@page "/admin/users"
@using ArchiveFqp.Models
@using ArchiveFqp.Models.DTO.Student
@using ArchiveFqp.Models.DTO.Teacher
@using ArchiveFqp.Models.Search
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject NavigationManager NavigationManager
@attribute [Authorize(Roles = "Администратор")]
@rendermode @(new InteractiveServerRenderMode())

<PageTitle>Админ-панель - Управление пользователями</PageTitle>

@if (RendererInfo.IsInteractive)
{
    <div class="container-fluid mt-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-people me-2"></i>Управление пользователями и аккаунтами
                    </h4>
                    <button class="btn btn-light btn-sm" @onclick="@(() => NavigationManager.NavigateTo("/admin"))">
                        <i class="bi bi-arrow-left"></i> Назад
                    </button>
                </div>
            </div>
            <div class="card-body">
                <!-- Вкладки -->
                <ul class="nav nav-tabs mb-3">
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "users" ? "active" : "")" @onclick="@(() => SetActiveTab("users"))">
                            <i class="bi bi-person-badge"></i> Пользователи
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "accounts" ? "active" : "")" @onclick="@(() => SetActiveTab("accounts"))">
                            <i class="bi bi-key"></i> Аккаунты
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "students" ? "active" : "")" @onclick="@(() => SetActiveTab("students"))">
                            <i class="bi bi-mortarboard"></i> Студенты
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "teachers" ? "active" : "")" @onclick="@(() => SetActiveTab("teachers"))">
                            <i class="bi bi-person-workspace"></i> Преподаватели
                        </button>
                    </li>
                </ul>

                <div class="row mb-0">
                    <div class="col">
                        <p class="text-muted">
                            Всего: @totalCount
                        </p>
                    </div>
                </div>

                <!-- Контент вкладок -->
                @if (activeTab == "users")
                {
                    usersPaginated ??= new() { PageSize = pageSize, CurrentPage = currentPage };
                    <UsersTable Users="usersPaginated" UsersChanged="LoadCurrentTabData" />
                }
                else if (activeTab == "accounts")
                {
                    accountsPaginated ??= new() { PageSize = pageSize, CurrentPage = currentPage };
                    <AccountsTable Accounts="accountsPaginated" AccountsChanged="LoadCurrentTabData" />
                }
                else if (activeTab == "students")
                {
                    studentsPaginated ??= new() { PageSize = pageSize, CurrentPage = currentPage };
                    <StudentsTable Students="studentsPaginated" StudentsChanged="LoadCurrentTabData" />
                }
                else if (activeTab == "teachers")
                {
                    teachersPaginated ??= new() { PageSize = pageSize, CurrentPage = currentPage };
                    <TeachersTable Teachers="teachersPaginated" TeachersChanged="LoadCurrentTabData" />
                }

                <!-- Пагинация -->
                @if (totalPages > 1)
                {
                    <nav>
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(1)">Первая</button>
                            </li>
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Предыдущая</button>
                            </li>
                            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                            {
                                int index = i;
                                <li class="page-item @(currentPage == i ? "active" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(index)">@index</button>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Следующая</button>
                            </li>
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(totalPages)">Последняя</button>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
}


@code {
    private string activeTab = "users";
    private PaginatedResult<Пользователь>? usersPaginated;
    private PaginatedResult<АккаунтПользователя>? accountsPaginated;
    private PaginatedResult<StudentDisplayDto>? studentsPaginated;
    private PaginatedResult<TeacherDisplayDto>? teachersPaginated;

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 0;
    private int totalCount = 0;

    private void SetActiveTab(string tab)
    {
        switch (activeTab)
        {
            case "users":
                usersPaginated?.Items = [];
                break;
            case "accounts":
                accountsPaginated?.Items = [];
                break;
            case "students":
                studentsPaginated?.Items = [];
                break;
            case "teachers":
                teachersPaginated?.Items = [];
                break;
        }
        activeTab = tab;
        ChangePage(1);
    }

    private void ChangePage(int page)
    {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        switch (activeTab)
        {
            case "users":
                usersPaginated?.CurrentPage = currentPage;
                break;
            case "accounts":
                accountsPaginated?.CurrentPage = currentPage;
                break;
            case "students":
                studentsPaginated?.CurrentPage = currentPage;
                break;
            case "teachers":
                teachersPaginated?.CurrentPage = currentPage;
                break;
        }
        StateHasChanged();
    }

    private async Task LoadCurrentTabData()
    {
        switch (activeTab)
        {
            case "users":
                currentPage = usersPaginated?.CurrentPage ?? 1;
                pageSize = usersPaginated?.PageSize ?? 10;
                totalPages = usersPaginated?.TotalPages ?? 0;
                totalCount = usersPaginated?.TotalCount ?? 0;
                break;
            case "accounts":
                currentPage = accountsPaginated?.CurrentPage ?? 1;
                pageSize = accountsPaginated?.PageSize ?? 10;
                totalPages = accountsPaginated?.TotalPages ?? 0;
                totalCount = accountsPaginated?.TotalCount ?? 0;
                break;
            case "students":
                currentPage = studentsPaginated?.CurrentPage ?? 1;
                pageSize = studentsPaginated?.PageSize ?? 10;
                totalPages = studentsPaginated?.TotalPages ?? 0;
                totalCount = studentsPaginated?.TotalCount ?? 0;
                break;
            case "teachers":
                currentPage = teachersPaginated?.CurrentPage ?? 1;
                pageSize = teachersPaginated?.PageSize ?? 10;
                totalPages = teachersPaginated?.TotalPages ?? 0;
                totalCount = teachersPaginated?.TotalCount ?? 0;
                break;
        }
    }
}