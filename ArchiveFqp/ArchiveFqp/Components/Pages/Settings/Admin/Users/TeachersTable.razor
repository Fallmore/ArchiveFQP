@using ArchiveFqp.Components.Components
@using ArchiveFqp.Interfaces.ReferenceData
@using ArchiveFqp.Interfaces.User
@using ArchiveFqp.Models
@using ArchiveFqp.Models.DTO.Student
@using ArchiveFqp.Models.DTO.Teacher
@using ArchiveFqp.Models.DatabaseNotification
@using ArchiveFqp.Models.ReferenceData
@using ArchiveFqp.Services.ReferenceData
@using Microsoft.EntityFrameworkCore
@inject IReferenceDataService RefDataService
@inject IUserService UserService
@inject IDbContextFactory<ArchiveFqpContext> DbFactory
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="table-responsive">
    <div class="mb-3">
        <div class="row">
            <div class="col-auto d-flex align-items-end">
                <button class="btn btn-success btn-sm" @onclick="OpenCreateModal">
                    <i class="bi bi-plus-circle"></i> Добавить преподавателя
                </button>
            </div>
            <div class="col-md-4 pt-1">
                <input type="text" class="form-control"
                       @bind="searchText"
                       @bind:event="oninput"
                       placeholder="Введите ФИО для поиска преподавателя" />
            </div>
        </div>
    </div>
    
    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Пользователь</th>
                <th>Институт</th>
                <th>Кафедра</th>
                <th>Должность</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @if (filteredTeachers == null)
            {
                <tr><td colspan="6" class="text-center">Загрузка...</td></tr>
            }
            else if (filteredTeachers.Count == 0)
            {
                <tr><td colspan="6" class="text-center">Нет данных</td></tr>
            }
            else
            {
                @foreach (var teacher in filteredTeachers)
                {
                    <tr>
                        <td>@teacher.IdПреподавателя</td>
                        <td>@teacher.Пользователь.ФИО</td>
                        <td>@teacher.Структура.Институт.Название</td>
                        <td>@teacher.Структура.Кафедра.Название</td>
                        <td>@teacher.Должность.Название</td>
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => OpenEditModal(teacher.ToTeacher())">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteTeacher(teacher.IdПреподавателя)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- Модальное окно для пользователя -->
@if (snapshot != null)
{
    <div class="modal fade @(showModal ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5)" @onclick:stopPropagation>
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">@(isEdit ? "Редактирование" : "Добавление") пользователя</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="@selectedTeacher" OnValidSubmit="@SaveTeacher" FormName="teacherForm">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Пользователь *</label>
                            <SearchableSelect TItem="Пользователь"
                                              TValue="int"
                                              Items="@users"
                                              TextSelector="@((s) => string.Join(" ", s.Фамилия, s.Имя, s.Отчество))"
                                              ValueSelector="@(s => s.IdПользователя)"
                                              Placeholder="Выберите или введите пользователя..."
                                              @bind-SelectedValue="@selectedTeacher.IdПользователя"
                                              OnCustomValue="@(() => selectedTeacher.IdПользователя = 0)" />
                            <ValidationMessage For="() => selectedTeacher.IdПользователя" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Должность *</label>
                            <InputSelect class="form-select" @bind-Value="selectedTeacher.IdДолжности">
                                <option value="0"></option>
                                @foreach (Должность position in snapshot.Posts.OrderBy(x => x.Название))
                                {
                                    <option value="@position.IdДолжности">@position.Название</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => selectedTeacher.IdДолжности" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Институт *</label>
                            <InputSelect class="form-select" @bind-Value="selectedTeacher.IdИнститута"
                                         @bind-Value:after="OnInstituteChanged">
                                <option value="0"></option>
                                @foreach (Институт institute in snapshot.Institutes.OrderBy(x => x.Название))
                                {
                                    <option value="@institute.IdИнститута">@institute.Название</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => selectedTeacher.IdИнститута" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Кафедра *</label>
                            <InputSelect class="form-select" @bind-Value="selectedTeacher.IdКафедры"
                                         disabled="@(selectedTeacher.IdИнститута == 0)">
                                <option value="0"></option>
                                @foreach (Кафедра department in filteredDepartments.OrderBy(x => x.Название))
                                {
                                    <option value="@department.IdКафедры">@department.Название</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => selectedTeacher.IdКафедры" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" type="button" @onclick="CloseModal">Отмена</button>
                        <button class="btn btn-primary" type="submit">Сохранить</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}
@code {
    private List<TeacherDisplayDto>? teachersDisplay;
    private List<Пользователь> users = null!;
    private Преподаватель selectedTeacher = new();
    private ReferenceDataSnapshot snapshot = null!;
    private bool showModal = false;
    private bool isEdit = false;

    private List<Кафедра> filteredDepartments = new();

    private string searchText = "";
    private List<TeacherDisplayDto> filteredTeachers
    {
        get
        {
            if (string.IsNullOrWhiteSpace(searchText))
                return teachersDisplay ?? [];

            return teachersDisplay?.Where(item =>
            {
                return item.Пользователь.ФИО.Contains(searchText, StringComparison.OrdinalIgnoreCase);
            }).ToList() ?? [];
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        RefDataService.TablesChanged += OnTablesChanged;
    }

    private async Task LoadData()
    {
        List<int> idTeachers = (await RefDataService.GetAsync<Преподаватель>()).Select(x => x.IdПользователя).ToList();
        teachersDisplay = (await UserService.GetTeacherDisplayAsync(idTeachers)).OrderBy(x => x.Пользователь.ФИО).ToList();
        users = await RefDataService.GetAsync<Пользователь>();
        snapshot = await RefDataService.GetAllAsync();
        StateHasChanged();
    }

    private void OpenCreateModal()
    {
        selectedTeacher = new();
        isEdit = false;
        showModal = true;
        StateHasChanged();
    }

    private void OpenEditModal(Преподаватель teacher)
    {
        selectedTeacher = teacher;
        isEdit = true;
        showModal = true;
        StateHasChanged();
    }

    private void CloseModal()
    {
        showModal = false;
        StateHasChanged();
    }

    private async Task SaveTeacher()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();

            if (isEdit)
            {
                context.Преподавательs.Update(selectedTeacher);
            }
            else
            {
                context.Преподавательs.Add(selectedTeacher);
            }

            await context.SaveChangesAsync();
            CloseModal();
            await JSRuntime.InvokeVoidAsync("alert", "Сохранено успешно");
        }
        catch (DbUpdateException ex)
        {
            string errorMessage = ex.InnerException?.Message ?? "";
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {errorMessage}");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private async Task DeleteTeacher(int id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Удалить пользователя?"))
        {
            try
            {
                using var context = DbFactory.CreateDbContext();
                var teacher = await context.Преподавательs.FindAsync(id);
                if (teacher != null)
                {
                    context.Преподавательs.Remove(teacher);
                    await context.SaveChangesAsync();
                }
            }
            catch (DbUpdateException ex)
            {
                string errorMessage = ex.InnerException?.Message ?? "";
                if (errorMessage.Contains(ReferenceDataService.GetTableName<Работа>()))
                    await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: Преподаватель является руководителем работ");
                else if (errorMessage.Contains(ReferenceDataService.GetTableName<Консультант>()))
                    await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: Преподаватель является консультантом работ");
                else if (errorMessage.Contains(ReferenceDataService.GetTableName<Рецензент>()))
                    await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: Преподаватель является рецензентом работ");
                else if (errorMessage.Contains(ReferenceDataService.GetTableName<ОценкаПреподавателя>()))
                    await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: Преподаватель имеет выставленные оценки");
                else
                    await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {errorMessage}");
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
            }
        }
    }

    private async Task UpdateDependentLists()
    {
        if (selectedTeacher.IdИнститута == 0)
            filteredDepartments = snapshot.Departments.ToList();
        else
            filteredDepartments = snapshot.Departments
                .Where(d => d.IdИнститута == selectedTeacher.IdИнститута)
                .DistinctBy(d => d.Название)
                .ToList();
    }


    private async Task OnInstituteChanged()
    {
        selectedTeacher.IdКафедры = 0;
        await UpdateDependentLists();
    }

    private async void OnTablesChanged(object? sender, TableChangeEvent e)
    {
        if (e.TableName == nameof(Преподаватель))
        {
            await InvokeAsync(async () => { await LoadData(); });
        }
    }

    public void Dispose()
    {
        RefDataService.TablesChanged -= OnTablesChanged;
    }
}