@page "/department/settings"
@using ArchiveFqp.Components.Components
@using ArchiveFqp.Interfaces.ReferenceData
@using ArchiveFqp.Interfaces.Settings
@using ArchiveFqp.Interfaces.User
@using ArchiveFqp.Models.DTO.Structure
@using ArchiveFqp.Models.DTO.Teacher
@using ArchiveFqp.Models.ReferenceData
@using ArchiveFqp.Models.Settings.Department
@using Newtonsoft.Json
@using ArchiveFqp.Models
@using ArchiveFqp.Models.Settings.SettingsArchive
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject SettingsArchive Settings
@inject ISettingsService SettingsService
@inject IReferenceDataService RefDataService
@inject IUserService UserService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize(Roles = "Ответственный кафедры, Завкафедрой")]
@rendermode @(new InteractiveServerRenderMode())

<PageTitle>Панель кафедры - Настройки кафедры</PageTitle>

@if (RendererInfo.IsInteractive && responsible != null)
{
    <div class="container mt-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-gear me-2"></i>Настройки кафедры<br />@responsible.Структура.Кафедра.Название
                    </h4>
                    <h6 class="mb-0">Не забудьте сохранить настройки</h6>
                    <button class="btn btn-light btn-sm" @onclick="@(() => NavigationManager.NavigateTo("/department"))">
                        <i class="bi bi-arrow-left"></i> Назад
                    </button>
                </div>
            </div>
            <div class="card-body">
                <EditForm Model="@settingsDto" OnValidSubmit="@SaveSettings">
                    <div class="row">
                        <!-- Основные настройки -->
                        <div class="col-md-12 mb-3">
                            <div class="card shadow-sm">
                                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">Автоматическое принятие решений на просмотр работ</h6>
                                </div>
                                <div class="card-body">
                                    @if (snapshot == null)
                                    {
                                        <div class="text-center py-5">
                                            <div class="spinner-border text-primary" role="status">
                                                <span class="visually-hidden">Загрузка...</span>
                                            </div>
                                            <p class="mt-2">Загрузка данных...</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="row">
                                            <!-- Левая колонка: Автоматическое принятие -->
                                            <div class="col-md-6">
                                                <div class="card mb-3">
                                                    <div class="card-header bg-success@(settingsDto.SettingsApplications.AutoAgreeWorkApplicationsEnabled ? "" : "-subtle") text-white">
                                                        <h6 class="mb-0 d-flex justify-content-between">
                                                            <i class="bi bi-check-circle me-2"></i>
                                                            Автоматическое принятие заявлений
                                                            <button type="button" class="btn btn-light btn-sm" @onclick="@(() => settingsDto.SettingsApplications.AutoAgreeWorkApplicationsEnabled = !settingsDto.SettingsApplications.AutoAgreeWorkApplicationsEnabled)">
                                                                <i class="bi bi-toggle-@(settingsDto.SettingsApplications.AutoAgreeWorkApplicationsEnabled ? "on" : "off")"></i>
                                                            </button>
                                                        </h6>
                                                    </div>
                                                    <div class="card-body">
                                                        <p class="text-muted small mb-3">
                                                            Заявления от следующих структур будут автоматически приняты
                                                        </p>
                                        
                                                        @if (settingsDto.SettingsApplications.AutoAgreeWorkApplications.Any())
                                                        {
                                                            <div class="mb-3">
                                                                @foreach (var kvp in settingsDto.SettingsApplications.AutoAgreeWorkApplications)
                                                                {
                                                                    <div class="card mb-2 border-success">
                                                                        <div class="card-body py-2">
                                                                            <div class="d-flex justify-content-between align-items-start">
                                                                                <div class="flex-grow-1">
                                                                                    <strong>Принимающая структура:</strong>
                                                                                    <div class="ms-3 small">
                                                                                        @GetStructureInfo(kvp.Key)
                                                                                    </div>
                                                                                    <strong class="mt-2">Автоматически принимаются от:</strong>
                                                                                    <div class="ms-3">
                                                                                        @foreach (var source in kvp.Value)
                                                                                        {
                                                                                            <div class="badge bg-secondary me-1 mb-1 p-2">
                                                                                                @GetShortStructureInfo(source)
                                                                                                <button type="button"
                                                                                                        class="btn-close btn-close-white ms-2"
                                                                                                        style="font-size: 0.6rem;"
                                                                                                        @onclick="@(() => RemoveAutoRule(kvp.Key, source, true))">
                                                                                                </button>
                                                                                            </div>
                                                                                        }
                                                                                    </div>
                                                                                </div>
                                                                                <button type="button"
                                                                                        class="btn btn-sm btn-outline-primary"
                                                                                        @onclick="@(() => ShowEditRules(kvp, true))">
                                                                                    <i class="bi bi-pen"></i>
                                                                                </button>
                                                                                <button type="button"
                                                                                        class="btn btn-sm btn-outline-danger"
                                                                                        @onclick="@(() => RemoveAllAutoRules(kvp.Key, true))">
                                                                                    <i class="bi bi-trash"></i>
                                                                                </button>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="alert alert-info">
                                                                <i class="bi bi-info-circle"></i> Нет настроенных правил автоматического принятия
                                                            </div>
                                                        }
                                        
                                                        <button type="button" class="btn btn-success btn-sm w-100" @onclick="() => ShowAddRuleModal(true)">
                                                            <i class="bi bi-plus-circle me-2"></i>Добавить правило принятия
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Правая колонка: Автоматическое отклонение -->
                                            <div class="col-md-6">
                                                <div class="card mb-3">
                                                    <div class="card-header bg-danger@(settingsDto.SettingsApplications.AutoDenyWorkApplicationsEnabled ? "" : "-subtle") text-white">
                                                        <h6 class="mb-0 d-flex justify-content-between">
                                                            <i class="bi bi-x-circle me-2"></i>
                                                            Автоматическое отклонение заявлений
                                                            <button type="button" class="btn btn-light btn-sm" @onclick="@(() => settingsDto.SettingsApplications.AutoDenyWorkApplicationsEnabled = !settingsDto.SettingsApplications.AutoDenyWorkApplicationsEnabled)">
                                                                <i class="bi bi-toggle-@(settingsDto.SettingsApplications.AutoDenyWorkApplicationsEnabled ? "on" : "off")"></i>
                                                            </button>
                                                        </h6>
                                                    </div>
                                                    <div class="card-body">
                                                        <p class="text-muted small mb-3">
                                                            Заявления от следующих структур будут автоматически отклонены
                                                        </p>
                                        
                                                        @if (settingsDto.SettingsApplications.AutoDenyWorkApplications.Any())
                                                        {
                                                            <div class="mb-3">
                                                                @foreach (var kvp in settingsDto.SettingsApplications.AutoDenyWorkApplications)
                                                                {
                                                                    <div class="card mb-2 border-danger">
                                                                        <div class="card-body py-2">
                                                                            <div class="d-flex justify-content-between align-items-start">
                                                                                <div class="flex-grow-1">
                                                                                    <strong>Отклоняющая структура:</strong>
                                                                                    <div class="ms-3 small">
                                                                                        @GetStructureInfo(kvp.Key)
                                                                                    </div>
                                                                                    <strong class="mt-2">Автоматически отклоняются от:</strong>
                                                                                    <div class="ms-3">
                                                                                        @foreach (var source in kvp.Value)
                                                                                        {
                                                                                            <div class="badge bg-secondary me-1 mb-1 p-2">
                                                                                                @GetShortStructureInfo(source)
                                                                                                <button type="button"
                                                                                                        class="btn-close btn-close-white ms-2"
                                                                                                        style="font-size: 0.6rem;"
                                                                                                        @onclick="@(() => RemoveAutoRule(kvp.Key, source, false))">
                                                                                                </button>
                                                                                            </div>
                                                                                        }
                                                                                    </div>
                                                                                </div>
                                                                                <button type="button"
                                                                                        class="btn btn-sm btn-outline-danger"
                                                                                        @onclick="@(() => RemoveAllAutoRules(kvp.Key, false))">
                                                                                    <i class="bi bi-trash"></i>
                                                                                </button>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="alert alert-info">
                                                                <i class="bi bi-info-circle"></i> Нет настроенных правил автоматического отклонения
                                                            </div>
                                                        }
                                        
                                                        <button type="button" class="btn btn-danger btn-sm w-100" @onclick="() => ShowAddRuleModal(false)">
                                                            <i class="bi bi-plus-circle me-2"></i>Добавить правило отклонения
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Расширения файлов -->
                        <div class="col-md-12">
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">Разрешенные типы файлов и их расширения</h6>
                                    <button type="button" class="btn btn-sm btn-light" @onclick="AddNewFileType">
                                        <i class="bi bi-plus-circle"></i> Добавить тип файла
                                    </button>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        @foreach (var fileType in settingsDto.AllowedFiles.Keys.ToList())
                                        {
                                            var fileTypeName = fileType;
                                            var extensions = settingsDto.AllowedFiles[fileTypeName];
                    
                                            <div class="col-md-4 col-lg-3 mb-3">
                                                <div class="card h-100">
                                                    <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                                        <span class="fw-bold small">@fileTypeName</span>
                                                        @if (fileTypeName != "Пояснительная записка (Pdf)")
                                                        {
                                                            <button type="button" class="btn btn-sm btn-link text-danger p-0"
                                                                    @onclick="() => RemoveFileType(fileTypeName)">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        }
                                                    </div>
                                                    <div class="card-body p-2">
                                                        <div class="input-group input-group-sm mb-2">
                                                            <input type="text" class="form-control"
                                                                   placeholder=".ext"
                                                                   @bind="newExtensionInputs[fileTypeName]"
                                                                   @bind:event="oninput"
                                                                   @onkeypress="(e) => HandleExtensionKeyPress(e, fileTypeName)" />
                                                            <button type="button" class="btn btn-success btn-sm"
                                                                    @onclick="() => AddExtension(fileTypeName)">
                                                                <i class="bi bi-plus"></i>
                                                            </button>
                                                        </div>
                                                        <div class="list-group list-group-flush" style="max-height: 200px; overflow-y: auto;">
                                                            @foreach (var ext in extensions)
                                                            {
                                                                <div class="list-group-item d-flex justify-content-between align-items-center p-1 ps-2">
                                                                    <span class="small">@ext</span>
                                                                    <button type="button" class="btn btn-sm btn-link text-danger p-0"
                                                                            @onclick="() => RemoveExtension(fileTypeName, ext)">
                                                                        <i class="bi bi-x"></i>
                                                                    </button>
                                                                </div>
                                                            }
                                                            @if (!extensions.Any())
                                                            {
                                                                <div class="text-muted small text-center p-2">
                                                                    Нет расширений
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Необходимые файлы для типов работ -->
                        <div class="col-md-12">
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">Необходимые файлы для типов работ</h6>
                                    <button type="button" class="btn btn-sm btn-light" @onclick="AddNewWorkTypeRequirement">
                                        <i class="bi bi-plus-circle"></i> Добавить тип работы
                                    </button>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover">
                                            <thead class="table-light">
                                                <tr>
                                                    <th style="width: 20%">Тип работы</th>
                                                    <th style="width: 70%">Необходимые файлы</th>
                                                    <th style="width: 10%">Действия</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var requiredFile in settingsDto.RequiredFiles.ToList())
                                                {
                                                    var workTypeName = requiredFile.Key;
                                                    var requiredFilesList = requiredFile.Value;
                            
                                                    <tr>
                                                        <td>
                                                            <select class="form-select form-select-sm"
                                                                    @bind="workTypeSelections[workTypeName]"
                                                                    @bind:after="() => OnWorkTypeChanged(workTypeName)">
                                                                <option value="">Выберите тип работы</option>
                                                                @foreach (var workType in workTypes)
                                                                {
                                                                    <option value="@workType.Название">@workType.Название</option>
                                                                }
                                                            </select>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex flex-wrap gap-1">
                                                                @foreach (var file in requiredFilesList)
                                                                {
                                                                    <span class="badge bg-primary d-inline-flex align-items-center gap-1">
                                                                        @file
                                                                        <button type="button" class="btn-close btn-close-white btn-sm"
                                                                                style="font-size: 0.5rem;"
                                                                                @onclick="() => RemoveRequiredFile(workTypeName, file)"></button>
                                                                    </span>
                                                                }
                                                                <div class="input-group input-group-sm" style="width: auto;">
                                                                    <select class="form-select form-select-sm"
                                                                            style="width: auto; min-width: 150px;"
                                                                            @bind="newRequiredFileInputs[workTypeName]">
                                                                        <option value="">Выберите файл...</option>
                                                                        @foreach (var fileType in settingsDto.AllowedFiles.Keys)
                                                                        {
                                                                            <option value="@fileType">@fileType</option>
                                                                        }
                                                                    </select>
                                                                    <button type="button" class="btn btn-success btn-sm"
                                                                            @onclick="() => AddRequiredFile(workTypeName)">
                                                                        <i class="bi bi-plus"></i>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td class="text-center">
                                                            <button type="button" class="btn btn-sm btn-danger"
                                                                    @onclick="() => RemoveWorkTypeRequirement(workTypeName)">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Кнопки -->
                        <div class="col-12">
                            <div class="d-flex justify-content-between">
                                <button type="button" class="btn btn-secondary" @onclick="Cancel">Отмена</button>
                                <button type="submit" class="btn btn-primary" disabled="@isSaving">Сохранить настройки</button>
                            </div>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    
    <!-- Модальное окно для добавления нового типа файла -->
    <div class="modal fade @(showAddFileTypeModal ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Добавление типа файла</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddFileTypeModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Название типа файла</label>
                        <input type="text" class="form-control" @bind="newFileTypeName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Начальные расширения (через запятую)</label>
                        <input type="text" class="form-control" @bind="newFileTypeExtensions"
                               placeholder=".doc, .docx, .pdf" />
                        <small class="text-muted">Пример: .doc, .docx, .pdf</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseAddFileTypeModal">Отмена</button>
                    <button type="button" class="btn btn-primary" @onclick="AddNewFileTypeConfirm">Добавить</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Модальное окно для добавления нового требования к типу работы -->
    <div class="modal fade @(showAddWorkTypeModal ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Добавление требований для типа работы</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddWorkTypeModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Тип работы</label>
                        <select class="form-select" @bind="newWorkTypeForRequirement">
                            <option value="">Выберите тип работы</option>
                            @foreach (var workType in workTypes)
                            {
                                <option value="@workType.Название">@workType.Название</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Начальный набор файлов</label>
                        <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var fileType in settingsDto.AllowedFiles.Keys)
                            {
                                var currentFileType = fileType; // Локальная переменная для замыкания
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           value="@currentFileType"
                                           checked="@IsFileTypeSelected(currentFileType)"
                                           @onchange="@(e => ToggleFileTypeSelection(currentFileType, e.Value is true))" />
                                    <label class="form-check-label">@currentFileType</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseAddWorkTypeModal">Отмена</button>
                    <button type="button" class="btn btn-primary" @onclick="AddNewWorkTypeRequirementConfirm">Добавить</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Модальное окно для добавления правила -->
    <div class="modal @(showRuleModal ? "show d-block" : "d-none")" tabindex="-1" role="dialog" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header @(isAgreeRule ? "bg-success" : "bg-danger") text-white">
                    <h5 class="modal-title">
                        <i class="bi @(isAgreeRule ? "bi-check-circle" : "bi-x-circle") me-2"></i>
                        Добавить правило @(isAgreeRule ? "принятия" : "отклонения")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseRuleModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-12 mb-3">
                            <h6 class="fw-bold">Выберите структуру, которая будет @(isAgreeRule ? "принимать" : "отклонять"):</h6>
                            <div class="card border-primary">
                                <div class="card-body p-3">
                                    <StructureSelector @bind-Value="targetStructure"
                                                       @bind-Value:after="() => SetStructuresData(targetStructure)"
                                                       Snapshot="snapshot"
                                                       DisableInstitute="@true"
                                                       DisableDepartment="@true"
                                                       @key="targetStructure" />
                                </div>
                            </div>
                        </div>
                    
                        <!-- Аккордеон источников -->
                        <div class="row">
                            <div class="col-12">
                                <h6 class="fw-bold mt-2 text-secondary">
                                    <i class="bi bi-diagram-3 me-2"></i>
                                    Структуры-источники (от которых будут автоматически @(isAgreeRule ? "приниматься" : "отклоняться") заявления):
                                </h6>
                        
                                <div class="accordion" id="sourcesAccordion">
                                    @for (int i = 0; i < sourceStructures.Count; i++)
                                    {
                                        int index = i;
                                        var source = sourceStructures[index];
                                        string accordionId = $"source_{index}";
                                        string collapseId = $"collapse_{accordionId}";
                                
                                        <div class="accordion-item mb-2 border rounded">
                                            <div class="accordion-header d-flex align-items-center p-2 bg-light">
                                                <div class="flex-grow-1">
                                                    <button class="btn btn-link text-decoration-none fw-bold p-0 me-3"
                                                            type="button"
                                                            data-bs-toggle="collapse"
                                                            data-bs-target="#@collapseId"
                                                            aria-expanded="false"
                                                            aria-controls="@collapseId">
                                                        Источник @(index + 1)
                                                    </button>
                                                    <span class="badge bg-secondary ms-2">
                                                        @GetShortStructureInfo(source)
                                                    </span>
                                                </div>
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger ms-2"
                                                        @onclick="@(() => RemoveSourceStructure(index))"
                                                        onclick:stopPropagation="true">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                    
                                            <div id="@collapseId"
                                                 class="accordion-collapse collapse"
                                                 data-bs-parent="#sourcesAccordion">
                                                <div class="accordion-body p-3">
                                                    <StructureSelector @bind-Value="sourceStructures[index]"
                                                                       @bind-Value:after="() => SetStructuresData(sourceStructures[index])"
                                                                       Snapshot="snapshot"
                                                                       @key="sourceStructures[index]" />
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                        
                                <button class="btn btn-outline-primary btn-sm w-100 mt-3" @onclick="AddSourceStructure">
                                    <i class="bi bi-plus-circle me-2"></i>Добавить источник
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseRuleModal">Отмена</button>
                    <button type="button" class="btn @(isAgreeRule ? "btn-success" : "btn-danger")" @onclick="AddRule">
                        <i class="bi bi-save me-2"></i>Сохранить правило
                    </button>
                </div>
            </div>
        </div>
    </div>

}


@code {
    private TeacherDisplayDto? responsible;
    private НастройкиКафедры settings = new();
    private SettingsDepartment settingsDto = new();
    private bool isSaving = false;

    private List<ТипРаботы> workTypes = null!;

    private Dictionary<string, string> newExtensionInputs = new();
    private Dictionary<string, string> newRequiredFileInputs = new();
    private Dictionary<string, string> workTypeSelections = new();

    private ReferenceDataSnapshot snapshot = null!;

    // Модальные окна
    private bool showAddFileTypeModal = false;
    private bool showAddWorkTypeModal = false;
    // Данные для нового типа файла
    private string newFileTypeName = "";
    private string newFileTypeExtensions = "";
    // Данные для нового типа работы
    private string newWorkTypeForRequirement = "";
    private List<string> selectedFilesForNewWorkType = new();

    private List<Угсн> filteredUgsns = new();
    private List<Направление> filteredDirections = new();
    private List<Профиль> filteredProfiles = new();
    private List<Кафедра> filteredDepartments = new();
    private bool showRuleModal = false;
    private bool isAgreeRule = true;
    private bool isEdit = false;
    private StructureDto targetStructure = new();
    private List<StructureDto> sourceStructures = new();

    protected override async Task OnInitializedAsync()
    {
        if (RendererInfo.IsInteractive)
        {
            await GetStructureInfo();
            await LoadSettings();
            await LoadData();
        }
    }

    private async Task GetStructureInfo()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        ClaimsPrincipal user = authState!.User;
        int idUser = int.Parse(user.Claims.First(x => x.Type == ClaimTypes.NameIdentifier).Value);
        List<string> departmentRoles = [Settings.RoleDepartmentHeadName, Settings.RoleDepartmentResponsibleName];

        responsible = (await UserService.GetTeacherDisplayAsync(idUser))
            .Where(x => x.Активно == true && x.Роли.Exists(y => departmentRoles.Contains(y.Название)))
            .FirstOrDefault();
    }

    private async Task LoadSettings()
    {
        settings = await SettingsService.GetSettings<НастройкиКафедры>(responsible!.Структура.Кафедра.IdКафедры)
                        ?? new() { IdКафедры = responsible!.Структура.Кафедра.IdКафедры };

        if (settings.Настройки != null)
        {
            settingsDto = (await SettingsService.GetSettingsJson<SettingsDepartment>(settings.Настройки))!;
        }
    }

    private async Task LoadData()
    {
        snapshot = await RefDataService.GetSnapshotAsync();
        workTypes = snapshot.WorkTypes.OrderBy(w => w.Название).ToList();
        InitializeDictionaries();

        
        foreach (var kvp in settingsDto.SettingsApplications.AutoAgreeWorkApplications)
        {
            SetStructuresData(kvp.Key);
            foreach (var source in kvp.Value)
            {
                SetStructuresData(source);
            }
        }

        foreach (var kvp in settingsDto.SettingsApplications.AutoDenyWorkApplications)
        {
            SetStructuresData(kvp.Key);
            foreach (var source in kvp.Value)
            {
                SetStructuresData(source);
            }
        }

        StateHasChanged();
    }

    private void InitializeDictionaries()
    {
        // Инициализация словарей для ввода расширений
        foreach (var fileType in settingsDto.AllowedFiles.Keys)
        {
            if (!newExtensionInputs.ContainsKey(fileType))
                newExtensionInputs[fileType] = "";
        }

        // Инициализация словарей для выбора файлов
        foreach (var requiredFile in settingsDto.RequiredFiles.Keys)
        {
            if (!newRequiredFileInputs.ContainsKey(requiredFile))
                newRequiredFileInputs[requiredFile] = "";
            if (!workTypeSelections.ContainsKey(requiredFile))
                workTypeSelections[requiredFile] = requiredFile;
        }
    }

    private async Task SaveSettings()
    {
        isSaving = true;
        StateHasChanged();
        try
        {
            await SettingsService.AddSettingsAsJson(settingsDto, settings);
            await SettingsService.Upsert(settings);

            await JSRuntime.InvokeVoidAsync("alert", "Настройки сохранены");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/department");
    }



    private void ShowAddRuleModal(bool isAgree)
    {
        isEdit = false;
        isAgreeRule = isAgree;
        targetStructure = new StructureDto()
        {
            Институт = responsible!.Структура.Институт,
            Кафедра = responsible!.Структура.Кафедра,
        };
        sourceStructures = new List<StructureDto>();
        showRuleModal = true;
        StateHasChanged();
    }

    private void ShowEditRules(KeyValuePair<StructureDto, List<StructureDto>> target, bool isAgree)
    {
        isEdit = true;
        isAgreeRule = isAgree;
        targetStructure = new(target.Key);
        sourceStructures = new(target.Value);
        SetStructuresData(targetStructure);
        showRuleModal = true;
        StateHasChanged();
    }

    private void CloseRuleModal()
    {
        showRuleModal = false;
        StateHasChanged();
    }

    private void AddSourceStructure()
    {
        sourceStructures.Add(new StructureDto());
        StateHasChanged();
    }

    private void RemoveSourceStructure(int index)
    {
        if (index >= 0 && index < sourceStructures.Count)
        {
            sourceStructures.RemoveAt(index);
            StateHasChanged();
        }
    }

    private void AddRule()
    {
        if (targetStructure.Институт.IdИнститута == 0)
        {
            JSRuntime.InvokeVoidAsync("alert", "Выберите принимающую структуру");
            return;
        }

        SetStructuresData(targetStructure);

        var validSources = sourceStructures.Where(s => s.Институт.IdИнститута != 0).ToList();
        if (!validSources.Any())
        {
            JSRuntime.InvokeVoidAsync("alert", "Добавьте хотя бы один источник");
            return;
        }

        Dictionary<StructureDto, List<StructureDto>> auto;
        if (isAgreeRule)
        {
            if (!settingsDto.SettingsApplications.AutoAgreeWorkApplications.ContainsKey(targetStructure))
                settingsDto.SettingsApplications.AutoAgreeWorkApplications[targetStructure] = new List<StructureDto>();
            auto = settingsDto.SettingsApplications.AutoAgreeWorkApplications;

        }
        else
        {
            if (!settingsDto.SettingsApplications.AutoDenyWorkApplications.ContainsKey(targetStructure))
                settingsDto.SettingsApplications.AutoDenyWorkApplications[targetStructure] = new List<StructureDto>();
            auto = settingsDto.SettingsApplications.AutoDenyWorkApplications;
        }

        if (isEdit)
        {
            // При редактировании сначала удаляем все старые правила для этой структуры
            auto.Remove(targetStructure);
            auto[targetStructure] = [];
        }

        foreach (var source in validSources)
        {
            // Проверка на дубликат
            if (!auto[targetStructure].Any(s =>
                s.Институт.IdИнститута == source.Институт.IdИнститута &&
                s.Кафедра.IdКафедры == source.Кафедра.IdКафедры &&
                s.Угсн.IdУгсн == source.Угсн.IdУгсн &&
                s.УгснСтандарт.IdУгснСтандарта == source.УгснСтандарт.IdУгснСтандарта &&
                s.Направление.IdНаправления == source.Направление.IdНаправления &&
                (s.Профиль?.IdПрофиля == source.Профиль?.IdПрофиля)))
            {
                SetStructuresData(source);

                auto[targetStructure].Add(source);
            }
        }

        CloseRuleModal();
    }

    private void SetStructuresData(StructureDto structure)
    {
        StructureDto result = new()
        {
            Институт = snapshot.Institutes.FirstOrDefault(x => x.IdИнститута == structure.Институт.IdИнститута) ?? new(),
            Кафедра = snapshot.Departments.FirstOrDefault(x => x.IdКафедры == structure.Кафедра.IdКафедры) ?? new(),
            Угсн = snapshot.Ugsns.FirstOrDefault(x => x.IdУгсн == structure.Угсн.IdУгсн) ?? new(),
            УгснСтандарт = snapshot.UgsnStandards.FirstOrDefault(x => x.IdУгснСтандарта == structure.УгснСтандарт.IdУгснСтандарта) ?? new(),
            Направление = snapshot.Directions.FirstOrDefault(x => x.IdНаправления == structure.Направление.IdНаправления) ?? new(),
            Профиль = structure.Профиль is null ? null : snapshot.Profiles.First(x => x.IdПрофиля == structure.Профиль.IdПрофиля)
        };
        structure.Copy(result);
    }

    private void RemoveAutoRule(StructureDto target, StructureDto source, bool isAgree)
    {
        Dictionary<StructureDto, List<StructureDto>> auto;
        auto = isAgree
            ? settingsDto.SettingsApplications.AutoAgreeWorkApplications
            : settingsDto.SettingsApplications.AutoDenyWorkApplications;

        if (auto.TryGetValue(target, out var sources))
        {
            sources.RemoveAll(s =>
                s.Институт.IdИнститута == source.Институт.IdИнститута &&
                s.Кафедра.IdКафедры == source.Кафедра.IdКафедры &&
                s.Угсн.IdУгсн == source.Угсн.IdУгсн &&
                s.УгснСтандарт.IdУгснСтандарта == source.УгснСтандарт.IdУгснСтандарта &&
                s.Направление.IdНаправления == source.Направление.IdНаправления &&
                (s.Профиль?.IdПрофиля == source.Профиль?.IdПрофиля));

            if (!sources.Any())
                auto.Remove(target);
        }
        StateHasChanged();
    }

    private async Task RemoveAllAutoRules(StructureDto target, bool isAgree)
    {
        Dictionary<StructureDto, List<StructureDto>> auto;
        auto = isAgree
            ? settingsDto.SettingsApplications.AutoAgreeWorkApplications
            : settingsDto.SettingsApplications.AutoDenyWorkApplications;

        if (await JSRuntime.InvokeAsync<bool>("confirm", "Вы уверены?"))
        {
            auto.Remove(target);
            StateHasChanged();
        }
    }

    private string GetStructureInfo(StructureDto structure)
    {
        var parts = new List<string>();

        if (structure.Институт.IdИнститута != 0)
            parts.Add($"Институт: {StructureDto.Abbreviate(structure.Институт.Название, true)}");

        if (structure.Кафедра.IdКафедры != 0)
            parts.Add($"Кафедра: {StructureDto.Abbreviate(structure.Кафедра.Название)}");

        if (structure.УгснСтандарт.IdУгснСтандарта != 0)
            parts.Add($"Стандарт: {structure.УгснСтандарт.Название}");

        if (structure.Угсн.IdУгсн != 0)
            parts.Add($"УГСН: {StructureDto.Abbreviate(structure.Угсн.Название)}");

        if (structure.Направление.IdНаправления != 0)
            parts.Add($"Направление: {StructureDto.Abbreviate(structure.Направление.Название)}");

        if (structure.Профиль?.IdПрофиля != 0 && structure.Профиль != null)
            parts.Add($"Профиль: {StructureDto.Abbreviate(structure.Профиль.Название)}");

        return string.Join(" → ", parts);
    }

    private string GetShortStructureInfo(StructureDto structure)
    {
        if (structure.Профиль?.IdПрофиля != 0 && structure.Профиль != null)
            return StructureDto.Abbreviate(structure.Профиль.Название);
        if (structure.Направление.IdНаправления != 0)
            return StructureDto.Abbreviate(structure.Направление.Название);
        if (structure.Угсн.IdУгсн != 0)
            return StructureDto.Abbreviate(structure.Угсн.Название);
        if (structure.УгснСтандарт.IdУгснСтандарта != 0)
            return structure.УгснСтандарт.Название;
        if (structure.Кафедра.IdКафедры != 0)
            return StructureDto.Abbreviate(structure.Кафедра.Название);
        if (structure.Институт.IdИнститута != 0)
            return StructureDto.Abbreviate(structure.Институт.Название, true);
        ;
        
        return "Не указано";
    }



    // Управление расширениями файлов
    private void AddExtension(string fileTypeName)
    {
        var newExt = newExtensionInputs[fileTypeName];
        
        if (string.IsNullOrWhiteSpace(newExt))
            return;
        
        if (!newExt.StartsWith("."))
            newExt = "." + newExt;
        
        if (!settingsDto.AllowedFiles.ContainsKey(fileTypeName))
            return;
        
        var extensions = settingsDto.AllowedFiles[fileTypeName];
        if (!extensions.Contains(newExt))
        {
            extensions.Add(newExt);
            newExtensionInputs[fileTypeName] = "";
            StateHasChanged();
        }
    }
    
    private void RemoveExtension(string fileTypeName, string extension)
    {
        if (settingsDto.AllowedFiles.TryGetValue(fileTypeName, out var extensions))
        {
            extensions.Remove(extension);
            
            // Если расширений не осталось, можно предложить удалить тип файла
            if (!extensions.Any())
            {
                // Опционально: показать предупреждение
            }
            
            StateHasChanged();
        }
    }
    
    private void HandleExtensionKeyPress(KeyboardEventArgs e, string fileTypeName)
    {
        if (e.Key == "Enter")
            AddExtension(fileTypeName);
    }
    
    // Управление типами файлов
    private void AddNewFileType()
    {
        newFileTypeName = "";
        newFileTypeExtensions = "";
        showAddFileTypeModal = true;
        StateHasChanged();
    }
    
    private void AddNewFileTypeConfirm()
    {
        if (string.IsNullOrWhiteSpace(newFileTypeName))
            return;
        
        if (settingsDto.AllowedFiles.ContainsKey(newFileTypeName))
        {
            // Показать ошибку - такой тип уже существует
            return;
        }
        
        var extensions = newFileTypeExtensions
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(e => e.Trim())
            .Where(e => e.StartsWith("."))
            .ToList();
        
        if (!extensions.Any())
        {
            extensions.Add(".txt"); // Расширение по умолчанию
        }
        
        settingsDto.AllowedFiles[newFileTypeName] = extensions;
        newExtensionInputs[newFileTypeName] = "";
        
        CloseAddFileTypeModal();
        StateHasChanged();
    }
    
    private void RemoveFileType(string fileTypeName)
    {
        // Проверяем, не используется ли этот тип в RequiredFiles
        var isUsed = settingsDto.RequiredFiles.Values.Any(files => files.Contains(fileTypeName));
        
        if (isUsed)
        {
            // Показать предупреждение, что тип используется в требованиях
            return;
        }
        
        settingsDto.AllowedFiles.Remove(fileTypeName);
        newExtensionInputs.Remove(fileTypeName);
        
        StateHasChanged();
    }
    
    private void CloseAddFileTypeModal()
    {
        showAddFileTypeModal = false;
        StateHasChanged();
    }

    // Проверка, выбран ли тип файла
    private bool IsFileTypeSelected(string fileType)
    {
        return selectedFilesForNewWorkType.Contains(fileType);
    }

    // Переключение выбора типа файла
    private void ToggleFileTypeSelection(string fileType, bool isSelected)
    {
        if (isSelected)
        {
            if (!selectedFilesForNewWorkType.Contains(fileType))
            {
                selectedFilesForNewWorkType.Add(fileType);
            }
        }
        else
        {
            selectedFilesForNewWorkType.Remove(fileType);
        }
        StateHasChanged();
    }
    
    // Управление необходимыми файлами для типов работ
    private void AddNewWorkTypeRequirement()
    {
        newWorkTypeForRequirement = "";
        selectedFilesForNewWorkType = new List<string>();
        showAddWorkTypeModal = true;
        StateHasChanged();
    }
    
    private void AddNewWorkTypeRequirementConfirm()
    {
        if (string.IsNullOrWhiteSpace(newWorkTypeForRequirement))
            return;
        
        if (settingsDto.RequiredFiles.ContainsKey(newWorkTypeForRequirement))
        {
            // Такой тип работы уже есть в требованиях
            return;
        }
        
        settingsDto.RequiredFiles[newWorkTypeForRequirement] = new List<string>(selectedFilesForNewWorkType);
        newRequiredFileInputs[newWorkTypeForRequirement] = "";
        workTypeSelections[newWorkTypeForRequirement] = newWorkTypeForRequirement;
        
        CloseAddWorkTypeModal();
        StateHasChanged();
    }
    
    private void RemoveWorkTypeRequirement(string workTypeName)
    {
        settingsDto.RequiredFiles.Remove(workTypeName);
        newRequiredFileInputs.Remove(workTypeName);
        workTypeSelections.Remove(workTypeName);
        
        StateHasChanged();
    }
    
    private void AddRequiredFile(string workTypeName)
    {
        var selectedFile = newRequiredFileInputs[workTypeName];
        
        if (string.IsNullOrWhiteSpace(selectedFile))
            return;
        
        if (!settingsDto.RequiredFiles.ContainsKey(workTypeName))
        {
            settingsDto.RequiredFiles[workTypeName] = new List<string>();
        }
        
        var requiredFiles = settingsDto.RequiredFiles[workTypeName];
        if (!requiredFiles.Contains(selectedFile))
        {
            requiredFiles.Add(selectedFile);
            newRequiredFileInputs[workTypeName] = "";
            
            StateHasChanged();
        }
    }
    
    private void RemoveRequiredFile(string workTypeName, string requiredFile)
    {
        if (settingsDto.RequiredFiles.TryGetValue(workTypeName, out var requiredFiles))
        {
            requiredFiles.Remove(requiredFile);
            
            if (!requiredFiles.Any())
            {
                // Если не осталось обязательных файлов, удаляем запись
                settingsDto.RequiredFiles.Remove(workTypeName);
                newRequiredFileInputs.Remove(workTypeName);
                workTypeSelections.Remove(workTypeName);
            }
            
            StateHasChanged();
        }
    }
    
    private void OnWorkTypeChanged(string oldKey)
    {
        var newKey = workTypeSelections[oldKey];
        
        if (oldKey != newKey && !string.IsNullOrEmpty(newKey))
        {
            // Переносим данные из старого ключа в новый
            if (settingsDto.RequiredFiles.TryGetValue(oldKey, out var files))
            {
                settingsDto.RequiredFiles[newKey] = files;
                settingsDto.RequiredFiles.Remove(oldKey);
                
                if (newRequiredFileInputs.ContainsKey(oldKey))
                {
                    newRequiredFileInputs[newKey] = newRequiredFileInputs[oldKey];
                    newRequiredFileInputs.Remove(oldKey);
                }
                
                workTypeSelections.Remove(oldKey);
                workTypeSelections[newKey] = newKey;
            }
        }
    }
    
    private void CloseAddWorkTypeModal()
    {
        showAddWorkTypeModal = false;
        StateHasChanged();
    }

