@using ArchiveFqp.Components.Components
@using ArchiveFqp.Interfaces.ReferenceData
@using ArchiveFqp.Interfaces.Teacher
@using ArchiveFqp.Interfaces.User
@using ArchiveFqp.Models
@using ArchiveFqp.Models.DTO.Structure
@using ArchiveFqp.Models.DTO.Student
@using ArchiveFqp.Models.DTO.Teacher
@using ArchiveFqp.Models.DatabaseNotification
@using ArchiveFqp.Models.ReferenceData
@using ArchiveFqp.Models.Search
@using ArchiveFqp.Models.Settings.SettingsArchive
@using ArchiveFqp.Services.ReferenceData
@using Microsoft.EntityFrameworkCore
@using Newtonsoft.Json
@using Newtonsoft.Json.Serialization
@inject IReferenceDataService RefDataService
@inject ITeacherService TeacherService
@inject IUserService UserService
@inject SettingsArchive Settings
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="table-responsive">
    <div class="mb-3">
        <div class="row">
            <div class="col-auto d-flex align-items-end">
                <button class="btn btn-success btn-sm" @onclick="OpenCreateModal">
                    <i class="bi bi-plus-circle"></i> Добавить преподавателя
                </button>
            </div>
            <div class="col-md-4 pt-1">
                <input type="text" class="form-control"
                       @bind="searchText"
                       @bind:event="oninput"
                       placeholder="Введите ФИО для поиска преподавателя" />
            </div>
        </div>
    </div>
    
    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>Статус</th>
                <th>Пользователь</th>
                <th>Роли</th>
                <th>Институт</th>
                <th>Кафедра</th>
                <th>Должность</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @if (Teachers == null)
            {
                <tr><td colspan="6" class="text-center">Загрузка...</td></tr>
            }
            else if (filteredTeachers.Count == 0)
            {
                <tr><td colspan="6" class="text-center">Нет данных</td></tr>
            }
            else
            {
                @foreach (var teacher in filteredTeachers.Skip((Teachers.CurrentPage - 1) * Teachers.PageSize).Take(Teachers.PageSize).ToList())
                {
                    var teacherRoles = teacher.Роли;
                    bool isVerifying = teacher.Роли.Exists(x => x.Название == Settings.RoleTeacherOnVerifyName);
                    
                    <tr>
                        <td>
                            @if (isVerifying)
                            {
                                <span class="badge bg-danger">Подтвердите препод-ля</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Подтвержден</span>
                            }
                        </td>
                        <td>
                            @teacher.Пользователь.ФИО
                            @if (teacher.IdПреподавателя == Responsible.IdПреподавателя)
                            {
                                <div class="mt-1">
                                    <span class="badge bg-info">Это Вы</span>
                                </div>
                            }
                        </td>
                        <td>
                            @if (teacherRoles.Count != 0)
                            {
                                foreach (var role in departmentRoles)
                                {
                                    if (teacherRoles.Exists(x => x.Название == role.Название))
                                    {
                                        <div>
                                            <span class="badge bg-primary me-1 mb-1">@role.Название</span>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                <div>
                                    <span class="badge bg-secondary me-1 mb-1">Нет аккаунта</span>
                                </div>
                            }
                        </td>
                        <td>@teacher.Структура.Институт.Название</td>
                        <td>@teacher.Структура.Кафедра.Название</td>
                        <td>@teacher.Должность.Название</td>
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => OpenEditModal(teacher.ToTeacher())">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteTeacher(teacher.IdПреподавателя)"
                                    disabled="@isVerifying">
                                <i class="bi bi-trash"></i>
                            </button>
                            @if (isVerifying)
                            {
                                <button class="btn btn-sm btn-success" @onclick="() => ApproveTeacher(teacher)">
                                    <i class="bi bi-check"></i>
                                </button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DenyTeacher(teacher)">
                                    <i class="bi bi-x"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- Модальное окно для пользователя -->
@if (snapshot != null)
{
    <div class="modal fade @(showModal ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5)" @onclick:stopPropagation>
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">@(isEdit ? "Редактирование" : "Добавление") пользователя</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="@selectedTeacher" OnValidSubmit="@SaveTeacher" FormName="teacherForm">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Пользователь *</label>
                            <SearchableSelect TItem="Пользователь"
                                              TValue="int"
                                              Items="@users"
                                              TextSelector="@((s) => string.Join(" ", s.Фамилия, s.Имя, s.Отчество))"
                                              ValueSelector="@(s => s.IdПользователя)"
                                              Placeholder="Выберите или введите пользователя..."
                                              @bind-SelectedValue="@selectedTeacher.IdПользователя"
                                              OnCustomValue="@(() => selectedTeacher.IdПользователя = 0)"
                                              Disabled="@isEdit" />
                            <ValidationMessage For="() => selectedTeacher.IdПользователя" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Должность *</label>
                            <InputSelect class="form-select" @bind-Value="selectedTeacher.IdДолжности">
                                <option value="0"></option>
                                @foreach (Должность position in snapshot.Posts.OrderBy(x => x.Название))
                                {
                                    <option value="@position.IdДолжности">@position.Название</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => selectedTeacher.IdДолжности" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Институт *</label>
                            <InputSelect class="form-select" @bind-Value="selectedTeacher.IdИнститута"
                                         @bind-Value:after="OnInstituteChanged" disabled>
                                <option value="0"></option>
                                @foreach (Институт institute in snapshot.Institutes.OrderBy(x => x.Название))
                                {
                                    <option value="@institute.IdИнститута">@institute.Название</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => selectedTeacher.IdИнститута" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Кафедра *</label>
                            <InputSelect class="form-select" @bind-Value="selectedTeacher.IdКафедры"
                                         disabled>
                                <option value="0"></option>
                                @foreach (Кафедра department in filteredDepartments.OrderBy(x => x.Название))
                                {
                                    <option value="@department.IdКафедры">@department.Название</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => selectedTeacher.IdКафедры" />
                        </div>
                        @if (selectedTeacher.IdПреподавателя != 0)
                        {
                            <div class="mb-3">
                                <label class="form-label">Роли</label>
                                <div class="border p-3 rounded">
                                    @foreach (var role in departmentRoles)
                                    {
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input"
                                                   @onchange="@((e) => ToggleRole(role.IdРоли, (bool)e.Value!))"
                                                   checked="@selectedTeacher.Роли.Contains(role.IdРоли)" />
                                            <label class="form-check-label">@role.Название</label>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" type="button" @onclick="CloseModal">Отмена</button>
                        <button class="btn btn-primary" type="submit">Сохранить</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}
@code {
    [Parameter] public TeacherDisplayDto Responsible { get; set; } = null!;
    [Parameter] public PaginatedResult<TeacherDisplayDto>? Teachers { get; set; }
    [Parameter] public EventCallback<int> TeachersChanged { get; set; }
    private List<Пользователь> users = null!;
    private Преподаватель selectedTeacher = new();
    private ReferenceDataSnapshot snapshot = null!;
    private bool showModal = false;
    private bool isEdit = false;

    private List<РольУчреждения> departmentRoles = null!;

    private List<Кафедра> filteredDepartments = new();

    private string searchText = "";
    private List<TeacherDisplayDto> filteredTeachers
    {
        get
        {
            List<TeacherDisplayDto> res = Teachers?.Items
                .OrderByDescending(x =>
                {
                    int isVerifying = x.Роли.Exists(x => x.Название == Settings.RoleTeacherOnVerifyName) ? 1 : 0;
                    int isDepartmentRole = x.Роли.Any(x => departmentRoles.Contains(x)) ? 1 : 0;
                    return isVerifying + isDepartmentRole;
                })
                .ThenBy(x => x.Пользователь.ФИО).ToList() ?? [];

            if (string.IsNullOrWhiteSpace(searchText))
                return res;

            return res.Where(item =>
                {
                    return item.Пользователь.ФИО.Contains(searchText, StringComparison.OrdinalIgnoreCase);
                }).ToList() ?? [];
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Teachers ??= new() { CurrentPage = 1, PageSize = 10 };
        await LoadData();
        RefDataService.TablesChanged += OnTablesChanged;

        List<string> temp = [Settings.RoleDepartmentHeadName,
                          Settings.RoleDepartmentResponsibleName,
                          Settings.RoleDepartmentClerkName];
        departmentRoles = snapshot.RolesOrganization.Where(x => temp.Contains(x.Название)).ToList();
    }

    private async Task LoadData()
    {
        snapshot = await RefDataService.GetSnapshotAsync();
        List<Преподаватель> teachers = (await RefDataService.GetAsync<Преподаватель>())
            .Where(x => x.IdКафедры == Responsible.Структура.Кафедра.IdКафедры).ToList();
        Teachers!.Items = await TeacherService.GetTeacherDisplayAsync(teachers);
        users = await RefDataService.GetAsync<Пользователь>();
        await TeachersChanged.InvokeAsync(1);
        StateHasChanged();
    }

    private async Task ChangePage(int page)
    {
        Teachers!.CurrentPage = page;
        StateHasChanged();
    }

    private async Task OpenCreateModal()
    {
        selectedTeacher = new()
        {
            IdИнститута = Responsible.Структура.Институт.IdИнститута,
            IdКафедры = Responsible.Структура.Кафедра.IdКафедры
        };
        await UpdateDependentLists();
        isEdit = false;
        showModal = true;
        StateHasChanged();
    }

    private async Task OpenEditModal(Преподаватель teacher)
    {
        selectedTeacher = teacher;
        await UpdateDependentLists();
        isEdit = true;
        showModal = true;
        StateHasChanged();
    }

    private void CloseModal()
    {
        showModal = false;
        StateHasChanged();
    }

    private async Task SaveTeacher()
    {
        try
        {
            string message = await TeacherService.Upsert(selectedTeacher) ? "Обновлено" : "Добавлено";
            CloseModal();
            await JSRuntime.InvokeVoidAsync("alert", message + " успешно");
        }
        catch (DbUpdateException ex)
        {
            string errorMessage = ex.InnerException?.Message ?? "";
            if (errorMessage.Contains("преподаватель_преподаватель_key"))
                errorMessage = "Преподаватель уже существует";

            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {errorMessage}");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private async Task DeleteTeacher(int id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Удалить преподавателя?"))
        {
            try
            {
                await TeacherService.Delete<Преподаватель>(id, true);
                await JSRuntime.InvokeVoidAsync("alert", "Преподаватель удален успешно");
            }
            catch (DbUpdateException ex)
            {
                string errorMessage = ex.InnerException?.Message ?? "";
                if (errorMessage.Contains(ReferenceDataService.GetTableName<Работа>()))
                    await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: Преподаватель является руководителем работ");
                else if (errorMessage.Contains(ReferenceDataService.GetTableName<Консультант>()))
                    await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: Преподаватель является консультантом работ");
                else if (errorMessage.Contains(ReferenceDataService.GetTableName<Рецензент>()))
                    await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: Преподаватель является рецензентом работ");
                else if (errorMessage.Contains(ReferenceDataService.GetTableName<ОценкаПреподавателя>()))
                    await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: Преподаватель имеет выставленные оценки");
                else
                    await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {errorMessage}");
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
            }
        }
    }

    private async Task ApproveTeacher(TeacherDisplayDto teacher)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Преподаватель точно принадлежит вашей кафедре?\nЕсли какие-то данные неверны, Вы можете их изменить."))
        {
            АккаунтПользователя? account = null;
            Преподаватель approvedTeacher = teacher.ToTeacher();
            approvedTeacher.Активно = true;
            approvedTeacher.Роли.Remove(snapshot.RolesOrganization.First(x => x.Название == Settings.RoleTeacherOnVerifyName).IdРоли);
            string message = "Преподаватель подтвержден и ему была присвоена роль преподавателя.";

            try
            {
                await TeacherService.Upsert(approvedTeacher);

                if (await VerifyTeacher(account, teacher))
                {
                    message += "\n\nУ преподавателя отсутстовал аккаунт и он был создан с базовыми логином и паролем:"
                            + $"\nЛогин: {account!.Логин}"
                            + $"\nПароль: {string.Join("", teacher.Пользователь.ФИО, StructureDto.Abbreviate(teacher.Структура.Кафедра.Название), 2026)}";
                }
                await JSRuntime.InvokeVoidAsync("alert", message);
            }
            catch (DbUpdateException ex)
            {
                string errorMessage = ex.InnerException?.Message ?? ex.Message;
                if (errorMessage.Contains("login_key"))
                    errorMessage = "У преподавателя отсутствует аккаунт и при добавлении базового "
                                   + $"аккаунта, аккаунт с логином {account!.Логин} уже существует";

                await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {errorMessage}");
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
            }
        }
    }

    // Возвращает true, если аккаунт создан, false - если просто изменены роли
    private async Task<bool> VerifyTeacher(АккаунтПользователя? account, TeacherDisplayDto teacher)
    {
        account = await UserService.GetUserAccountAsync(teacher.Пользователь.Пользователь);
        if (account == null)
        {
            account = await UserService.AddAccountTeacherDefault(teacher);
            return true;
        }
        else
        {
            List<РольУчреждения> roles = await RefDataService.GetAsync<РольУчреждения>();
                    
            // Добавляем роль Преподаватель, если отсутствует
            int idTeacherRole = account.Роли.FindIndex(x => x == roles.First(x => x.Название == Settings.RoleTeacherName).IdРоли);
            if (idTeacherRole == -1) account.Роли.Add(roles.First(x => x.Название == Settings.RoleTeacherName).IdРоли);

            await UserService.Upsert(account);
            return false;
        }
    }

    private async Task DenyTeacher(TeacherDisplayDto teacher)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Преподаватель точно НЕ принадлежит вашей кафедре?\nЕсли какие-то данные неверны, Вы можете их изменить."))
        {
            if (await TeacherService.Delete<Преподаватель>(teacher.IdПреподавателя, true))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Преподаватель отклонен");
            }
        }
    }

    private async Task UpdateDependentLists()
    {
        if (selectedTeacher.IdИнститута == 0)
            filteredDepartments = snapshot.Departments.ToList();
        else
            filteredDepartments = snapshot.Departments
                .Where(d => d.IdИнститута == selectedTeacher.IdИнститута)
                .DistinctBy(d => d.Название)
                .ToList();
    }


    private async Task OnInstituteChanged()
    {
        selectedTeacher.IdКафедры = 0;
        await UpdateDependentLists();
    }

    private void ToggleRole(int role, bool isSelected)
    {
        if (isSelected && !selectedTeacher.Роли.Contains(role))
        {
            selectedTeacher.Роли.Add(role);
        }
        else if (!isSelected && selectedTeacher.Роли.Contains(role))
        {
            selectedTeacher.Роли.Remove(role);
        }
    }

    private async void OnTablesChanged(object? sender, TableChangeEvent e)
    {
        await InvokeAsync(async () =>
        {
            JsonSerializerSettings options = new()
            { ContractResolver = new DefaultContractResolver { NamingStrategy = new SnakeCaseNamingStrategy() } };
            string json;

            if (e.TableName == nameof(Преподаватель))
            {
                json = e.New?.ToString() ?? e.Old!.ToString();
                Преподаватель? teacher = JsonConvert.DeserializeObject<Преподаватель>(json, options);

                // Пропускаем, если преподавтель не относится к кафедре
                if (teacher is null
                    || Responsible.Структура.Кафедра.IdКафедры != teacher.IdКафедры)
                    return;

                if (e.ChangeType == TableChangeType.Insert)
                {
                    Teachers!.Items.Add(await TeacherService.GetTeacherDisplayAsync(teacher));
                }
                else
                {
                    int index = Teachers!.Items.FindIndex(x => x.IdПреподавателя == teacher.IdПреподавателя);
                    if (index == -1) return;
                    if (e.ChangeType == TableChangeType.Update)
                        Teachers!.Items[index] = await TeacherService.GetTeacherDisplayAsync(teacher);
                    else Teachers!.Items.RemoveAt(index);
                }
                await TeachersChanged.InvokeAsync(1);
            }
            else if (e.TableName == nameof(АккаунтПользователя))
            {
                json = e.New?.ToString() ?? e.Old!.ToString();
                АккаунтПользователя? account = JsonConvert.DeserializeObject<АккаунтПользователя>(json, options);

                if (account is null) return;
                int index = Teachers!.Items.FindIndex(x => x.Пользователь.Пользователь.IdПользователя == account.IdПользователя);
                if (index == -1) return;

                if (e.ChangeType == TableChangeType.Delete)
                {
                    Teachers!.Items.RemoveAt(index);
                    await TeachersChanged.InvokeAsync(1);
                }
                else await LoadData();
            }
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        RefDataService.TablesChanged -= OnTablesChanged;
    }
}