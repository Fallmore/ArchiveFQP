@page "/department/works"
@using ArchiveFqp.Components.Components
@using ArchiveFqp.Components.Pages.Works.Add
@using ArchiveFqp.Components.Pages.WorksApplications
@using ArchiveFqp.Factories.DisplayDto.Student
@using ArchiveFqp.Factories.DisplayDto.Teacher
@using ArchiveFqp.Interfaces.ReferenceData
@using ArchiveFqp.Interfaces.User
@using ArchiveFqp.Interfaces.Work
@using ArchiveFqp.Models
@using ArchiveFqp.Models.DTO.Attribute
@using ArchiveFqp.Models.DTO.Teacher
@using ArchiveFqp.Models.DTO.Work
@using ArchiveFqp.Models.DatabaseNotification
@using ArchiveFqp.Models.ReferenceData
@using ArchiveFqp.Models.Search
@using ArchiveFqp.Services.FileUpload
@using ArchiveFqp.Services.ReferenceData
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using Newtonsoft.Json
@using Newtonsoft.Json.Serialization
@inject AuthenticationStateProvider AuthStateProvider
@inject IUserService UserService
@inject IDbContextFactory<ArchiveFqpContext> DbFactory
@inject NavigationManager NavigationManager
@inject WorkFileUploadService FileUploadService
@inject IReferenceDataService RefDataService
@inject IWorkService WorkService
@inject IJSRuntime JSRuntime
@implements IDisposable
@attribute [Authorize(Roles = "Ответственный кафедры, Завкафедрой")]
@rendermode @(new InteractiveServerRenderMode())

<PageTitle>Панель кафедры - Управление работами</PageTitle>

@if (RendererInfo.IsInteractive)
{
    <div class="container-fluid mt-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-file-earmark-text me-2"></i>Управление работами<br />кафедры @responsible!.Структура.Кафедра.Название
                    </h4>
                    <button class="btn btn-light btn-sm" @onclick="@(() => NavigationManager.NavigateTo("/department"))">
                        <i class="bi bi-arrow-left"></i> Назад
                    </button>
                </div>
            </div>
            <div class="card-body">

                <!-- Поисковая панель -->
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-12">
                                <div class="input-group mb-3">
                                    <input type="text"
                                           class="form-control"
                                           placeholder="Введите название работы..."
                                           @bind="searchModel.SearchText" />
                                    <button class="btn btn-outline-secondary z-0" type="button" @onclick="@(async () => { await SearchWorks(); })">
                                        <i class="bi bi-search"></i> Найти
                                    </button>
                                    <button class="btn @(advancedSearch ? "btn-primary" : "btn-outline-primary") z-0" type="button" @onclick="ToggleAdvancedSearch"
                                            data-bs-toggle="collapse" data-bs-target="#collapseAdvancedSearch"
                                            aria-expanded="false" aria-controls="collapseAdvancedSearch">
                                        <i class="bi bi-funnel"></i> Расширенный поиск
                                    </button>
                                    <button class="btn btn-outline-secondary z-0" type="button" @onclick="ClearSearch">
                                        <i class="bi bi-x"></i> Очистить
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Расширенный поиск -->
                        <div class="collapse" id="collapseAdvancedSearch">
                            <div class="card card-body">
                                <div class="row mt-2">
                                    <div class="col-md-3 mb-3">
                                        <label class="form-label mb-0 fw-bold">Количество страниц</label>
                                        <div class="row d-flex justify-content-center align-items-center">
                                            <div class="col">
                                                <select class="form-select" @bind="searchModel.MinPages"
                                                        placeholder="С">
                                                    <option value=""></option>
                                                    @{
                                                        int maxP = searchModel.MaxPages ?? maxPage;
                                                        foreach (var i in Enumerable.Range(minPage, maxP - minPage + 1))
                                                        {
                                                            <option value="@i">@i</option>
                                                        }
                                                    }
                                                </select>
                                            </div>
                                            <label class="col-sm-1 col-form-label d-flex justify-content-center align-items-center">—</label>
                                            <div class="col">
                                                <select class="form-select" @bind="searchModel.MaxPages"
                                                        placeholder="По">
                                                    <option value=""></option>
                                                    @{
                                                        int minP = searchModel.MinPages ?? minPage;
                                                        foreach (var i in Enumerable.Range(minP, maxPage - minP + 1))
                                                        {
                                                            <option value="@i">@i</option>
                                                        }
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        <label class="form-label mb-0 fw-bold">Год защиты</label>
                                        <div class="row d-flex justify-content-center align-items-center">
                                            <div class="col">
                                                <select class="form-select" @bind="searchModel.MinYearDefense"
                                                        placeholder="С">
                                                    <option value=""></option>
                                                    @foreach (var i in Enumerable.Range(minYear, maxYear - minYear + 1))
                                                    {
                                                        <option value="@i">@i</option>
                                                    }
                                                </select>
                                            </div>
                                            <label class="col-sm-1 col-form-label d-flex justify-content-center align-items-center">—</label>
                                            <div class="col">
                                                <select class="form-select" @bind="searchModel.MaxYearDefense"
                                                        placeholder="По">
                                                    <option value=""></option>
                                                    @foreach (var i in Enumerable.Range(minYear, maxYear - minYear + 1))
                                                    {
                                                        <option value="@i">@i</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        <label class="form-label mb-0 fw-bold">Дата добавления</label>
                                        <div class="row d-flex justify-content-center align-items-center">
                                            <div class="col-sm-5" style="padding-left:0px;padding-right:2px">
                                                <InputDate class="form-control" @bind-Value="searchModel.MinDateAdded" />
                                            </div>
                                            <label class="col-sm-1 col-form-label d-flex justify-content-center align-items-center">—</label>
                                            <div class="col-sm-5" style="padding-right:0px;padding-left:2px">
                                                <InputDate class="form-control" @bind-Value="searchModel.MaxDateAdded" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        <label class="form-label mb-0 fw-bold">Дата изменения</label>
                                        <div class="row d-flex justify-content-center align-items-center">
                                            <div class="col-sm-5" style="padding-left:0px;padding-right:5px">
                                                <InputDate class="form-control" @bind-Value="searchModel.MinDateChanged" />
                                            </div>
                                            <label class="col-sm-1 col-form-label d-flex justify-content-center align-items-center">—</label>
                                            <div class="col-sm-5" style="padding-right:0px;padding-left:5px">
                                                <InputDate class="form-control" @bind-Value="searchModel.MaxDateChanged" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        <label class="form-label mb-0 fw-bold">Тип работы</label>
                                        <select class="form-select" @bind="searchModel.IdWorkType">
                                            <option value="-1">Все</option>
                                            @foreach (var type in snapshot.WorkTypes)
                                            {
                                                <option value="@type.IdТипаРаботы">@type.Название</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        <label class="form-label mb-0 fw-bold">Статус работы</label>
                                        <select class="form-select" @bind="searchModel.IdWorkStatus">
                                            <option value="-1">Все</option>
                                            @foreach (var status in snapshot.WorkStatuses)
                                            {
                                                <option value="@status.IdСтатусаРаботы">@status.Название</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        <label class="form-label mb-0 fw-bold">Доступ работы</label>
                                        <select class="form-select" @bind="searchModel.IdWorkAccess">
                                            <option value="-1"></option>
                                            @foreach (var access in snapshot.WorkAccess.OrderBy(x => x.IdДоступаРаботы))
                                            {
                                                <option value="@access.IdДоступаРаботы">@access.Название</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-3 mb-2">
                                        <label class="form-label mb-0 fw-bold">Студент</label>
                                        <SearchableSelect TItem="Студент"
                                                          TValue="int?"
                                                          Items="@workStudents"
                                                          TextSelector="@((s) => studentDtoFactory!.CreateDisplayDtoAsync(s).Result.Пользователь.ФИО)"
                                                          ValueSelector="@(s => s.IdСтудента)"
                                                          Placeholder="Выберите или введите студента..."
                                                          @bind-SelectedValue="@searchModel.IdStudent"
                                                          OnCustomValue="@(() => searchModel.IdStudent = null)" />
                                    </div>

                                    <div class="col-md-3  ">
                                        <label class="form-label mb-0 fw-bold">Руководитель</label>
                                        <SearchableSelect TItem="Преподаватель"
                                                          TValue="int?"
                                                          Items="workTeachers"
                                                          TextSelector="@((s) => teacherDtoFactory!.CreateDisplayDtoAsync(s).Result.Пользователь.ФИО)"
                                                          ValueSelector="@(s => s.IdПреподавателя)"
                                                          Placeholder="Выберите или введите руководителя..."
                                                          @bind-SelectedValue="@searchModel.IdTeacher"
                                                          OnCustomValue="@(() => searchModel.IdTeacher = null)" />
                                    </div>

                                    <div class="col-md-3 ">
                                        <MultipleSearchableSelect TItem="Преподаватель"
                                                                  TValue="int"
                                                                  Label="Консультанты"
                                                                  Placeholder="Введите или выберите ФИО консультанта..."
                                                                  DefaultValue="-1"
                                                                  @bind-SelectedValues="searchModel.IdConsultants"
                                                                  Items="workTeachers"
                                                                  TextSelector="@(t => teacherDtoFactory!.CreateDisplayDtoAsync(t).Result.Пользователь.ФИО)"
                                                                  ValueSelector="@(t => t.IdПреподавателя)"
                                                                  OnCustomValue="@((i) => searchModel.IdConsultants[i] = -1)" />
                                    </div>

                                    <div class="col-md-3">
                                        <MultipleSearchableSelect TItem="Преподаватель"
                                                                  TValue="int"
                                                                  Label="Рецензенты"
                                                                  Placeholder="Введите или выберите ФИО рецензента..."
                                                                  DefaultValue="-1"
                                                                  @bind-SelectedValues="searchModel.IdReviewers"
                                                                  Items="workTeachers"
                                                                  TextSelector="@(t => teacherDtoFactory!.CreateDisplayDtoAsync(t).Result.Пользователь.ФИО)"
                                                                  ValueSelector="@(t => t.IdПреподавателя)"
                                                                  OnCustomValue="@((i) => searchModel.IdReviewers[i] = -1)" />
                                    </div>

                                    <!-- Структура учреждения -->
                                    <div class="col-md-3">
                                        <label class="form-label mb-0 fw-bold">Направление</label>
                                        <InputSelectSctructure TItem="Направление"
                                                               Items="snapshot.Directions.OrderBy(x => x.Название)"
                                                               @bind-Value="searchModel.IdDirection"
                                                               Snapshot="snapshot"
                                                               DefaultTooltip="Все" />
                                    </div>

                                    <div class="col-md-3">
                                        <label class="form-label mb-0 fw-bold">Профиль</label>
                                        <InputSelectSctructure TItem="Профиль"
                                                               Items="snapshot.Profiles.OrderBy(x => x.Название)"
                                                               @bind-Value="searchModel.IdProfile"
                                                               Snapshot="snapshot"
                                                               DefaultTooltip="Все" />
                                    </div>
                                </div>

                                <!-- Поиск по атрибутам -->
                                <div class="row mt-3">
                                    <div class="accordion" id="accordionAttributes">
                                        <div class="accordion-item">
                                            <button class="accordion-button collapsed" style="height:40px;" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAttributes" aria-expanded="true" aria-controls="collapseAttributes">
                                                <h5><strong>Атрибуты</strong></h5>
                                            </button>
                                            <div id="collapseAttributes" class="accordion-collapse collapse" aria-labelledby="headingOne">
                                                <div class="accordion-body">
                                                    <div class="row">
                                                        @foreach (var attribute in searchModel.AllAttributes)
                                                        {
                                                            <div class="col-md-4 mb-0">
                                                                <div class="card mb-2">
                                                                    <div class="card-body py-2">
                                                                        <div class="form-check">
                                                                            <input class="form-check-input"
                                                                                   type="checkbox"
                                                                                   id="attr-@(attribute.IdАтрибута)"
                                                                                   @onchange="@((e) => ToggleAttribute(attribute.IdАтрибута, ((bool)e.Value!)))"
                                                                                   checked="@(searchModel.SelectedAttributes.ContainsKey(attribute.IdАтрибута) ? true : false)" />
                                                                            <label class="form-check-label fw-bold" for="attr-@(attribute.IdАтрибута)">
                                                                                @(attribute.Название)
                                                                            </label>
                                                                        </div>

                                                                        @if (searchModel.SelectedAttributes.ContainsKey(attribute.IdАтрибута))
                                                                        {
                                                                            <div class="mt-2">
                                                                                <select class="form-select form-select-sm"
                                                                                        @onchange="@((e) => UpdateAttributeValue(attribute.IdАтрибута, e.Value?.ToString()))">
                                                                                    <option value="">Выберите значение</option>
                                                                                    @foreach (var value in searchModel.AttributeValues.FirstOrDefault(av => av.IdАтрибута == attribute.IdАтрибута)?.Данные ?? [])
                                                                                    {
                                                                                        <option selected="@(searchModel.SelectedAttributes[attribute.IdАтрибута] == value ? true : false)"
                                                                                                value="@value">@value</option>
                                                                                    }
                                                                                </select>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @if (isLoading)
                {
                    <div class="text-center mt-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Загрузка...</span>
                        </div>
                        <p class="mt-2">Поиск работ...</p>
                    </div>
                }
                else if (filteredWorks == null || works == null || filteredWorks.Items.Count == 0)
                {
                    <div class="alert alert-info mt-4">
                        <i class="bi bi-info-circle"></i> Работы не найдены
                    </div>
                }
                else
                {
                    <!-- Информация о результатах -->
                    <div class="row mb-3 ">
                        <div class="col-auto d-flex align-items-center">
                            <p class="text-muted mt-0">
                                Найдено работ: @filteredWorks.TotalCount
                            </p>
                        </div>
                        <div class="col">
                            <button class="btn btn-success" @onclick="OpenIssueModal"
                                    disabled="@(!filteredWorks.Items.Any(x => x.Выделено))">
                                <i class="bi bi-arrow-up"></i> Выдать выделенные работы
                            </button>
                        </div>
                    </div>

                    <!-- Таблица работ -->
                    <div class="table-responsive">
                        <table class="table table-hover table-striped">
                            <thead class="table-dark">
                                <tr>
                                    <th>
                                        <InputCheckbox class="form-check-input"
                                                       @bind-Value="allSelected"
                                                       @bind-Value:after="AllSelect" />
                                    </th>
                                    <th>Тема</th>
                                    <th>Студент</th>
                                    <th>Руководитель</th>
                                    <th>Тип</th>
                                    <th>Доступ</th>
                                    <th>Статус</th>
                                    <th>Дата добавления</th>
                                    <th>Дата изменения</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var work in filteredWorks.Items.Skip((filteredWorks.CurrentPage - 1) * filteredWorks.PageSize).Take(filteredWorks.PageSize))
                                {
                                    <tr>
                                        <td>
                                            <InputCheckbox class="form-check-input"
                                                           @bind-Value="work.Выделено"
                                                           id="flexCheckDefault" />
                                        </td>
                                        <td>@work.Тема</td>
                                        <td>@work.Студент.Пользователь.ФИО</td>
                                        <td>@work.Руководитель.Пользователь.ФИО</td>
                                        <td>@work.ТипРаботы.Название</td>
                                        <td>
                                            <InputSelect class="form-select" @bind-Value="work.ДоступРаботы.IdДоступаРаботы"
                                                         @bind-Value:after="() => OnWorkAccessChanged(work)"
                                                         @key="@work.IdРаботы">
                                                @foreach (ДоступРаботы workAccess in snapshot.WorkAccess.OrderBy(x => x.IdДоступаРаботы))
                                                {
                                                    <option value="@workAccess.IdДоступаРаботы">@workAccess.Название</option>
                                                }
                                            </InputSelect>
                                        </td>
                                        <td>@work.СтатусРаботы.Название</td>
                                        <td>@work.ДатаДобавления.ToString("dd.MM.yyyy")</td>
                                        <td>@(work.ДатаИзменения?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td>
                                            <button class="btn btn-sm btn-primary" @onclick="() => OpenEditModal(work)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteWork(work.IdРаботы)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Пагинация -->
                    @if (filteredWorks != null && filteredWorks.TotalPages > 1)
                    {
                        <nav>
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(filteredWorks.CurrentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(1)">Первая</button>
                                </li>
                                <li class="page-item @(filteredWorks.CurrentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(filteredWorks.CurrentPage - 1)">Предыдущая</button>
                                </li>
                                @for (int i = Math.Max(1, filteredWorks.CurrentPage - 2); i <= Math.Min(filteredWorks.TotalPages, filteredWorks.CurrentPage + 2); i++)
                                {
                                    int index = i;
                                    <li class="page-item @(filteredWorks.CurrentPage == i ? "active" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(index)">@index</button>
                                    </li>
                                }
                                <li class="page-item @(filteredWorks.CurrentPage == filteredWorks.TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(works.CurrentPage + 1)">Следующая</button>
                                </li>
                                <li class="page-item @(filteredWorks.CurrentPage == filteredWorks.TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(works.TotalPages)">Последняя</button>
                                </li>
                            </ul>
                        </nav>
                    }
                }

            </div>
        </div>
    </div>

    <!-- Модальное окно для редактирования -->
    @if (showEditModal)
    {
        <div class="modal fade @(showEditModal ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5)">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title">Редактирование работы</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="col-12">
                            <div class="card shadow-sm">
                                <div class="card-body">
                                    <WorkDataAdd @bind-WorkDto="@WorkDto"
                                                 EndEdit="CompleteModal"
                                                 IsEdit="true" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CloseModal">Закрыть редактирование</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Модальное окно для выдачи -->
    @if (showIssueModal)
    {
        <div class="modal fade @(showIssueModal ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5)">
        
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title">Выдача работ</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="col-12">
                            <div class="card shadow-sm">
                                <div class="card-body">
                                    <WorkApplicationSend WorksForSend="[..filteredWorks!.Items.Where(x => x.Выделено)]"
                                                         TeacherDtoFactory="teacherDtoFactory"
                                                         Responsible="responsible!"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CloseModal">Закрыть выдачу</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private TeacherDisplayDto? responsible;

    private WorkCreateDto WorkDto { get; set; } = new();
    private WorkSearchModel searchModel = new();
    private bool advancedSearch = false;
    private bool isLoading = false;
    private bool showEditModal = false;
    private bool showIssueModal = false;

    private PaginatedResult<Работа>? works;
    private PaginatedResult<WorkDisplayDto>? filteredWorks;

    private ReferenceDataSnapshot snapshot = null!;
    private List<Пользователь> users = new();
    private List<Студент> workStudents = new();
    private List<Преподаватель> workTeachers = new();
    private List<Преподаватель> workDepartmentTeachers = new();
    private List<Консультант> workConsultants = new();
    private List<Рецензент> workReviewers = new();
    private int minPage, maxPage, minYear, maxYear;
    private TeacherDtoFactory? teacherDtoFactory;
    private StudentDtoFactory? studentDtoFactory;
    private bool allSelected = false;

    protected override async Task OnInitializedAsync()
    {
        if (RendererInfo.IsInteractive)
        {
            teacherDtoFactory = new(RefDataService);
            studentDtoFactory = new(RefDataService);
            await GetStructureInfo();
            await LoadData();

            searchModel.IdInstitute = responsible!.Структура.Институт.IdИнститута;
            searchModel.IdDepartment = responsible!.Структура.Кафедра.IdКафедры;

            await SearchWorks();
            if (filteredWorks?.Items != null && filteredWorks.Items.Count > 0)
            {
                minPage = filteredWorks?.Items.Min(w => w.КоличСтраниц) ?? 1;
                maxPage = filteredWorks?.Items.Max(w => w.КоличСтраниц) ?? 200;
                minYear = filteredWorks?.Items.Min(w => WorkService.PickDateWork(w)) ?? 2000;
                maxYear = filteredWorks?.Items.Max(w => WorkService.PickDateWork(w)) ?? 2050;
            }
            RefDataService.TablesChanged += OnTablesChanged;
        }
    }

    private async Task GetStructureInfo()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        ClaimsPrincipal user = authState!.User;
        int idUser = int.Parse(user.Claims.First(x => x.Type == ClaimTypes.NameIdentifier).Value);
        responsible = (await UserService.GetTeacherDisplayAsync(idUser)).FirstOrDefault(x => x.Активно == true);
    }

    private async Task LoadData()
    {
        snapshot = await RefDataService.GetSnapshotAsync();
        users = await RefDataService.GetAsync<Пользователь>();
        workConsultants = (await WorkService.GetConsultantsAsync()).DistinctBy(c => c.IdПреподавателя).ToList();
        workReviewers = (await WorkService.GetReviewersAsync()).DistinctBy(c => c.IdПреподавателя).ToList();
        searchModel.AllAttributes = await WorkService.GetAllAttributesAsync();
        searchModel.AttributeValues = await WorkService.GetAttributeValuesAsync(searchModel.AllAttributes);
        workStudents = [.. (await WorkService.GetStudentsAsync())
            .Where(x => x.IdКафедры == responsible!.Структура.Кафедра.IdКафедры)
            .OrderBy(s => users.First(u => u.IdПользователя == s.IdПользователя).Фамилия)];
        workTeachers = [.. (await WorkService.GetTeachersAsync())
            .OrderBy(s => users.First(u => u.IdПользователя == s.IdПользователя).Фамилия)];
        workDepartmentTeachers = [.. workTeachers
            .Where(x => x.IdКафедры == responsible!.Структура.Кафедра.IdКафедры)];
        StateHasChanged();
    }

