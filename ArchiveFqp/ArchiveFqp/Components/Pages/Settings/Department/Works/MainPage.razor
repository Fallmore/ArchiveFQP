    private async Task OnWorkAccessChanged(WorkDisplayDto editingWork)
    {
        try
        {
            using var context = DbFactory.CreateDbContext();

            Работа work = context.Работаs.First(x => x.IdРаботы == editingWork.IdРаботы);
            work.IdДоступаРаботы = editingWork.ДоступРаботы.IdДоступаРаботы;
            context.Работаs.Update(work);
            await context.SaveChangesAsync();
            await JSRuntime.InvokeVoidAsync("alert", "Работа обновлена");
        }
        catch (DbUpdateException ex)
        {
            string errorMessage = ex.InnerException?.Message ?? ex.Message;
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {errorMessage}");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private async Task DeleteWork(int id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Удалить работу? Это действие удалит также все файлы работы!"))
        {
            try
            {
                using var context = DbFactory.CreateDbContext();
                var work = await context.Работаs.FindAsync(id);
                if (work != null)
                {
                    FileUploadService.DirectoryDelete(work.Местоположение);
                    context.Работаs.Remove(work);
                    await context.SaveChangesAsync();
                }
            }
            catch (DbUpdateException ex)
            {
                string errorMessage = ex.InnerException?.Message ?? ex.Message;
                if (errorMessage.Contains(ReferenceDataService.GetTableName<ЗаявлениеРаботы>()))
                    errorMessage = "Работа имеет связанные заявления";

                await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {errorMessage}");
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
            }
        }
    }

    private async void OnTablesChanged(object? sender, TableChangeEvent e)
    {
        await InvokeAsync(async () =>
        {
            if (e.TableName == nameof(Работа))
            {
                JsonSerializerSettings options = new()
                { ContractResolver = new DefaultContractResolver { NamingStrategy = new SnakeCaseNamingStrategy() } };
                string json = e.New?.ToString() ?? e.Old!.ToString();

                Работа? work = JsonConvert.DeserializeObject<Работа>(json, options);
                if (work is null) return;
                
                WorkDisplayDto displayDto = await WorkService.GetWorkDisplayAsync(work);
                if (displayDto.Студент.Структура.Кафедра.IdКафедры != responsible!.Структура.Кафедра.IdКафедры)
                    return;

                await LoadData();
                await SearchWorks();
            }
        });
    }

    #region Поиск работ

    private async Task SearchWorks()
    {
        isLoading = true;
        allSelected = false;
        StateHasChanged();

        try
        {
            works = await WorkService.FindWorksAsync(searchModel);

            if (works.Items.Count != 0)
            {
                filteredWorks = new()
                {
                    CurrentPage = works.CurrentPage,
                    PageSize = works.PageSize,
                    Items = await WorkService.GetWorkDisplayAsync(works.Items, [])
                };
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // Разворот расширенного поиска
    private void ToggleAdvancedSearch()
    {
        advancedSearch = !advancedSearch;
    }

    // Разворот атрибута
    private void ToggleAttribute(int attributeId, bool isSelected)
    {
        if (isSelected && !searchModel.SelectedAttributes.ContainsKey(attributeId))
        {
            searchModel.SelectedAttributes[attributeId] = "";
        }
        else if (!isSelected)
        {
            searchModel.SelectedAttributes.Remove(attributeId);
        }
    }

    private void UpdateAttributeValue(int attributeId, string? value)
    {
        if (searchModel.SelectedAttributes.ContainsKey(attributeId))
        {
            searchModel.SelectedAttributes[attributeId] = value ?? "";
        }
    }

    private void ClearSearch()
    {
        List<Атрибут> attr = searchModel.AllAttributes;
        List<AttributeValuesDto> attrVal = searchModel.AttributeValues;
        searchModel = new()
        {
            IdInstitute = responsible!.Структура.Институт.IdИнститута,
            IdDepartment = responsible!.Структура.Кафедра.IdКафедры,
            AllAttributes = attr,
            AttributeValues = attrVal
        };
    }
    
    private async Task ChangePage(int page)
    {
        filteredWorks!.CurrentPage = page;
        StateHasChanged();
    }

    #endregion

    private void AllSelect()
    {
        filteredWorks!.Items.ForEach(x => x.Выделено = allSelected);
    }

    public void Dispose()
    {
        RefDataService.TablesChanged -= OnTablesChanged;
    }
