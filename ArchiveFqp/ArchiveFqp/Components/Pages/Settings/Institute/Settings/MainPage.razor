@page "/institute/settings"
@using ArchiveFqp.Components.Components
@using ArchiveFqp.Interfaces.ReferenceData
@using ArchiveFqp.Interfaces.Settings
@using ArchiveFqp.Interfaces.User
@using ArchiveFqp.Models.DTO.Structure
@using ArchiveFqp.Models.DTO.Teacher
@using ArchiveFqp.Models.ReferenceData
@using ArchiveFqp.Models.Settings.Institute
@using Newtonsoft.Json
@using ArchiveFqp.Models
@using ArchiveFqp.Models.Settings.SettingsArchive
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject ISettingsService SettingsService
@inject IReferenceDataService RefDataService
@inject IUserService UserService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize(Roles = "Ответственный института")]
@rendermode @(new InteractiveServerRenderMode())

<PageTitle>Панель ответственного института - Настройки института</PageTitle>

@if (RendererInfo.IsInteractive && responsible != null)
{
    <div class="container mt-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-gear me-2"></i>Настройки института<br/>@responsible.Структура.Институт.Название.Replace("Институт ", "")
                    </h4>
                    <h6 class="mb-0">Не забудьте сохранить настройки</h6>
                    <button class="btn btn-light btn-sm" @onclick="@(() => NavigationManager.NavigateTo("/institute"))">
                        <i class="bi bi-arrow-left"></i> Назад
                    </button>
                </div>
            </div>
            <div class="card-body">
                <EditForm Model="@settingsDto" OnValidSubmit="@SaveSettings">
                    <div class="row">
                        <!-- Расширения файлов -->
                        <div class="col-md-12">
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">Разрешенные типы файлов и их расширения</h6>
                                    <button type="button" class="btn btn-sm btn-light" @onclick="AddNewFileType">
                                        <i class="bi bi-plus-circle"></i> Добавить тип файла
                                    </button>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        @foreach (var fileType in settingsDto.AllowedFiles.Keys.ToList())
                                        {
                                            var fileTypeName = fileType;
                                            var extensions = settingsDto.AllowedFiles[fileTypeName];
                    
                                            <div class="col-md-4 col-lg-3 mb-3">
                                                <div class="card h-100">
                                                    <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                                        <span class="fw-bold small">@fileTypeName</span>
                                                        @if (fileTypeName != "Пояснительная записка (Pdf)")
                                                        {
                                                            <button type="button" class="btn btn-sm btn-link text-danger p-0"
                                                                    @onclick="() => RemoveFileType(fileTypeName)">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        }
                                                    </div>
                                                    <div class="card-body p-2">
                                                        <div class="input-group input-group-sm mb-2">
                                                            <input type="text" class="form-control"
                                                                   placeholder=".ext"
                                                                   @bind="newExtensionInputs[fileTypeName]"
                                                                   @bind:event="oninput"
                                                                   @onkeypress="(e) => HandleExtensionKeyPress(e, fileTypeName)" />
                                                            <button type="button" class="btn btn-success btn-sm"
                                                                    @onclick="() => AddExtension(fileTypeName)">
                                                                <i class="bi bi-plus"></i>
                                                            </button>
                                                        </div>
                                                        <div class="list-group list-group-flush" style="max-height: 200px; overflow-y: auto;">
                                                            @foreach (var ext in extensions)
                                                            {
                                                                <div class="list-group-item d-flex justify-content-between align-items-center p-1 ps-2">
                                                                    <span class="small">@ext</span>
                                                                    <button type="button" class="btn btn-sm btn-link text-danger p-0"
                                                                            @onclick="() => RemoveExtension(fileTypeName, ext)">
                                                                        <i class="bi bi-x"></i>
                                                                    </button>
                                                                </div>
                                                            }
                                                            @if (!extensions.Any())
                                                            {
                                                                <div class="text-muted small text-center p-2">
                                                                    Нет расширений
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Необходимые файлы для типов работ -->
                        <div class="col-md-12">
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">Необходимые файлы для типов работ</h6>
                                    <button type="button" class="btn btn-sm btn-light" @onclick="AddNewWorkTypeRequirement">
                                        <i class="bi bi-plus-circle"></i> Добавить тип работы
                                    </button>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover">
                                            <thead class="table-light">
                                                <tr>
                                                    <th style="width: 20%">Тип работы</th>
                                                    <th style="width: 70%">Необходимые файлы</th>
                                                    <th style="width: 10%">Действия</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var requiredFile in settingsDto.RequiredFiles.ToList())
                                                {
                                                    var workTypeName = requiredFile.Key;
                                                    var requiredFilesList = requiredFile.Value;
                            
                                                    <tr>
                                                        <td>
                                                            <select class="form-select form-select-sm"
                                                                    @bind="workTypeSelections[workTypeName]"
                                                                    @bind:after="() => OnWorkTypeChanged(workTypeName)">
                                                                <option value="">Выберите тип работы</option>
                                                                @foreach (var workType in workTypes)
                                                                {
                                                                    <option value="@workType.Название">@workType.Название</option>
                                                                }
                                                            </select>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex flex-wrap gap-1">
                                                                @foreach (var file in requiredFilesList)
                                                                {
                                                                    <span class="badge bg-primary d-inline-flex align-items-center gap-1">
                                                                        @file
                                                                        <button type="button" class="btn-close btn-close-white btn-sm"
                                                                                style="font-size: 0.5rem;"
                                                                                @onclick="() => RemoveRequiredFile(workTypeName, file)"></button>
                                                                    </span>
                                                                }
                                                                <div class="input-group input-group-sm" style="width: auto;">
                                                                    <select class="form-select form-select-sm"
                                                                            style="width: auto; min-width: 150px;"
                                                                            @bind="newRequiredFileInputs[workTypeName]">
                                                                        <option value="">Выберите файл...</option>
                                                                        @foreach (var fileType in settingsDto.AllowedFiles.Keys)
                                                                        {
                                                                            <option value="@fileType">@fileType</option>
                                                                        }
                                                                    </select>
                                                                    <button type="button" class="btn btn-success btn-sm"
                                                                            @onclick="() => AddRequiredFile(workTypeName)">
                                                                        <i class="bi bi-plus"></i>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td class="text-center">
                                                            <button type="button" class="btn btn-sm btn-danger"
                                                                    @onclick="() => RemoveWorkTypeRequirement(workTypeName)">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Кнопки -->
                        <div class="col-12">
                            <div class="d-flex justify-content-between">
                                <button type="button" class="btn btn-secondary" @onclick="Cancel">Отмена</button>
                                <button type="submit" class="btn btn-primary">Сохранить настройки</button>
                            </div>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    
    <!-- Модальное окно для добавления нового типа файла -->
    <div class="modal fade @(showAddFileTypeModal ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Добавление типа файла</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddFileTypeModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Название типа файла</label>
                        <input type="text" class="form-control" @bind="newFileTypeName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Начальные расширения (через запятую)</label>
                        <input type="text" class="form-control" @bind="newFileTypeExtensions"
                               placeholder=".doc, .docx, .pdf" />
                        <small class="text-muted">Пример: .doc, .docx, .pdf</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseAddFileTypeModal">Отмена</button>
                    <button type="button" class="btn btn-primary" @onclick="AddNewFileTypeConfirm">Добавить</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Модальное окно для добавления нового требования к типу работы -->
    <div class="modal fade @(showAddWorkTypeModal ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Добавление требований для типа работы</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddWorkTypeModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Тип работы</label>
                        <select class="form-select" @bind="newWorkTypeForRequirement">
                            <option value="">Выберите тип работы</option>
                            @foreach (var workType in workTypes)
                            {
                                <option value="@workType.Название">@workType.Название</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Начальный набор файлов</label>
                        <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var fileType in settingsDto.AllowedFiles.Keys)
                            {
                                var currentFileType = fileType; // Локальная переменная для замыкания
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           value="@currentFileType"
                                           checked="@IsFileTypeSelected(currentFileType)"
                                           @onchange="@(e => ToggleFileTypeSelection(currentFileType, e.Value is true))" />
                                    <label class="form-check-label">@currentFileType</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseAddWorkTypeModal">Отмена</button>
                    <button type="button" class="btn btn-primary" @onclick="AddNewWorkTypeRequirementConfirm">Добавить</button>
                </div>
            </div>
        </div>
    </div>
}


@code {
    private TeacherDisplayDto? responsible;
    private НастройкиИнститута settings = new();
    private SettingsInstitute settingsDto = new();

    private List<ТипРаботы> workTypes = null!;

    private Dictionary<string, string> newExtensionInputs = new();
    private Dictionary<string, string> newRequiredFileInputs = new();
    private Dictionary<string, string> workTypeSelections = new();

    private ReferenceDataSnapshot snapshot = null!;

    // Модальные окна
    private bool showAddFileTypeModal = false;
    private bool showAddWorkTypeModal = false;
    // Данные для нового типа файла
    private string newFileTypeName = "";
    private string newFileTypeExtensions = "";
    // Данные для нового типа работы
    private string newWorkTypeForRequirement = "";
    private List<string> selectedFilesForNewWorkType = new();

    private List<Угсн> filteredUgsns = new();
    private List<Направление> filteredDirections = new();
    private List<Профиль> filteredProfiles = new();
    private List<Кафедра> filteredDepartments = new();
    private StructureDto targetStructure = new();
    private List<StructureDto> sourceStructures = new();

    protected override async Task OnInitializedAsync()
    {
        if (RendererInfo.IsInteractive)
        {
            await GetStructureInfo();
            await LoadSettings();
            await LoadData();
        }
    }

    private async Task GetStructureInfo()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        ClaimsPrincipal user = authState!.User;
        int idUser = int.Parse(user.Claims.First(x => x.Type == ClaimTypes.NameIdentifier).Value);
        responsible = (await UserService.GetTeacherDisplayAsync(idUser)).FirstOrDefault(x => x.Активно == true);
    }

    private async Task LoadSettings()
    {
        settings = await SettingsService.GetSettings<НастройкиИнститута>(responsible!.Структура.Институт.IdИнститута)
                        ?? new() { IdИнститута = responsible!.Структура.Институт.IdИнститута };

        if (settings.Настройки != null)
            settingsDto = (await SettingsService.GetSettingsJson<SettingsInstitute>(settings.Настройки))!;
    }

    private async Task LoadData()
    {
        snapshot = await RefDataService.GetSnapshotAsync();
        workTypes = snapshot.WorkTypes.OrderBy(w => w.Название).ToList();
        InitializeDictionaries();

        StateHasChanged();
    }

    private void InitializeDictionaries()
    {
        // Инициализация словарей для ввода расширений
        foreach (var fileType in settingsDto.AllowedFiles.Keys)
        {
            if (!newExtensionInputs.ContainsKey(fileType))
                newExtensionInputs[fileType] = "";
        }

        // Инициализация словарей для выбора файлов
        foreach (var requiredFile in settingsDto.RequiredFiles.Keys)
        {
            if (!newRequiredFileInputs.ContainsKey(requiredFile))
                newRequiredFileInputs[requiredFile] = "";
            if (!workTypeSelections.ContainsKey(requiredFile))
                workTypeSelections[requiredFile] = requiredFile;
        }
    }

    private async Task SaveSettings()
    {
        try
        {

            await SettingsService.AddSettingsAsJson(settingsDto, settings);
            await SettingsService.Upsert(settings);

            await JSRuntime.InvokeVoidAsync("alert", "Настройки сохранены");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/institute");
    }

    // Управление расширениями файлов
    private void AddExtension(string fileTypeName)
    {
        var newExt = newExtensionInputs[fileTypeName];
        
        if (string.IsNullOrWhiteSpace(newExt))
            return;
        
        if (!newExt.StartsWith("."))
            newExt = "." + newExt;
        
        if (!settingsDto.AllowedFiles.ContainsKey(fileTypeName))
            return;
        
        var extensions = settingsDto.AllowedFiles[fileTypeName];
        if (!extensions.Contains(newExt))
        {
            extensions.Add(newExt);
            newExtensionInputs[fileTypeName] = "";
            StateHasChanged();
        }
    }
    
    private void RemoveExtension(string fileTypeName, string extension)
    {
        if (settingsDto.AllowedFiles.TryGetValue(fileTypeName, out var extensions))
        {
            extensions.Remove(extension);
            
            // Если расширений не осталось, можно предложить удалить тип файла
            if (!extensions.Any())
            {
                // Опционально: показать предупреждение
            }
            
            StateHasChanged();
        }
    }
    
    private void HandleExtensionKeyPress(KeyboardEventArgs e, string fileTypeName)
    {
        if (e.Key == "Enter")
            AddExtension(fileTypeName);
    }
    
    // Управление типами файлов
    private void AddNewFileType()
    {
        newFileTypeName = "";
        newFileTypeExtensions = "";
        showAddFileTypeModal = true;
        StateHasChanged();
    }
    
    private void AddNewFileTypeConfirm()
    {
        if (string.IsNullOrWhiteSpace(newFileTypeName))
            return;
        
        if (settingsDto.AllowedFiles.ContainsKey(newFileTypeName))
        {
            // Показать ошибку - такой тип уже существует
            return;
        }
        
        var extensions = newFileTypeExtensions
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(e => e.Trim())
            .Where(e => e.StartsWith("."))
            .ToList();
        
        if (!extensions.Any())
        {
            extensions.Add(".txt"); // Расширение по умолчанию
        }
        
        settingsDto.AllowedFiles[newFileTypeName] = extensions;
        newExtensionInputs[newFileTypeName] = "";
        
        CloseAddFileTypeModal();
        StateHasChanged();
    }
    
    private void RemoveFileType(string fileTypeName)
    {
        // Проверяем, не используется ли этот тип в RequiredFiles
        var isUsed = settingsDto.RequiredFiles.Values.Any(files => files.Contains(fileTypeName));
        
        if (isUsed)
        {
            // Показать предупреждение, что тип используется в требованиях
            return;
        }
        
        settingsDto.AllowedFiles.Remove(fileTypeName);
        newExtensionInputs.Remove(fileTypeName);
        
        StateHasChanged();
    }
    
    private void CloseAddFileTypeModal()
    {
        showAddFileTypeModal = false;
        StateHasChanged();
    }

    // Проверка, выбран ли тип файла
    private bool IsFileTypeSelected(string fileType)
    {
        return selectedFilesForNewWorkType.Contains(fileType);
    }

    // Переключение выбора типа файла
    private void ToggleFileTypeSelection(string fileType, bool isSelected)
    {
        if (isSelected)
        {
            if (!selectedFilesForNewWorkType.Contains(fileType))
            {
                selectedFilesForNewWorkType.Add(fileType);
            }
        }
        else
        {
            selectedFilesForNewWorkType.Remove(fileType);
        }
        StateHasChanged();
    }
    
    // Управление необходимыми файлами для типов работ
    private void AddNewWorkTypeRequirement()
    {
        newWorkTypeForRequirement = "";
        selectedFilesForNewWorkType = new List<string>();
        showAddWorkTypeModal = true;
        StateHasChanged();
    }
    
    private void AddNewWorkTypeRequirementConfirm()
    {
        if (string.IsNullOrWhiteSpace(newWorkTypeForRequirement))
            return;
        
        if (settingsDto.RequiredFiles.ContainsKey(newWorkTypeForRequirement))
        {
            // Такой тип работы уже есть в требованиях
            return;
        }
        
        settingsDto.RequiredFiles[newWorkTypeForRequirement] = new List<string>(selectedFilesForNewWorkType);
        newRequiredFileInputs[newWorkTypeForRequirement] = "";
        workTypeSelections[newWorkTypeForRequirement] = newWorkTypeForRequirement;
        
        CloseAddWorkTypeModal();
        StateHasChanged();
    }
    
    private void RemoveWorkTypeRequirement(string workTypeName)
    {
        settingsDto.RequiredFiles.Remove(workTypeName);
        newRequiredFileInputs.Remove(workTypeName);
        workTypeSelections.Remove(workTypeName);
        
        StateHasChanged();
    }
    
    private void AddRequiredFile(string workTypeName)
    {
        var selectedFile = newRequiredFileInputs[workTypeName];
        
        if (string.IsNullOrWhiteSpace(selectedFile))
            return;
        
        if (!settingsDto.RequiredFiles.ContainsKey(workTypeName))
        {
            settingsDto.RequiredFiles[workTypeName] = new List<string>();
        }
        
        var requiredFiles = settingsDto.RequiredFiles[workTypeName];
        if (!requiredFiles.Contains(selectedFile))
        {
            requiredFiles.Add(selectedFile);
            newRequiredFileInputs[workTypeName] = "";
            
            StateHasChanged();
        }
    }
    
    private void RemoveRequiredFile(string workTypeName, string requiredFile)
    {
        if (settingsDto.RequiredFiles.TryGetValue(workTypeName, out var requiredFiles))
        {
            requiredFiles.Remove(requiredFile);
            
            if (!requiredFiles.Any())
            {
                // Если не осталось обязательных файлов, удаляем запись
                settingsDto.RequiredFiles.Remove(workTypeName);
                newRequiredFileInputs.Remove(workTypeName);
                workTypeSelections.Remove(workTypeName);
            }
            
            StateHasChanged();
        }
    }
    
    private void OnWorkTypeChanged(string oldKey)
    {
        var newKey = workTypeSelections[oldKey];
        
        if (oldKey != newKey && !string.IsNullOrEmpty(newKey))
        {
            // Переносим данные из старого ключа в новый
            if (settingsDto.RequiredFiles.TryGetValue(oldKey, out var files))
            {
                settingsDto.RequiredFiles[newKey] = files;
                settingsDto.RequiredFiles.Remove(oldKey);
                
                if (newRequiredFileInputs.ContainsKey(oldKey))
                {
                    newRequiredFileInputs[newKey] = newRequiredFileInputs[oldKey];
                    newRequiredFileInputs.Remove(oldKey);
                }
                
                workTypeSelections.Remove(oldKey);
                workTypeSelections[newKey] = newKey;
            }
        }
    }
    
    private void CloseAddWorkTypeModal()
    {
        showAddWorkTypeModal = false;
        StateHasChanged();
    }

}