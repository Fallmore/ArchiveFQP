@page "/institute/works"
@using ArchiveFqp.Components.Pages.Works.Add
@using ArchiveFqp.Interfaces.ReferenceData
@using ArchiveFqp.Interfaces.User
@using ArchiveFqp.Interfaces.Work
@using ArchiveFqp.Models
@using ArchiveFqp.Models.DTO.Teacher
@using ArchiveFqp.Models.DTO.Work
@using ArchiveFqp.Models.DatabaseNotification
@using ArchiveFqp.Models.ReferenceData
@using ArchiveFqp.Services.FileUpload
@using ArchiveFqp.Services.ReferenceData
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject IUserService UserService
@inject IDbContextFactory<ArchiveFqpContext> DbFactory
@inject NavigationManager NavigationManager
@inject WorkFileUploadService FileUploadService
@inject IReferenceDataService RefDataService
@inject IWorkService WorkService
@inject IJSRuntime JSRuntime
@implements IDisposable
@attribute [Authorize(Roles = "Ответственный института")]
@rendermode @(new InteractiveServerRenderMode())

<PageTitle>Панель ответственного института - Управление работами</PageTitle>

@if (RendererInfo.IsInteractive)
{
    <div class="container-fluid mt-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-file-earmark-text me-2"></i>Управление работами<br />института @responsible!.Структура.Институт.Название.Replace("Институт ", "")
                    </h4>
                    <button class="btn btn-light btn-sm" @onclick="@(() => NavigationManager.NavigateTo("/institute"))">
                        <i class="bi bi-arrow-left"></i> Назад
                    </button>
                </div>
            </div>
            <div class="card-body">
                <!-- Поиск -->
                <div class="row mb-3">
                    <div class="col-md-4">
                        <input type="text" class="form-control" placeholder="Поиск по теме/студенту/руководителю..."
                               @bind="searchText" @bind:event="oninput"
                               @bind:after="LoadWorksAsync" />
                    </div>
                    <div class="col-md-2">
                        <select class="form-select" @bind="filterTypeId" @bind:event="onchange"
                                @bind:after="LoadWorksAsync">
                            <option value="">Все типы</option>
                            @foreach (var type in snapshot.WorkTypes)
                            {
                                <option value="@type.IdТипаРаботы">@type.Название</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" @bind="filterStatusId" @bind:event="onchange"
                                @bind:after="LoadWorksAsync">
                            <option value="">Все статусы</option>
                            @foreach (var status in snapshot.WorkStatuses)
                            {
                                <option value="@status.IdСтатусаРаботы">@status.Название</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" @bind="filterAccessId" @bind:event="onchange"
                                @bind:after="LoadWorksAsync">
                            <option value="">Все доступы</option>
                            @foreach (var status in snapshot.WorkAccess.OrderBy(x => x.IdДоступаРаботы))
                            {
                                <option value="@status.IdДоступаРаботы">@status.Название</option>
                            }
                        </select>
                    </div>
                </div>

                <!-- Таблица работ -->
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>Тема</th>
                                <th>Студент</th>
                                <th>Руководитель</th>
                                <th>Тип</th>
                                <th>Доступ</th>
                                <th>Статус</th>
                                <th>Дата добавления</th>
                                <th>Дата изменения</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (filteredWorks == null)
                            {
                                <tr><td colspan="8" class="text-center">Загрузка...</td></tr>
                            }
                            else if (filteredWorks.Count == 0)
                            {
                                <tr><td colspan="8" class="text-center">Нет данных</td></tr>
                            }
                            else
                            {
                                @foreach (var work in filteredWorks)
                                {
                                    <tr>
                                        <td>@work.Тема</td>
                                        <td>@work.Студент.Пользователь.ФИО</td>
                                        <td>@work.Руководитель.Пользователь.ФИО</td>
                                        <td>@work.ТипРаботы.Название</td>
                                        <td>
                                            <InputSelect class="form-select" @bind-Value="work.ДоступРаботы.IdДоступаРаботы"
                                                         @bind-Value:after="() => OnWorkAccessChanged(work)"
                                                         @key="@work.IdРаботы">
                                                @foreach (ДоступРаботы workAccess in snapshot.WorkAccess.OrderBy(x => x.IdДоступаРаботы))
                                                {
                                                    <option value="@workAccess.IdДоступаРаботы">@workAccess.Название</option>
                                                }
                                            </InputSelect>
                                        </td>
                                        <td>@work.СтатусРаботы.Название</td>
                                        <td>@work.ДатаДобавления.ToString("dd.MM.yyyy")</td>
                                        <td>@(work.ДатаИзменения?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td>
                                            @* <button class="btn btn-sm btn-primary" @onclick="() => OpenEditModal(work)">
                                                <i class="bi bi-pencil"></i>
                                            </button> *@
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteWork(work.IdРаботы)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Пагинация -->
                @if (totalPages > 1)
                {
                    <nav>
                        <ul class="pagination justify-content-center">
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(currentPage == i ? "active" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(i)">@i</button>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>

    <!-- TODO: Отладьте изменение, т.к. я его сделал, а потом понял, что он вне функционала диплома...-->
    <!-- Модальное окно для редактирования -->
    @* <div class="modal fade @(showModal ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Редактирование работы</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="col-12">
                        <div class="card shadow-sm">
                            <div class="card-header bg-primary">
                                <h4 class="mb-0 text-white">
                                    <i class="bi bi-plus-circle me-2"></i>Добавление новой работы
                                </h4>
                            
                            </div>
                            <div class="card-body">
                                <WorkDataAdd @bind-WorkDto="@WorkDto"
                                             IsEdit="true" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Отмена</button>
                </div>
            </div>
        </div>
    </div> *@
}


@code {
    private TeacherDisplayDto? responsible;

    private WorkCreateDto WorkDto { get; set; } = new();
    private List<WorkDisplayDto>? works;
    private List<Работа> worksOriginal = new();
    private ReferenceDataSnapshot snapshot = null!;
    private int? filterTypeId;
    private int? filterStatusId;
    private int? filterAccessId;
    private int currentPage = 1;
    private int pageSize = 20;
    private int totalPages = 1;
    private bool showModal = false;

    private string searchText = "";
    private List<WorkDisplayDto>? filteredWorks;

    protected override async Task OnInitializedAsync()
    {
        if (RendererInfo.IsInteractive)
        {
            await GetStructureInfo();
            await LoadData();
            RefDataService.TablesChanged += OnTablesChanged;
        }
    }

    private async Task GetStructureInfo()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        ClaimsPrincipal user = authState!.User;
        int idUser = int.Parse(user.Claims.First(x => x.Type == ClaimTypes.NameIdentifier).Value);
        responsible = await UserService.GetTeacherDisplayAsync(idUser);
    }

    public async Task LoadWorksAsync()
    {
        using ArchiveFqpContext context = DbFactory.CreateDbContext();

        // TODO: если нагружает БД, то воспользуйтесь ReferenceDataService
        worksOriginal = context.Работаs
                .Include(s => s.IdСтудентаNavigation).ThenInclude(s => s.IdПользователяNavigation)
                .Include(s => s.IdПреподавателяNavigation).ThenInclude(s => s.IdПользователяNavigation)
                .Include(s => s.IdТипаРаботыNavigation)
                .Include(s => s.IdСтатусаРаботыNavigation)
                .Include(s => s.IdДоступаРаботыNavigation)
                .Where(item => item.IdСтудентаNavigation.IdИнститута == responsible!.Структура.Институт.IdИнститута
                        && (!filterTypeId.HasValue || item.IdТипаРаботыNavigation.IdТипаРаботы == filterTypeId.Value)
                        && (!filterStatusId.HasValue || item.IdСтатусаРаботыNavigation.IdСтатусаРаботы == filterStatusId.Value)
                        && (!filterAccessId.HasValue || item.IdДоступаРаботыNavigation.IdДоступаРаботы == filterAccessId.Value))
                .AsEnumerable()
                .Where(item => (string.IsNullOrWhiteSpace(searchText) || item.Тема.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                        || (string.IsNullOrWhiteSpace(searchText) || (item.IdСтудентаNavigation.IdПользователяNavigation.Фамилия + " " + item.IdСтудентаNavigation.IdПользователяNavigation.Имя + " " + item.IdСтудентаNavigation.IdПользователяNavigation.Отчество).Contains(searchText, StringComparison.OrdinalIgnoreCase))
                        || (string.IsNullOrWhiteSpace(searchText) || (item.IdПреподавателяNavigation.IdПользователяNavigation.Фамилия + " " + item.IdПреподавателяNavigation.IdПользователяNavigation.Имя + " " + item.IdПреподавателяNavigation.IdПользователяNavigation.Отчество).Contains(searchText, StringComparison.OrdinalIgnoreCase)))
                .ToList();

        filteredWorks = await WorkService.GetWorkDisplayAsync(worksOriginal
                .Skip((currentPage - 1) * pageSize)
                .Take(pageSize).ToList(), []);
    }

    private async Task LoadData()
    {
        snapshot = await RefDataService.GetSnapshotAsync();
        await LoadWorksAsync();
        StateHasChanged();
    }

    private async Task ChangePage(int page)
    {
        currentPage = page;
        filteredWorks = await WorkService.GetWorkDisplayAsync(worksOriginal
                .Skip((currentPage - 1) * pageSize)
                .Take(pageSize).ToList(), []);
        StateHasChanged();
    }

    private void OpenEditModal(WorkDisplayDto work)
    {
        WorkDto = new(work);
        showModal = true;
        StateHasChanged();
    }

    private void CloseModal()
    {
        showModal = false;
        StateHasChanged();
    }

    private async Task OnWorkAccessChanged(WorkDisplayDto editingWork)
    {
        try
        {
            using var context = DbFactory.CreateDbContext();

            Работа work = context.Работаs.First(x => x.IdРаботы == editingWork.IdРаботы);
            work.IdДоступаРаботы = editingWork.ДоступРаботы.IdДоступаРаботы;
            context.Работаs.Update(work);
            await context.SaveChangesAsync();
            await JSRuntime.InvokeVoidAsync("alert", "Работа обновлена");
        }
        catch (DbUpdateException ex)
        {
            string errorMessage = ex.InnerException?.Message ?? ex.Message;
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {errorMessage}");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private async Task DeleteWork(int id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Удалить работу? Это действие удалит также все файлы работы!"))
        {
            try
            {
                using var context = DbFactory.CreateDbContext();
                var work = await context.Работаs.FindAsync(id);
                if (work != null)
                {
                    FileUploadService.DirectoryDelete(work.Местоположение);
                    context.Работаs.Remove(work);
                    await context.SaveChangesAsync();
                }
            }
            catch (DbUpdateException ex)
            {
                string errorMessage = ex.InnerException?.Message ?? ex.Message;
                if (errorMessage.Contains(ReferenceDataService.GetTableName<ЗаявлениеРаботы>()))
                    errorMessage = "Работа имеет связанные заявления";
                
                await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {errorMessage}");
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
            }
        }
    }

    private async void OnTablesChanged(object? sender, TableChangeEvent e)
    {
        if (e.TableName == nameof(Работа))
        {
            await InvokeAsync(async () => { await LoadData(); });
        }
    }

    public void Dispose()
    {
        RefDataService.TablesChanged -= OnTablesChanged;
    }
}