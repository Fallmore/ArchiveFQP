@using ArchiveFqp.Models.DTO.User
@using ArchiveFqp.Interfaces.User
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

@if (currentUser == null)
{
    <h4><strong>Вы Гость</strong></h4>
}
else
{
    if (errorMessage != null && successMessage == null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <EditForm EditContext="editContext" OnValidSubmit="@HandleValidSubmit" FormName="userGeneralInfoEdit">
        <DataAnnotationsValidator />
        <ValidationSummary class="alert alert-danger" />

        <div class="row mb-1">
            <!-- Фамилия -->
            <div class="col">
                <label class="form-label mb-0 mx-1 fw-bold">Фамилия</label>
                <InputText class="form-control" @bind-Value="currentUser.Фамилия"
                           disabled="@isAuthorizedByServices" style="@(isAuthorizedByServices ? "cursor:not-allowed" : "")" />
            </div>
            <div class="col">
                <!-- Имя -->
                <label class="form-label mb-0 mx-1 fw-bold">Имя</label>
                <InputText class="form-control" @bind-Value="currentUser.Имя"
                           disabled="@isAuthorizedByServices" style="@(isAuthorizedByServices ? "cursor:not-allowed" : "")" />
            </div>
            <div class="col">
                <!-- Отчество -->
                <label class="form-label mb-0 mx-1 fw-bold">Отчество</label>
                <InputText class="form-control" @bind-Value="currentUser.Отчество"
                           disabled="@isAuthorizedByServices" style="@(isAuthorizedByServices ? "cursor:not-allowed" : "")" />
            </div>
        </div>

        <div class="row mb-1">
            <div class="col-md-4 mb-1">
                <!-- Email -->
                <label class="form-label mb-0 mx-1 fw-bold">Email</label>
                <InputText class="form-control" @bind-Value="currentUser.Email"
                           disabled="@isAuthorizedByServices" style="@(isAuthorizedByServices ? "cursor:not-allowed" : "")" />
            </div>

            @if (isAuthorizedByServices)
            {
                <div class="col-md-4 mb-1">
                    <!-- Информация -->
                    <p class="text-muted mt-4 mx-1">Изменить данные вы можете на портале АГТУ</p>
                </div>
            }
        </div>

        <div class="row-md-6">
            <button type="submit" class="btn btn-success mt-3" disabled="@(!IsInfoChanged())">
                Сохранить изменения
            </button>
        </div>
    </EditForm>
}

@code {
    [Parameter] public Пользователь? User { get; set; }
    private Пользователь? currentUser;
    private bool isAuthorizedByServices = false;

    EditContext? editContext;
    ValidationMessageStore? messageStore;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        if (User != null)
        {
            currentUser = new()
            {
                IdПользователя = User.IdПользователя,
                Фамилия = User.Фамилия,
                Имя = User.Имя,
                Отчество = User.Отчество,
                Email = User.Email
            };

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            ClaimsPrincipal user = authState!.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                string? provider = user.Claims.FirstOrDefault(x => x.Type == "AuthProvider")?.Value;
                isAuthorizedByServices = !string.IsNullOrWhiteSpace(provider);
            }

            editContext = new(currentUser);
            messageStore = new(editContext);
            editContext.OnValidationStateChanged += HandleValidationRequested;
        }
    }

    private bool IsInfoChanged()
    {
        if (currentUser!.Фамилия == User!.Фамилия &&
            currentUser!.Имя == User!.Имя &&
            currentUser!.Отчество == User!.Отчество &&
            currentUser!.Email == User!.Email)
            return false;
        return true;
    }

    private void HandleValidationRequested(object? sender, ValidationStateChangedEventArgs args)
    {
        messageStore?.Clear();
        successMessage = null;
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            errorMessage = null;
            await UserService.Upsert(currentUser!);
            successMessage = "Данные успешно обновлены";

            User!.Фамилия = currentUser!.Фамилия;
            User!.Имя = currentUser!.Имя;
            User!.Отчество = currentUser!.Отчество;
            User!.Email = currentUser!.Email;
        }
        catch (DbUpdateException ex)
        {
            errorMessage = ex.InnerException?.Message ?? "";
            if (errorMessage.Contains("email"))
                errorMessage = "Введенный email уже существует";

            errorMessage = "Ошибка при отправке:" + errorMessage;
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при отправке: {ex.Message}";
        }
    }

    public void Dispose()
    {
        messageStore?.Clear();
        successMessage = null;
    }
}
