@using ArchiveFqp.Models.Auth
@using ArchiveFqp.Interfaces.Auth
@inject NavigationManager Navigation
@inject IAuthService AuthService

@if (User == null)
{
    <h4><strong>Вы Гость</strong></h4>
}
else
{
    if (errorMessage != null && successMessage == null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <EditForm EditContext="editContext" OnValidSubmit="@HandleValidSubmit" FormName="userSecurityEdit">
        <DataAnnotationsValidator />

        <div class="row mb-1">
            <!-- Старый пароль -->
            <div class="col">
                <label class="form-label mb-0 mx-1 fw-bold">Старый пароль</label>
                <div class="input-group" style="padding:0; border-right-color:transparent">
                    <InputText @bind-Value="model.OldPassword" type="password" class="form-control input-password" style="border-right-color:transparent" id="old-password" />
                    <div class="input-group-text" style="border-left-color:transparent; background-color:transparent;">
                        <input id="eye" class="form-check-input checkbox-password" style="border-color:transparent" type="checkbox" onclick="ChangeVisibilityPassword('old-password')">
                        <label for="eye"></label>
                    </div>
                </div>
                <ValidationMessage For="() => model.OldPassword" />
            </div>
            <div class="col">
                <!-- Новый пароль -->
                <label class="form-label mb-0 mx-1 fw-bold">Новый пароль</label>
                <div class="input-group" style="padding:0; border-right-color:transparent">
                    <InputText @bind-Value="model.NewPassword" type="password" class="form-control input-password" style="border-right-color:transparent" id="new-password" />
                    <div class="input-group-text" style="border-left-color:transparent; background-color:transparent;">
                        <input id="eye-new" class="form-check-input checkbox-password" style="border-color:transparent" type="checkbox" onclick="ChangeVisibilityPassword('new-password')">
                        <label for="eye-new"></label>
                    </div>
                </div>
                <ValidationMessage For="() => model.NewPassword" />
            </div>
            <div class="col">
                <!-- Подтвердите пароль -->
                <label class="form-label mb-0 mx-1 fw-bold">Подтвердите пароль</label>
                <div class="input-group" style="padding:0; border-right-color:transparent">
                    <InputText @bind-Value="model.ConfirmPassword" type="password" class="form-control input-password" style="border-right-color:transparent" id="confirm-password" />
                    <div class="input-group-text" style="border-left-color:transparent; background-color:transparent;">
                        <input id="eye-confirm" class="form-check-input checkbox-password" style="border-color:transparent" type="checkbox" onclick="ChangeVisibilityPassword('confirm-password')">
                        <label for="eye-confirm"></label>
                    </div>
                </div>
                <ValidationMessage For="() => model.ConfirmPassword" />
            </div>
        </div>

        <div class="row-md-6">
            <button type="submit" class="btn btn-success mt-3" disabled="@disable">
                Сохранить изменения
            </button>
        </div>
    </EditForm>
}

<script>
    function ChangeVisibilityPassword(name) {
      var x = document.getElementById(name);
      if (x.type === "password") {
        x.type = "text";
      } else {
        x.type = "password";
      }
    }
    
</script>

@code {
    [Parameter] public АккаунтПользователя? User { get; set; }
    private ChangePasswordModel model = new();

    EditContext? editContext;
    ValidationMessageStore? messageStore;
    private string? errorMessage;
    private string? successMessage;

    private bool disable => string.IsNullOrWhiteSpace(model.OldPassword) ||
                            string.IsNullOrWhiteSpace(model.NewPassword) ||
                            string.IsNullOrWhiteSpace(model.ConfirmPassword);

    protected override async Task OnInitializedAsync()
    {
        if (User != null)
        {
            model.Login = User.Логин;
            editContext = new(model);
            messageStore = new(editContext);
            editContext.OnValidationStateChanged += HandleValidationRequested;
        }
    }

    private void HandleValidationRequested(object? sender, ValidationStateChangedEventArgs args)
    {
        messageStore?.Clear();
        successMessage = null;
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            errorMessage = null;
            AuthResult result = await AuthService.ChangePasswordAsync(model);
            if (result.Success)
            {
                successMessage = "Пароль успешно изменен";
                Navigation.NavigateTo("/user/profile", forceLoad: true);
            }
            else
            {
                messageStore?.Add(() => model.OldPassword, "Пароль должен совпадать с текущим");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при отправке: {ex.Message}";
        }
    }
}
