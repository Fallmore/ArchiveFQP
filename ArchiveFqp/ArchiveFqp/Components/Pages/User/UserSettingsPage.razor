@using ArchiveFqp.Interfaces.Settings
@using ArchiveFqp.Models.Auth
@using ArchiveFqp.Interfaces.Auth
@using System.Security.Claims
@using ArchiveFqp.Models.Settings.User
@inject NavigationManager Navigation
@inject ISettingsService SettingsService

@if (User == null)
{
    <h4><strong>Вы Гость</strong></h4>
}
else
{
    if (errorMessage != null && successMessage == null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <EditForm EditContext="editContext" OnValidSubmit="@HandleValidSubmit" FormName="userSettingsEdit">
        <DataAnnotationsValidator />

        <div class="row mb-1">
            <div class="col">
                <div class="form-check">
                    <InputCheckbox class="form-check-input"
                                   @bind-Value="userSettingsFromJson.ReceiveEmailNotifications"
                                   id="flexCheckDefault" />
                    <label class="form-check-label" for="flexCheckDefault">
                        Получать уведомления на почту
                    </label>
                </div>
            </div>
        </div>

        <div class="row-md-6">
            <button type="submit" class="btn btn-success mt-3">
                Сохранить изменения
            </button>
        </div>
    </EditForm>
}

@code {
    [Parameter] public Пользователь? User { get; set; }
    private НастройкиПользователя? userSettings;
    private SettingsUser userSettingsFromJson = new();

    EditContext? editContext;
    ValidationMessageStore? messageStore;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        if (User != null)
        {
            userSettings = await SettingsService.GetSettings<НастройкиПользователя>(User.IdПользователя);
            if (userSettings != null)
            {
                if (!string.IsNullOrWhiteSpace(userSettings.Настройки))
                {
                    userSettingsFromJson = (await SettingsService.GetSettingsJson<SettingsUser>(userSettings.Настройки))!;
                }
            }

            editContext = new(userSettingsFromJson);
            messageStore = new(editContext);
            editContext.OnValidationStateChanged += HandleValidationRequested;
        }
    }

    private void HandleValidationRequested(object? sender, ValidationStateChangedEventArgs args)
    {
        messageStore?.Clear();
        successMessage = null;
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            errorMessage = null;
            await SettingsService.AddSettingsAsJson(userSettingsFromJson, userSettings!);
            bool result = await SettingsService.Upsert(userSettings!);
            if (result)
            {
                successMessage = "Настройки успешно изменены";
            }
            else
            {
                errorMessage = "Ошибка при сохранении настроек";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при отправке: {ex.Message}";
        }
    }
}
