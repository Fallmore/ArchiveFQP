@page "/works/add"
@using ArchiveFqp.Models.DTO.Work
@using Microsoft.AspNetCore.Authorization
@inject IJSRuntime JSRuntime
@rendermode @(new InteractiveServerRenderMode(prerender: true))
@attribute [Authorize(Roles = "Завкафедрой,Ответственный кафедры,Ответственный института,Администратор")]

<PageTitle>АГТУ - Добавление работы</PageTitle>

@if (RendererInfo.IsInteractive)
{
    <div class="container mt-4">
        <!-- Выбор режима добавления -->
        @if (selectedMode == null)
        {
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white text-center">
                            <h4 class="mb-0">Добавление работ</h4>
                        </div>
                        <div class="card-body text-center">
                            <p class="mb-4">Выберите способ добавления работ в архив</p>
                            <div class="d-flex justify-content-center gap-3">
                                <button type="button" class="btn btn-lg btn-primary" @onclick="() => selectedMode = AddMode.Single">
                                    <i class="bi bi-file-earmark-plus me-2"></i>
                                    Добавить одну работу
                                </button>
                                <button type="button" class="btn btn-lg btn-outline-primary" @onclick="() => selectedMode = AddMode.Multiple">
                                    <i class="bi bi-files me-2"></i>
                                    Добавить несколько работ
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (selectedMode == AddMode.Single)
        {
            <div class="position-relative">
                <button type="button" class="btn btn-outline-secondary mb-3" @onclick="BackToModeSelection">
                    <i class="bi bi-arrow-left"></i> Назад к выбору
                </button>
                
                <WorkAddOne SessionStoreNameWorkDTO="@sessionStoreNameWorkDTOSingle"
                            EndAdd="EndAddOne" />
            </div>
        }

        @if (selectedMode == AddMode.Multiple)
        {
            <div class="position-relative">
                <button type="button" class="btn btn-outline-secondary mb-3" @onclick="BackToModeSelection">
                    <i class="bi bi-arrow-left"></i> Назад к выбору
                </button>
                
                <WorkAddMultiple SessionStoreNameWorkDTO="@sessionStoreNameWorkDTOMultiple"
                                 EndAdd="EndAddMultiple" />
            </div>
        }
    </div>
}

@code {
    private enum AddMode
    {
        Single,
        Multiple
    }
    
    private AddMode? selectedMode;
    
    private string sessionStoreNameWorkDTOSingle = "workDTOSingle";
    private string sessionStoreNameWorkDTOMultiple = "workDTOMultiple";

    private void BackToModeSelection()
    {
        selectedMode = null;
    }

    private async Task EndAddOne()
    {
        selectedMode = null;
        await JSRuntime.InvokeVoidAsync("alert", "Работа успешно добавлена!");
    }

    private async Task EndAddMultiple()
    {
        selectedMode = null;
        await JSRuntime.InvokeVoidAsync("alert", "Работы успешно добавлены!");
    }
}
