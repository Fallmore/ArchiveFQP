@using ArchiveFqp.Interfaces.ReferenceData
@using ArchiveFqp.Models.AiExtractor
@using ArchiveFqp.Models.DTO.Attribute
@using ArchiveFqp.Models.DTO.Work
@using ArchiveFqp.Models.DatabaseNotification
@using ArchiveFqp.Models.Settings.SettingsArchive
@using ArchiveFqp.Interfaces.Work
@using ArchiveFqp.Services.AiExtractor
@using Microsoft.EntityFrameworkCore
@using ArchiveFqp.Components.Components
@using ArchiveFqp.Models.DTO
@using Newtonsoft.Json
@using Newtonsoft.Json.Serialization
@using System.Text.Json
@inject IDbContextFactory<ArchiveFqpContext> DbFactory
@inject IWorkService WorkService
@inject ILogger<WorkAdd> Logger
@inject SettingsArchive Settings
@inject IReferenceDataService RefDataService
@inject AiExtractorService AiExtractorService
@implements IDisposable
@rendermode @(new InteractiveServerRenderMode(prerender: false))


@if (RendererInfo.IsInteractive)
{
    @if (aiError != null)
    {
        <div class="alert alert-warning">
            @aiError
            <button type="button" class="btn btn-warning"
                    @onclick="StartSearch">
                <i class="bi bi-arrow-repeat"></i> Попробовать снова
            </button>
        </div>
    }
    @if (aiStatus != null)
    {
        <div class="text-center alert alert-@(aiSuccess ? "success" : "info")">
            @if (aiRunning)
            {
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden"></span>
                </div>
                
            }
            <p class="mt-2 mb-0">@aiStatus</p>
            @if (aiRunning || aiConnecting)
            {
                <button type="button" class="btn btn-danger"
                        @onclick="CancelCurrentOperation" disabled="@token.IsCancellationRequested">
                    <i class="bi bi-x-circle"></i> Отменить
                </button>
            }
        </div>
    }

    @if (errorMessage != null && successMessage == null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    @if (warningMessage != null)
    {
        <div class="alert alert-warning">@warningMessage</div>
    }
    @if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <EditForm EditContext="@editContext" FormName="workAttributesAdd" @onsubmit:preventDefault="true">
        <div class="card mb-2">
            <div class="card-body">
                <div class="row">
                    @if (updated)
                        @foreach (AttributeDto attribute in Attributes)
                        {
                            int index = Attributes.IndexOf(attribute);
                            <div class="col-md-6 mb-2">
                                <div class="form-check">
                                    <label class="form-check-label mb-0 fw-bold">
                                        @(attribute.Название)
                                    </label>
                                </div>

                                <SearchableSelect TItem="string"
                                                  TValue="string"
                                                  Items="@(attributeValues.First(av => av.IdАтрибута == attribute.IdАтрибута).Данные.Prepend(Settings.AttributesValueNone).ToList())"
                                                  Placeholder="Выберите или введите данные атрибута..."
                                                  IsInvalid="@(string.IsNullOrWhiteSpace(attribute.Данные))"
                                                  SelectedValue="@(attribute.Данные)"
                                                  SelectedValueChanged="@(async (s) => await SetAttribute(index, s))"
                                                  OnCustomValue="@(async (s) => await SetAttribute(index, s))"
                                                  Disabled="WorkDto.AttributesValuesAdded" />
                            </div>
                        }
                </div>
            </div>
        </div>

        <!-- Кнопки действий -->
        <div class="row mt-4">
            <div class="col-12 d-flex justify-content-between">
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#acceptenceModal"
                        disabled="@(WorkDto.AttributesValuesAdded || !ValidateAttributes() || isSubmitting)">
                    Сохранить значения атрибутов
                </button>
            </div>
        </div>

        <div class="modal fade" id="acceptenceModal" tabindex="-1" aria-labelledby="acceptenceModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="acceptenceModalLabel">Подтверждение добавления</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p>Вы уверены в правильности данных? После добавления их нельзя будет изменить!</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
                        <button type="button" class="btn btn-primary" data-bs-dismiss="modal" @onclick="ConfirmSubmit">Подтвердить</button>
                    </div>
                </div>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter] public WorkCreateDto WorkDto { get; set; } = new();
    [Parameter] public EventCallback<WorkCreateDto> WorkDtoChanged { get; set; }

    private List<AttributeDto> Attributes = [];
    private List<AttributeValuesDto> attributeValues = [];
    private bool updated = false;
    private bool isSubmitting = false;
    private string? errorMessage;
    private string? warningMessage;
    private string? successMessage;

    private string? aiError;
    private ProcessWorkResult? aiResult;
    private string? aiStatus;
    private string? aiTaskId;
    private bool aiSuccess;
    private bool aiRunning;
    private bool aiConnecting;

    CancellationTokenSource cancelTokenSource = new CancellationTokenSource();
    CancellationToken token;

    private EditContext? editContext;

    private EventHandler<TableChangeEvent>? _tablesChangedHandler;

    protected override async Task OnInitializedAsync()
    {
        if (RendererInfo.IsInteractive)
        {
            Attributes = WorkDto.Attributes ?? [];
            editContext = new(Attributes);
            await UpdateAttributes();

            _tablesChangedHandler = (s, e) => InvokeAsync(() => UpdateAttributes(s, e));
            RefDataService.TablesChanged += _tablesChangedHandler;

            if (WorkDto.TypeAddAttributes == TypeAddAttributes.AI && !WorkDto.AttributesSearched)
                await StartSearch();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Пересоздаём EditContext, если модель параметра изменилась (чтобы валидация работала корректно)
        if (editContext == null || editContext.Model != Attributes)
        {
            editContext = new(Attributes);
            // await UpdateAttributes();
        }
    }

    private async Task ConfirmSubmit()
    {
        isSubmitting = true;
        StateHasChanged();
        if (editContext != null && editContext.Validate())
        {
            await HandleValidSubmit();
        }

        isSubmitting = false;
        StateHasChanged();
    }

    private bool ValidateAttributes()
    {
        return Attributes.All(a => !string.IsNullOrWhiteSpace(a.Данные) &&
            a.Данные != Settings.AttributesValueAwait);
    }

    private async Task SetAttribute(int index, string value)
    {
        Attributes[index].Данные = value;
        await WorkDtoChanged.InvokeAsync(WorkDto);
    }

    private async Task UpdateAttributes()
    {
        updated = false;
        Attributes = (await WorkService.GetWorkAttributesAsync(Attributes[0].IdРаботы, []))
                ?.Select(a =>
                {
                    if (a.Данные == Settings.AttributesValueAwait)
                        a.Данные = "";
                    return a;
                }).ToList() ?? [];
        await WorkDtoChanged.InvokeAsync(WorkDto);
        attributeValues = await WorkService.GetAttributeValuesAsync(Attributes.Select(ad => ad.ToAttribute()).ToList());
        updated = true;
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        List<AttributeDto> deletedAttributes = [];
        

        try
        {
            using var context = DbFactory.CreateDbContext();

            List<AttributeDto>? currentAttributes = await WorkService.GetWorkAttributesAsync(Attributes[0].IdРаботы, []);

            if (currentAttributes == default)
            {
                errorMessage = "Работа была удалена";
                WorkDto.AttributesValuesAdded = true;
                await WorkDtoChanged.InvokeAsync(WorkDto);
                StateHasChanged();
                return;
            }

            if (!currentAttributes.SequenceEqual(Attributes))
            {
                attributeValues = await WorkService.GetAttributeValuesAsync(currentAttributes.Select(ad => ad.ToAttribute()).ToList());
                await WorkDtoChanged.InvokeAsync(WorkDto);
                warningMessage = "Были добавлены новые атрибуты";
                return;
            }

            foreach (AttributeDto attribute in Attributes)
            {
                ДанныеПоАтриб? дпа = context.ДанныеПоАтрибs.Find(attribute.IdДанных);
                if (дпа == default)
                {
                    deletedAttributes.Add(attribute);
                }
                else
                {
                    дпа.Данные = attribute.Данные;
                }
            }

            if (deletedAttributes.Count != 0)
            {
                warningMessage = "Некоторые атрибуты были удалены:\n"
                    + string.Join("\n", deletedAttributes.Select(da => da.Название));
            }

            await context.SaveChangesAsync();
            successMessage = "Данные атрибутов успешно добавлены!";
            WorkDto.AttributesValuesAdded = true;
            await WorkDtoChanged.InvokeAsync(WorkDto);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Ошибка добавления данных атрибутов");
            errorMessage = $"Ошибка при добавлении: {ex.Message}";
        }
    }

    private async Task UpdateAttributes(object? sender, TableChangeEvent e)
    {
        if (e.TableName == nameof(ДанныеПоАтриб))
        {
            ДанныеПоАтриб? dAttr = null;
            JsonSerializerSettings options = new()
            { ContractResolver = new DefaultContractResolver { NamingStrategy = new SnakeCaseNamingStrategy() } };

            string json = e.ChangeType == TableChangeType.Delete ? e.Old!.ToString() : e.New!.ToString();
            dAttr = JsonConvert.DeserializeObject<ДанныеПоАтриб>(json, options);

            // Пропускаем обновление атрибутов, если изменение не относится к текущей работе
            // Или атрибутов нет (происходит, когда работа удалена)
            if (dAttr == null || Attributes == null
                    || Attributes.Count == 0 || dAttr.IdРаботы != Attributes[0].IdРаботы) return;

            await UpdateAttributes();
        }
    }

    #region Взаимодействие с сервисом локальной ИИ

    private async Task<HealthResponse> GetHealth()
    {
        return await AiExtractorService.Health();
    }

    private async Task StartSearch()
    {
        aiSuccess = false;
        aiStatus = "Соединение с сервисом...";
        token = cancelTokenSource.Token;
        aiError = null;
        aiConnecting = true;
        StateHasChanged();

        HealthResponse response = await GetHealth();
        if (response.Status == "error" || !response.ChromaDb || !string.IsNullOrEmpty(response.Ollama.Error))
        {
            aiError = "Сервис поиска данных атрибутов недоступен. Приносим извинения";
            aiStatus = null;
            return;
        }

        await RunWithCancellation(async () =>
        {
            if (token.IsCancellationRequested)
            {
                aiStatus = "Поиск данных атрибутов отменен";
                aiConnecting = false;
                return;
            }

            aiResult = null;
            aiConnecting = false; // Не даем отменить внесение
            aiStatus = "Внесение пояснительной записки в базу ИИ...";
            StateHasChanged();
            IndexResponse result = await AiExtractorService.IndexDocumentAsync(WorkDto.Местоположение!);

            if (token.IsCancellationRequested)
            {
                aiStatus = "Поиск данных атрибутов отменен";
                return;
            }

            aiStatus = "Поиск данных атрибутов...";
            var task = await AiExtractorService.StartProcessWorkAsync(WorkDto.Местоположение!, WorkDto.IdРаботы);
            if (!string.IsNullOrEmpty(task.Error))
            {
                aiError = task.Error;
                aiStatus = null;
                return;
            }
            else if (token.IsCancellationRequested)
            {
                aiStatus = "Поиск данных атрибутов отменен";
                aiConnecting = false;
                return;
            }

            aiTaskId = task.TaskId;

            aiRunning = true;
            StateHasChanged();
            aiResult = await PollUntilComplete(
                aiTaskId, () => AiExtractorService.GetProcessWorkStatusAsync(aiTaskId)
            );
        },
        () => aiRunning = false);
    }

    private async Task<ProcessWorkResult?> PollUntilComplete(
        string taskId,
        Func<Task<ProcessWorkStatusResponse>> statusFunc)
    {
        while (!token.IsCancellationRequested)
        {
            var status = await statusFunc();

            if (status.Status == "completed")
            {
                aiStatus = "Поиск завершен";
                aiSuccess = WorkDto.AttributesSearched = true;
                return status.Result;
            }

            if (status.Status == "cancelled")
            {
                aiStatus = "Поиск данных атрибутов отменен";
                return null;
            }

            if (status.Status == "error")
            {
                aiError = $"Ошибка: {status.Error}";
                aiStatus = null;
                return null;
            }

            await Task.Delay(3000, token);
        }

        return null;
    }

    private async Task RunWithCancellation(Func<Task> action, Action cleanup)
    {
        try
        {
            await action();
        }
        catch (OperationCanceledException)
        {
            aiStatus = "Поиск данных атрибутов отменен";
        }
        catch (Exception ex)
        {
            aiError = $"Ошибка: {ex.Message}";
            aiStatus = null;
        }
        finally
        {
            cleanup();
            aiTaskId = null;
            await WorkDtoChanged.InvokeAsync(WorkDto);
            StateHasChanged();
        }
    }

    private async Task CancelCurrentOperation()
    {
        Cancel();
        if (aiTaskId != null)
        {
            try
            {
                if (aiRunning)
                    await AiExtractorService.CancelProcessWorkAsync(aiTaskId);
            }
            catch { /* игнорируем ошибки отмены */ }
        }
    }

    #endregion

    private void Cancel()
    {
        cancelTokenSource.Cancel();
        cancelTokenSource.Dispose();
        cancelTokenSource = new();
    }

    public void Dispose()
    {
        if (_tablesChangedHandler != null)
            RefDataService.TablesChanged -= _tablesChangedHandler;
    }
}
