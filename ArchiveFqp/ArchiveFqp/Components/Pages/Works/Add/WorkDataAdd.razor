    private async Task<ExtractTitleResult?> PollUntilComplete(
        string taskId, Func<Task<ExtractTitleStatusResponse>> statusFunc)
    {
        while (!token.IsCancellationRequested)
        {
            var status = await statusFunc();

            if (status.Status == "completed")
            {
                aiStatus = "Титульник извлечён";
                return status.Result;
            }

            if (status.Status == "cancelled")
            {
                aiStatus = "Извлечение титульника отменено";
                return null;
            }

            if (status.Status == "error")
            {
                aiError = $"Ошибка: {status.Error}";
                aiStatus = null;
                return null;
            }

            await Task.Delay(3000, token);
        }

        return null;
    }

    private async Task RunWithCancellation(Func<Task> action, Func<Task> cleanup)
    {
        try
        {
            await action();
        }
        catch (OperationCanceledException)
        {
            aiStatus = "Извлечение титульника отменено";
        }
        catch (Exception ex)
        {
            aiError = $"Ошибка: {ex.Message}";
            aiStatus = null;
        }
        finally
        {
            await cleanup();
            aiTaskId = null;
            StateHasChanged();
        }
    }

    private async Task CancelCurrentOperation()
    {
        Cancel();
        if (aiTaskId != null)
        {
            try
            {
                if (aiRunning)
                    await AiExtractorService.CancelTitleExtractionAsync(aiTaskId);
            }
            catch { /* игнорируем ошибки отмены */ }
        }
    }

    private async Task SetExtractedDatas(ExtractTitleResult? result)
    {
        if (result == null) return;

        TitleInfo title = result.Title;
        WorkDto.Тема = title.Тема;

        double threshold = 0.5;

        List<TeacherDisplayDto> teachersDto = await teacherDtoFactory!.CreateDisplayDtoAsync(filteredTeachers);
        (string? teacherFio, _) = StringSimilarity.FindBest(title.Руководитель, [.. teachersDto.Select(x => x.Пользователь.ФИО)], threshold);
        if (teacherFio != null)
            WorkDto.IdПреподавателя = teachersDto.First(x => x.Пользователь.ФИО == teacherFio).IdПреподавателя;

        if (title.ТипРаботы != "Н/Д")
        {
            if (title.ТипРаботы.ToLower().Contains("бакалавр")) WorkDto.IdТипаРаботы = snapshot.WorkTypes.FirstOrDefault(x => x.Название.Contains("ВКРБ"))?.IdТипаРаботы;
            else if (title.ТипРаботы.ToLower().Contains("магистр")) WorkDto.IdТипаРаботы = snapshot.WorkTypes.FirstOrDefault(x => x.Название.Contains("МД"))?.IdТипаРаботы;
            await OnWorkTypeChanged();
        }

        List<StudentDisplayDto> studentsDto = await studentDtoFactory!.CreateDisplayDtoAsync(filteredStudents);
        (string? studentFio, _) = StringSimilarity.FindBest(title.Автор, [.. studentsDto.Select(x => x.Пользователь.ФИО)], threshold);

        if (studentFio != null)
        {
            WorkDto.IdСтудента = studentsDto.First(x => x.Пользователь.ФИО == studentFio).IdСтудента;
            await OnStudentChanged(WorkDto.IdСтудента);
        }
        else
        {
            WorkDto.IsNewUser = true;
            string[] fio = title.Автор.Split(" ");
            WorkDto.Surname = fio[0];
            WorkDto.Name = fio[1];
            WorkDto.Patronymic = string.Join(" ", fio[2..]);

            (var institute, _) = StringSimilarity.FindBest(title.Институт, snapshot.Institutes, threshold);
            if (institute != null && institute.IdИнститута != WorkDto.IdИнститута && !disableInstitute)
                WorkDto.IdИнститута = institute.IdИнститута;

            (var department, _) = StringSimilarity.FindBest(title.Кафедра, snapshot.Departments, threshold);
            if (department != null && department.IdКафедры != WorkDto.IdКафедры && !disableDepartment)
                WorkDto.IdКафедры = department.IdКафедры;

            (var direction, _) = StringSimilarity.FindBest(title.Направление, snapshot.Directions, threshold);
            if (direction != null && direction.IdНаправления != WorkDto.IdНаправления) WorkDto.IdНаправления = direction.IdНаправления;

            (var profile, _) = StringSimilarity.FindBest(title.Профиль, snapshot.Profiles, threshold);
            if (profile != null && profile.IdПрофиля != WorkDto.IdПрофиля) WorkDto.IdПрофиля = profile.IdПрофиля;

            if (title.Год != "Н/Д") WorkDto.ГодВыпуска = int.Parse(title.Год);
        }
    }

