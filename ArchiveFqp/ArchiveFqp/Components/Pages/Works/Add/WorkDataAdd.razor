    protected override async Task OnInitializedAsync()
    {
        teacherDtoFactory = new(RefDataService);
        studentDtoFactory = new(RefDataService);

        await UpdateData();

        FileUploadService.ProgressChanged += OnUploadProgressChanged;
        RefDataService.TablesChanged += OnTablesChanged;

        if (IsEdit)
        {
            workDtoOriginal = new(WorkDto);
            uploadedFiles = FileUploadService.GetFiles(workDtoOriginal.Местоположение!);
        }

        editContext = new(WorkDto);
        messageStore = new(editContext);
        editContext.OnValidationStateChanged += HandleValidationRequested;
