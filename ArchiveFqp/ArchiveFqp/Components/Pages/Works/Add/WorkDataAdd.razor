    private async Task SetStructuresByRole()
    {
        AuthenticationState? authState = await authenticationState!;
        ClaimsPrincipal user = authState!.User;

        if (user.IsInRole(Settings.RoleAdminName)) return;

        int idUser = int.Parse(user.Claims.First(x => x.Type == ClaimTypes.NameIdentifier).Value);
        Преподаватель? teacher = (await RefDataService.GetAsync<Преподаватель>())
            .FirstOrDefault(x => x.IdПользователя == idUser);

        if (teacher == null)
        {
            Navigation.NavigateTo("/logout", true);
            return;
        }

        WorkDto.IdИнститута = teacher.IdИнститута;
        disableInstitute = true;
        if (user.IsInRole(Settings.RoleInstituteResponsibleName))
        {
            await UpdateDependentLists();
            await SaveStateWorkDTO();
            filteredStudents = filteredStudents
                .Where(x => x.IdИнститута == teacher.IdИнститута).ToList();
            return;
        }

        if (user.IsInRole(Settings.RoleDepartmentHeadName) || user.IsInRole(Settings.RoleDepartmentResponsibleName))
        {
            WorkDto.IdКафедры = teacher.IdКафедры;
            await UpdateDependentLists();
            await SaveStateWorkDTO();
            disableDepartment = true;
            filteredStudents = filteredStudents
                .Where(x => x.IdИнститута == teacher.IdИнститута && x.IdКафедры == teacher.IdКафедры).ToList();
            return;
        }
    }

    private async Task UpdateDependentLists()
    {
        filteredStudents = snapshot.Students.OrderBy(s => users.First(u => u.IdПользователя == s.IdПользователя).Фамилия).ToList();

        if (!WorkDto.IdИнститута.HasValue)
            filteredDepartments = snapshot.Departments.ToList();
        else
        {
            filteredDepartments = snapshot.Departments
            .Where(d => d.IdИнститута == WorkDto.IdИнститута)
            .DistinctBy(d => d.Название)
            .ToList();

            filteredStudents = filteredStudents.Where(x => x.IdИнститута == WorkDto.IdИнститута).ToList();
        }

        if (WorkDto.IdКафедры.HasValue)
            filteredStudents = filteredStudents.Where(x => x.IdКафедры == WorkDto.IdКафедры).ToList();

        if (!WorkDto.IdУгснСтандарта.HasValue)
            filteredUgsns = snapshot.Ugsns;
        else
        {
            filteredDirections = snapshot.Directions
                .Where(d => d.IdКафедры == WorkDto.IdКафедры)
                .ToList();

            List<int> idUgsns = filteredDirections.Select(x => x.IdУгсн).ToList();
            filteredUgsns = snapshot.Ugsns
                .Where(u => u.IdУгснСтандарта == WorkDto.IdУгснСтандарта && idUgsns.Contains(u.IdУгсн))
                .ToList();

            filteredStudents = filteredStudents.Where(x => x.IdНаправления == WorkDto.IdНаправления).ToList();
        }

        if (!WorkDto.IdУгсн.HasValue)
            filteredDirections = snapshot.Directions;
        else
        {
            filteredDirections = snapshot.Directions
            .Where(d => d.IdКафедры == WorkDto.IdКафедры && d.IdУгсн == WorkDto.IdУгсн)
            .ToList();

            filteredStudents = filteredStudents.Where(x => x.IdНаправления == WorkDto.IdНаправления).ToList();
        }

        if (!WorkDto.IdНаправления.HasValue)
            filteredProfiles = snapshot.Profiles;
        else
        {
            filteredProfiles = snapshot.Profiles
            .Where(p => p.IdНаправления == WorkDto.IdНаправления)
            .ToList();

            filteredStudents = filteredStudents.Where(x => x.IdПрофиля == WorkDto.IdПрофиля).ToList();
        }

        if (isFqp)
        {

            string workType = snapshot.WorkTypes.First(wt => wt.IdТипаРаботы == WorkDto.IdТипаРаботы).Название;
            // Фильтруем списки студентов и уровня образования
            if (Settings.FqpWorksEducationLevels.TryGetValue(workType!, out List<string>? edcucationLevels))
            {
                filteredEducationLevels = snapshot.EducationLevels
                    .Where(x => edcucationLevels.Contains(x.Название))
                    .ToList();

                List<int> fqps = snapshot.WorkTypes
                    .Where(x => Settings.FqpWorks.Contains(x.Название))
                    .Select(x => x.IdТипаРаботы).ToList();

                List<Работа> works = await RefDataService.GetAsync<Работа>();
                filteredStudents = filteredStudents
                    .Where(x => filteredEducationLevels.Select(y => y.IdУровняОбразования).Contains(x.IdУровняОбразования))
                    .Where(x => !works
                        .Where(w => fqps.Contains(w.IdТипаРаботы))
                        .Select(y => y.IdСтудента).Contains(x.IdСтудента))
                    .OrderBy(s => users.First(u => u.IdПользователя == s.IdПользователя).Фамилия)
                    .ToList();

                if (WorkDto.IdСтудента != null && !WorkDto.IsNewUser
                    && !filteredStudents.Exists(s => s.IdСтудента == WorkDto.IdСтудента))
                {
                    WorkDto.IdСтудента = null;
                    await OnStudentChanged(null);
                    StateHasChanged();
                }
            }
        }
        else
        {
            filteredEducationLevels = snapshot.EducationLevels;
            filteredStudents = filteredStudents.OrderBy(s => users.First(u => u.IdПользователя == s.IdПользователя).Фамилия).ToList();
        }
    }

