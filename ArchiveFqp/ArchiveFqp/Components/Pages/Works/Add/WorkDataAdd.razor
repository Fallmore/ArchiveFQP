    private async Task SwitchToStudent()
    {
        if (WorkDto.IsNewUser)
        {
            WorkDto.IsNewUser = false;
            await OnStudentChanged(WorkDto.IdСтудента);
        }
    }

    private void Cancel()
    {
        cancelTokenSource.Cancel();
        cancelTokenSource.Dispose();
        cancelTokenSource = new();
    }

    public void Dispose()
    {
        FileUploadService.ProgressChanged -= OnUploadProgressChanged;
        RefDataService.TablesChanged -= OnTablesChanged;
        cancelTokenSource.Cancel();
        cancelTokenSource.Dispose();
    }
