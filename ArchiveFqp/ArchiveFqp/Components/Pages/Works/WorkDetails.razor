@using ArchiveFqp.Interfaces.ReferenceData
@using ArchiveFqp.Interfaces.User
@using ArchiveFqp.Models.DTO.Attribute
@using ArchiveFqp.Models.DTO.Teacher
@using ArchiveFqp.Models.DTO.Work
@using ArchiveFqp.Models.Search
@using ArchiveFqp.Interfaces.Work
@using ArchiveFqp.Models.Settings.SettingsArchive
@using System.Security.Claims
@inject SettingsArchive Settings
@inject IReferenceDataService RefDataService
@inject IUserService UserService
@inject IWorkService WorkService

<PageTitle>АГТУ - @(work?.Тема ?? "Детали работы")</PageTitle>

<div class="container mt-4">
    <!-- Кнопка назад -->
    @if (ShowExtraButtons)
    {
        <div class="row mb-3">
            <div class="col d-flex justify-content-between">
                <button class="btn btn-outline-primary" onclick="history.back();">
                    <i class="bi bi-arrow-left"></i> Назад
                </button>
        
                @if (Settings.FqpWorks.Contains(displayDto.ТипРаботы.Название))
                {
                    <a class="btn btn-outline-primary"
                           href="@urlWatchWork">
                        <i class="bi bi-eye-fill"></i> Посмотреть ПЗ
                    </a>
                }
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
            <p class="mt-2">Загрузка информации о работе...</p>
        </div>
    }
    else if (displayDto.IdРаботы == 0)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> Работа не найдена
        </div>
    }
    else if (accessDenied)
    {
        <div class="alert alert-danger">
            <i class="bi bi-x-circle"></i> У вас нет доступа к этой работе
        </div>
    }
    else
    {
        <!-- Заголовок с основной информацией -->
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <i class="bi bi-file-earmark-text me-2"></i>
                    @displayDto.ТипРаботы.Название
                </h4>
                <span class="badge @GetStatusBadgeClass(displayDto.СтатусРаботы.Название) bg-opacity-75 fs-6">
                    @(displayDto.СтатусРаботы.Название)
                </span>
            </div>
            <div class="card-body">
                <h2 class="card-title mb-4">@displayDto.Тема</h2>

                <div class="row">
                    <!-- Левая колонка: основная информация -->
                    <div class="col-lg-7">
                        <!-- Информация об авторе и руководителе -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="card h-100 border-0 bg-light">
                                    <div class="card-body">
                                        <h5 class="card-title text-primary">
                                            <i class="bi bi-person-circle me-2"></i>Студент
                                        </h5>
                                        <p class="card-text mb-1 fs-5">
                                            @(displayDto.Студент.Пользователь.ФИО)
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card h-100 border-0 bg-light">
                                    <div class="card-body">
                                        <h5 class="card-title text-primary">
                                            <i class="bi bi-mortarboard me-2"></i>Руководитель
                                        </h5>
                                        <p class="card-text mb-1 fs-5">
                                            @(displayDto.Руководитель.Пользователь.ФИО)
                                        </p>
                                        @if (!string.IsNullOrEmpty(displayDto.Руководитель.Должность.Название))
                                        {
                                            <p class="card-text text-muted">
                                                <i class="bi bi-briefcase me-1"></i>@(displayDto.Руководитель.Должность.Название)
                                            </p>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!--Консультанты и рецензенты-->
                        <div class="row mb-4">
                            @if (displayDto.Консультанты != null && displayDto.Консультанты.Count != 0)
                            {
                                <div class="col-md-6">
                                    <div class="card h-100 border-0 bg-light">
                                        <div class="card-body">
                                            <h5 class="card-title text-primary">
                                                <i class="bi bi-mortarboard me-2"></i>Консультанты
                                            </h5>
                                            @foreach (TeacherDisplayDto consultant in displayDto.Консультанты)
                                            {
                                                <p class="card-text mb-1 fs-5">
                                                    @(consultant.Пользователь.ФИО)
                                                </p>
                                                @if (!string.IsNullOrEmpty(consultant.Должность.Название))
                                                {
                                                    <p class="card-text text-muted">
                                                        <i class="bi bi-briefcase me-1"></i>@(consultant.Должность.Название)
                                                    </p>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (displayDto.Рецензенты != null && displayDto.Рецензенты.Count != 0)
                            {
                                <div class="col-md-6">
                                    <div class="card h-100 border-0 bg-light">
                                        <div class="card-body">
                                            <h5 class="card-title text-primary">
                                                <i class="bi bi-mortarboard me-2"></i>Рецензенты
                                            </h5>
                                            @foreach (TeacherDisplayDto reviewer in displayDto.Рецензенты)
                                            {
                                                <p class="card-text mb-1 fs-5">
                                                    @(reviewer.Пользователь.ФИО)
                                                </p>
                                                @if (!string.IsNullOrEmpty(reviewer.Должность.Название))
                                                {
                                                    <p class="card-text text-muted">
                                                        <i class="bi bi-briefcase me-1"></i>@(reviewer.Должность.Название)
                                                    </p>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Характеристики работы -->
                        <div class="card mb-4 border-0 bg-light">
                            <div class="card-body">
                                <h5 class="card-title text-primary mb-3">
                                    <i class="bi bi-info-circle me-2"></i>Характеристики работы
                                </h5>
                                <div class="row">
                                    <div class="col-sm-6">
                                        <ul class="list-unstyled">
                                            <li class="mb-2">
                                                <i class="bi bi-file-text me-2 text-primary"></i>
                                                <strong>Количество страниц:</strong>
                                                @(displayDto.КоличСтраниц.ToString() ?? "Не указано")
                                            </li>
                                            <li class="mb-2">
                                                <i class="bi bi-calendar-plus me-2 text-primary"></i>
                                                <strong>Дата добавления:</strong>
                                                @displayDto.ДатаДобавления.ToString("dd.MM.yyyy")
                                            </li>
                                        </ul>
                                    </div>
                                    <div class="col-sm-6">
                                        <ul class="list-unstyled">
                                            @if (displayDto.ДатаИзменения.HasValue)
                                            {
                                                <li class="mb-2">
                                                    <i class="bi bi-calendar-check me-2 text-primary"></i>
                                                    <strong>Последнее изменение:</strong>
                                                    @displayDto.ДатаИзменения.Value.ToString("dd.MM.yyyy")
                                                </li>
                                            }
                                            <li class="mb-2">
                                                <i class="bi bi-shield me-2 text-primary"></i>
                                                <strong>Доступ работы:</strong>
                                                @(displayDto.ДоступРаботы.Название)
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Аннотация -->
                        @if (!string.IsNullOrEmpty(displayDto.Аннотация))
                        {
                            <div class="card mb-4 border-0 bg-light">
                                <div class="card-body">
                                    <h5 class="card-title text-primary mb-3">
                                        <i class="bi bi-info-circle me-2"></i>Аннотация
                                    </h5>
                                    @displayDto.Аннотация
                                </div>
                            </div>
                        }

                        <!-- Атрибуты работы -->
                        @if (displayDto.Атрибуты != null && displayDto.Атрибуты.Count != 0)
                        {
                            <div class="card mb-4 border-0 bg-light">
                                <div class="card-body">
                                    <h5 class="card-title text-primary mb-3">
                                        <i class="bi bi-tags me-2"></i>Атрибуты работы
                                    </h5>
                                    <div class="row">
                                        @foreach (var attr in displayDto.Атрибуты)
                                        {
                                            <div class="col-md-6 mb-2">
                                                <div class="d-flex align-items-center">
                                                    <span class="badge bg-secondary me-2">@attr.Название</span>
                                                    <span>@attr.Данные</span>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Правая колонка: дополнительная информация -->
                    <div class="col-lg-5">
                        <!-- Информация о направлении/кафедре и т.д. -->
                        @{
                            <div class="card mb-4 border-0 bg-light">
                                <div class="card-body">
                                    <h5 class="card-title text-primary mb-3">
                                        <i class="bi bi-building me-2"></i>Образовательная программа
                                    </h5>
                                    <p class="mb-1">
                                        <strong>Институт:</strong><br>
                                        @displayDto.Студент.Структура.Институт.Название
                                    </p>
                                    <p class="mb-1">
                                        <strong>Стандарт УГСН:</strong><br>
                                        @(displayDto.Студент.Структура.УгснСтандарт.Название)
                                    </p>
                                    <p class="mb-1">
                                        <strong>УГСН:</strong><br>
                                        @(displayDto.Студент.Структура.Угсн.Название)
                                    </p>
                                    <p class="mb-1">
                                        <strong>Кафедра:</strong><br>
                                        @(displayDto.Студент.Структура.Кафедра.Название)
                                    </p>
                                    <p class="mb-0">
                                        <strong>Направление:</strong><br>
                                        @(displayDto.Студент.Структура.Направление.Название)
                                    </p>
                                    @if (displayDto.Студент.Структура.Профиль != null && !string.IsNullOrEmpty(displayDto.Студент.Структура.Профиль.Название))
                                    {
                                        <p class="mb-1">
                                            <strong>Профиль:</strong><br>
                                            @(displayDto.Студент.Структура.Профиль.Название)
                                        </p>
                                    }
                                    <p class="mb-1">
                                        <strong>Уровень образования:</strong><br>
                                        @(displayDto.Студент.УровеньОбразования.Название)
                                    </p>
                                    <p class="mb-1">
                                        <strong>Форма образования:</strong><br>
                                        @(displayDto.Студент.ФормаОбучения.Название)
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
        [CascadingParameter] private Task<AuthenticationState>? authenticationState { get; set; }

        [Parameter] public int? IdWork { get; set; }
        [Parameter] public bool ShowExtraButtons { get; set; } = true;
        [Parameter] public WorkDisplayDto? DisplayDto { get; set; }
    private Работа? work;
    private int? lastIdWork;
    private WorkDisplayDto displayDto = new();

    private string urlWatchWork = "/works/applications/send?w=";

    private bool isLoading = true;
    private bool accessDenied = false;

    protected override async Task OnInitializedAsync()
    {
        urlWatchWork += IdWork;
        await LoadWorkDetails();
    }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();

        if (IdWork != lastIdWork)
        {
            await LoadWorkDetails();
        }
    }

    private async Task LoadWorkDetails()
    {
        isLoading = true;
        StateHasChanged();
        try
        {
            if (DisplayDto == null)
            {
                WorkSearchModel wsm = new();
                if (IdWork == null || IdWork < 1)
                {
                    work = null;
                    displayDto = new();
                    return;
                }

                wsm.IdWork = IdWork;
                lastIdWork = wsm.IdWork;

                // Загружаем работу со всеми связанными данными
                work = await WorkService.GetWorkAsync(wsm.IdWork!.Value);

                if (work != null)
                {
                    displayDto = await WorkService.GetWorkDisplayAsync(work);

                    accessDenied = !(await CheckAccessAndClaims(displayDto));
                }
            }
            else
            {
                displayDto = DisplayDto;
                accessDenied = !(await CheckAccessAndClaims(displayDto));
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetStatusBadgeClass(string status)
    {
        return status.ToLower() switch
        {
            "завершена" or "опубликована" => "bg-success",
            "в работе" or "в обработке" => "bg-warning text-dark",
            "на проверке" or "на рецензии" => "bg-info",
            "отклонена" or "возвращена" => "bg-danger",
            "черновик" => "bg-secondary",
            _ => "bg-primary"
        };
    }

    private async Task<bool> CheckAccessAndClaims(WorkDisplayDto work)
    {
        AuthenticationState? authState = await authenticationState!;
        ClaimsPrincipal? user = authState?.User;

        if (user == null || !user.Identity!.IsAuthenticated)
        {
            if (work.ДоступРаботы.Название == Settings.WorkAccessAll) return true;
            return false;
        }

        if (user.IsInRole(Settings.RoleAdminName))
        {
            urlWatchWork = "/works/read/" + displayDto.IdРаботы;
            return true;
        }

        int idUser = int.Parse(user.Claims.First(x => x.Type == ClaimTypes.NameIdentifier).Value);
        List<РольУчреждения> roles = await RefDataService.GetAsync<РольУчреждения>();
        bool isOk = false;

        if (user.IsInRole(Settings.RoleInstituteResponsibleName) || user.IsInRole(Settings.RoleDepartmentHeadName)
            || user.IsInRole(Settings.RoleDepartmentResponsibleName) || user.IsInRole(Settings.RoleTeacherName))
        {

            List<Преподаватель> teachers = (await UserService.GetTeacherAsync(idUser))
                .Where(x => !x.Роли.Contains(roles.First(r => r.Название == Settings.RoleTeacherOnVerifyName).IdРоли))
                .ToList();
            Преподаватель? teacher = null;

            if (teachers.Count != 0)
            {
                // Руководитель работы
                if (idUser == work.Руководитель.Пользователь.Пользователь.IdПользователя)
                {
                    urlWatchWork = "/works/read/" + displayDto.IdРаботы;
                    isOk = true;
                }
                
                teachers = teachers.Where(x => x.Активно == true).ToList();

                // Даём сразу смотреть ПЗ, если это ответственный института
                teacher = teachers.Where(x => x.Роли.Contains(roles.First(z => z.Название == Settings.RoleInstituteResponsibleName).IdРоли))
                    .FirstOrDefault();
                if (teacher != null && work.Студент.Структура.Институт.IdИнститута == teacher.IdИнститута)
                {
                    urlWatchWork = "/works/read/" + displayDto.IdРаботы;
                    // Доступ внутри кафедр, направлений и профилей без секретов
                    if (work.ДоступРаботы.Название != Settings.WorkAccessSecret) isOk = true;
                }

                // Даём сразу смотреть ПЗ, если это завкафедрой или ответственный кафедры
                teacher = teachers.Where(x => x.Роли.Intersect(roles.Where(y => y.Название == Settings.RoleDepartmentHeadName
                                                                        || y.Название == Settings.RoleDepartmentResponsibleName)
                                                                .Select(z => z.IdРоли)
                                                                .ToList())
                                                 .Count() != 0)
                              .FirstOrDefault();
                if (teacher != null && work.Студент.Структура.Кафедра.IdКафедры == teacher.IdКафедры)
                {
                    urlWatchWork = "/works/read/" + displayDto.IdРаботы;

                    // Доступ к засекреченному
                    if (work.ДоступРаботы.Название == Settings.WorkAccessSecret) isOk = true;
                }

                if (work.ДоступРаботы.Название == Settings.WorkAccessAll ||
                    work.ДоступРаботы.Название == Settings.WorkAccessOrganization) isOk = true;

                // Доступ внутри института
                if (work.ДоступРаботы.Название == Settings.WorkAccessInstitute
                        && teachers.Exists(x => x.IdИнститута == work.Студент.Структура.Институт.IdИнститута)) isOk = true;

                // Доступ внутри кафедры, направления и профиля без секретов
                if (work.ДоступРаботы.Название != Settings.WorkAccessSecret
                    && teachers.Exists(x => x.IdКафедры == work.Студент.Структура.Кафедра.IdКафедры)) isOk = true;
            }
        }

        if (user.IsInRole(Settings.RoleStudentName))
        {
            List<Студент> students = (await UserService.GetStudentAsync(idUser))
                .Where(x => !x.Роли.Contains(roles.First(r => r.Название == Settings.RoleStudentOnVerifyName).IdРоли))
                .ToList();
            if (students.Count == 0) return isOk;

            // Работа студента
            if (idUser == work.Студент.Пользователь.Пользователь.IdПользователя)
            {
                urlWatchWork = "/works/read/" + displayDto.IdРаботы;
                isOk = true;
            }

            // Если пользователь и преподаватель, и студент и прошёл проверки наверху
            // то пропускаем проверки дальше
            if (isOk) return isOk;

            students = students.Where(x => x.Активно == true).ToList();
            if (work.ДоступРаботы.Название == Settings.WorkAccessAll ||
                work.ДоступРаботы.Название == Settings.WorkAccessOrganization) return true;
            if (work.ДоступРаботы.Название == Settings.WorkAccessSecret) return false;

            if ((work.ДоступРаботы.Название == Settings.WorkAccessInstitute
                    && students.Exists(x => x.IdИнститута == work.Студент.Структура.Институт.IdИнститута))
                ||
                (work.ДоступРаботы.Название == Settings.WorkAccessDepartment
                    && students.Exists(x => x.IdКафедры == work.Студент.Структура.Кафедра.IdКафедры))
                ||
                (work.ДоступРаботы.Название == Settings.WorkAccessDirection
                    && students.Exists(x => x.IdНаправления == work.Студент.Структура.Направление.IdНаправления))) return true;
            
            // Если нет профиля, то нет смысла дальше проверять соответствие
            if (students.All(x => x.IdПрофиля == null)) return false;

            if (work.ДоступРаботы.Название == Settings.WorkAccessProfile
                && 
                (work.Студент.Структура?.Профиль?.IdПрофиля == null
                    || students.Exists(x => x.IdПрофиля == work.Студент.Структура.Профиль.IdПрофиля))) return true;
        }
        
        return isOk;
    }

}