@page "/works/gallery"
@using System.Text.Json
@using System.Web
@using ArchiveFqp.Components.Components
@using ArchiveFqp.Components.Pages.Report
@using ArchiveFqp.Factories.DisplayDto.Student
@using ArchiveFqp.Factories.DisplayDto.Teacher
@using ArchiveFqp.Models.DTO.Attribute
@using ArchiveFqp.Models.DTO.Work
@using ArchiveFqp.Models.ReferenceData
@using ArchiveFqp.Models.Search
@using ArchiveFqp.Interfaces.Work
@using ArchiveFqp.Interfaces.ReferenceData
@using System.Diagnostics
@using System.Text
@using System.Security.Claims
@using ArchiveFqp.Models.Settings.SettingsArchive
@inject NavigationManager Navigation
@inject SettingsArchive Settings
@inject IWorkService WorkService
@inject IReferenceDataService RefDataService;
@rendermode @(new InteractiveServerRenderMode())

<PageTitle>АГТУ - Учебные работы</PageTitle>

@if (RendererInfo.IsInteractive)
{
    #region Для делопроизводителя

    <AuthorizeView Roles="@($"{Settings.RoleDepartmentClerkName}, {Settings.RoleAdminName}")">
        <div class="container mb-2">
            <button class="btn btn-outline-secondary z-0" type="button" @onclick="() => showReportGenerator = true"
                    data-bs-toggle="modal" data-bs-target="#@modalName">
                <i class="bi bi-search"></i> Сформировать отчет
            </button>
        </div>

        <div class="modal fade" id="@modalName" tabindex="-1" aria-labelledby="reportModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="workApplicationModalLabel">Настройка отчета</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        @if (showReportGenerator)
                        {
                            <ReportGenerator Works="FilteredResult?.Items"
                                             SearchModel="searchModel" />
                        }
                    </div>
                </div>
            </div>
        </div>
    </AuthorizeView>
    #endregion

    <div class="container">
        <div @ref="topAnchor" tabindex="-1" style="outline: none; position: absolute;"></div>

        <!-- Поисковая панель -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row">
                    <div class="col-12">
                        <div class="input-group mb-3">
                            <input type="text"
                                   class="form-control"
                                   placeholder="Введите название работы..."
                                   @bind="searchModel.SearchText"
                                   @bind:event="oninput"
                                   @onkeypress="@(e => { if (e.Key == "Enter") { searchModel.Page = 1; UpdateUrl(); } })" />
                            <button class="btn btn-outline-secondary z-0" type="button" @onclick="@(() => { searchModel.Page = 1; UpdateUrl(); })">
                                <i class="bi bi-search"></i> Найти
                            </button>
                            <button class="btn @(advancedSearch ? "btn-primary" : "btn-outline-primary") z-0" type="button" @onclick="ToggleAdvancedSearch"
                                    data-bs-toggle="collapse" data-bs-target="#collapseAdvancedSearch"
                                    aria-expanded="false" aria-controls="collapseAdvancedSearch">
                                <i class="bi bi-funnel"></i> Расширенный поиск
                            </button>
                            <button class="btn btn-outline-secondary z-0" type="button" @onclick="ClearSearch">
                                <i class="bi bi-x"></i> Очистить
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Расширенный поиск -->
                <div class="collapse" id="collapseAdvancedSearch">
                    <div class="card card-body">
                        <div class="row mt-2">
                            <div class="col-md-3 mb-3">
                                <label class="form-label mb-0 fw-bold">Количество страниц</label>
                                <div class="row d-flex justify-content-center align-items-center">
                                    <div class="col">
                                        <select class="form-select" @bind="searchModel.MinPages"
                                                placeholder="С">
                                            <option value=""></option>
                                            @{
                                                int maxP = searchModel.MaxPages ?? maxPage;
                                                foreach (var i in Enumerable.Range(minPage, maxP - minPage + 1))
                                                {
                                                    <option value="@i">@i</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <label class="col-sm-1 col-form-label d-flex justify-content-center align-items-center">—</label>
                                    <div class="col">
                                        <select class="form-select" @bind="searchModel.MaxPages"
                                                placeholder="По">
                                            <option value=""></option>
                                            @{
                                                int minP = searchModel.MinPages ?? minPage;
                                                foreach (var i in Enumerable.Range(minP, maxPage - minP + 1))
                                                {
                                                    <option value="@i">@i</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            @if (showAllDates || selectedWorkType != null && Settings.FqpWorks.Contains(selectedWorkType.Название))
                            {
                                <div class="col-md-3 mb-3">
                                    <label class="form-label mb-0 fw-bold">Год защиты</label>
                                    <div class="row d-flex justify-content-center align-items-center">
                                        <div class="col">
                                            <select class="form-select" @bind="searchModel.MinYearDefense"
                                                    placeholder="С">
                                                <option value=""></option>
                                                @foreach (var i in Enumerable.Range(minYear, maxYear - minYear + 1))
                                                {
                                                    <option value="@i">@i</option>
                                                }
                                            </select>
                                        </div>
                                        <label class="col-sm-1 col-form-label d-flex justify-content-center align-items-center">—</label>
                                        <div class="col">
                                            <select class="form-select" @bind="searchModel.MaxYearDefense"
                                                    placeholder="По">
                                                <option value=""></option>
                                                @foreach (var i in Enumerable.Range(minYear, maxYear - minYear + 1))
                                                {
                                                    <option value="@i">@i</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (showAllDates || selectedWorkType != null && !Settings.FqpWorks.Contains(selectedWorkType.Название))
                            {
                                <div class="col-md-3 mb-3">
                                    <label class="form-label mb-0 fw-bold">Дата добавления</label>
                                    <div class="row d-flex justify-content-center align-items-center">
                                        <div class="col-sm-5" style="padding-left:0px;padding-right:2px">
                                            <InputDate class="form-control" @bind-Value="searchModel.MinDateAdded" />
                                        </div>
                                        <label class="col-sm-1 col-form-label d-flex justify-content-center align-items-center">—</label>
                                        <div class="col-sm-5" style="padding-right:0px;padding-left:2px">
                                            <InputDate class="form-control" @bind-Value="searchModel.MaxDateAdded" />
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (showWorkDateChanged)
                            {
                                <div class="col-md-3 mb-3">
                                    <label class="form-label mb-0 fw-bold">Дата изменения</label>
                                    <div class="row d-flex justify-content-center align-items-center">
                                        <div class="col-sm-5" style="padding-left:0px;padding-right:5px">
                                            <InputDate class="form-control" @bind-Value="searchModel.MinDateChanged" />
                                        </div>
                                        <label class="col-sm-1 col-form-label d-flex justify-content-center align-items-center">—</label>
                                        <div class="col-sm-5" style="padding-right:0px;padding-left:5px">
                                            <InputDate class="form-control" @bind-Value="searchModel.MaxDateChanged" />
                                        </div>
                                    </div>
                                </div>
                            }

                            <div class="col-md-3 mb-3">
                                <label class="form-label mb-0 fw-bold">Тип работы</label>
                                <select class="form-select" @bind="searchModel.IdWorkType" @bind:after="OnWorkTypeChanged">
                                    <option value="-1">Все</option>
                                    @foreach (var type in snapshot.WorkTypes)
                                    {
                                        <option value="@type.IdТипаРаботы">@type.Название</option>
                                    }
                                </select>
                            </div>

                            @if (showWorkStatus)
                            {
                                <div class="col-md-3 mb-3">
                                    <label class="form-label mb-0 fw-bold">Статус работы</label>
                                    <select class="form-select" @bind="searchModel.IdWorkStatus">
                                        <option value="-1">Все</option>
                                        @foreach (var status in snapshot.WorkStatuses)
                                        {
                                            <option value="@status.IdСтатусаРаботы">@status.Название</option>
                                        }
                                    </select>
                                </div>
                            }

                            @if (showWorkAccess)
                            {
                                <div class="col-md-3 mb-3">
                                    <label class="form-label mb-0 fw-bold">Доступ работы</label>
                                    <select class="form-select" @bind="searchModel.IdWorkAccess">
                                        <option value="-1"></option>
                                        @foreach (var access in snapshot.WorkAccess)
                                        {
                                            <option value="@access.IdДоступаРаботы">@access.Название</option>
                                        }
                                    </select>
                                </div>
                            }

                            <div class="col-md-3 mb-2">
                                <label class="form-label mb-0 fw-bold">Студент</label>
                                <SearchableSelect TItem="Студент"
                                                  TValue="int?"
                                                  Items="@workStudents"
                                                  TextSelector="@((s) => studentDtoFactory!.CreateDisplayDtoAsync(s).Result.Пользователь.ФИО)"
                                                  ValueSelector="@(s => s.IdСтудента)"
                                                  Placeholder="Выберите или введите студента..."
                                                  @bind-SelectedValue="@searchModel.IdStudent"
                                                  OnCustomValue="@(() => searchModel.IdStudent = null)" />
                            </div>

                            <div class="col-md-3  ">
                                <label class="form-label mb-0 fw-bold">Руководитель</label>
                                <SearchableSelect TItem="Преподаватель"
                                                  TValue="int?"
                                                  Items="workTeachers"
                                                  TextSelector="@((s) => teacherDtoFactory!.CreateDisplayDtoAsync(s).Result.Пользователь.ФИО)"
                                                  ValueSelector="@(s => s.IdПреподавателя)"
                                                  Placeholder="Выберите или введите руководителя..."
                                                  @bind-SelectedValue="@searchModel.IdTeacher"
                                                  OnCustomValue="@(() => searchModel.IdTeacher = null)" />
                            </div>

                            <div class="col-md-3 ">
                                <MultipleSearchableSelect TItem="Преподаватель"
                                                          TValue="int"
                                                          Label="Консультанты"
                                                          Placeholder="Введите или выберите ФИО консультанта..."
                                                          DefaultValue="-1"
                                                          @bind-SelectedValues="searchModel.IdConsultants"
                                                          Items="workTeachers"
                                                          TextSelector="@(t => teacherDtoFactory!.CreateDisplayDtoAsync(t).Result.Пользователь.ФИО)"
                                                          ValueSelector="@(t => t.IdПреподавателя)"
                                                          OnCustomValue="@((i) => searchModel.IdConsultants[i] = -1)" />
                            </div>

                            <div class="col-md-3">
                                <MultipleSearchableSelect TItem="Преподаватель"
                                                          TValue="int"
                                                          Label="Рецензенты"
                                                          Placeholder="Введите или выберите ФИО рецензента..."
                                                          DefaultValue="-1"
                                                          @bind-SelectedValues="searchModel.IdReviewers"
                                                          Items="workTeachers"
                                                          TextSelector="@(t => teacherDtoFactory!.CreateDisplayDtoAsync(t).Result.Пользователь.ФИО)"
                                                          ValueSelector="@(t => t.IdПреподавателя)"
                                                          OnCustomValue="@((i) => searchModel.IdReviewers[i] = -1)" />
                            </div>

                            <!-- Структура учреждения -->
                            <div class="col-md-3">
                                <label class="form-label mb-0 fw-bold">Институт</label>
                                <select class="form-select" @bind="searchModel.IdInstitute">
                                    <option value="-1">Все</option>
                                    @foreach (var institute in snapshot.Institutes)
                                    {
                                        <option value="@institute.IdИнститута">@institute.Название</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label mb-0 fw-bold">Кафедра</label>
                                <InputSelectSctructure TItem="Кафедра"
                                                       Items="snapshot.Departments.OrderBy(x => x.Название)"
                                                       @bind-Value="searchModel.IdDepartment"
                                                       Snapshot="snapshot"
                                                       DefaultTooltip="Все" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label mb-0 fw-bold">Направление</label>
                                <InputSelectSctructure TItem="Направление"
                                                       Items="snapshot.Directions.OrderBy(x => x.Название)"
                                                       @bind-Value="searchModel.IdDirection"
                                                       Snapshot="snapshot"
                                                       DefaultTooltip="Все" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label mb-0 fw-bold">Профиль</label>
                                <InputSelectSctructure TItem="Профиль"
                                                       Items="snapshot.Profiles.OrderBy(x => x.Название)"
                                                       @bind-Value="searchModel.IdProfile"
                                                       Snapshot="snapshot"
                                                       DefaultTooltip="Все" />
                            </div>
                        </div>

                        <!-- Поиск по атрибутам -->
                        <div class="row mt-3">
                            <div class="accordion" id="accordionAttributes">
                                <div class="accordion-item">
                                    <button class="accordion-button collapsed" style="height:40px;" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAttributes" aria-expanded="true" aria-controls="collapseAttributes">
                                        <h5><strong>Атрибуты</strong></h5>
                                    </button>
                                    <div id="collapseAttributes" class="accordion-collapse collapse" aria-labelledby="headingOne">
                                        <div class="accordion-body">
                                            <div class="row">
                                                @foreach (var attribute in searchModel.AllAttributes)
                                                {
                                                    <div class="col-md-4 mb-0">
                                                        <div class="card mb-2">
                                                            <div class="card-body py-2">
                                                                <div class="form-check">
                                                                    <input class="form-check-input"
                                                                           type="checkbox"
                                                                           id="attr-@(attribute.IdАтрибута)"
                                                                           @onchange="@((e) => ToggleAttribute(attribute.IdАтрибута, ((bool)e.Value!)))"
                                                                           checked="@(searchModel.SelectedAttributes.ContainsKey(attribute.IdАтрибута) ? true : false)" />
                                                                    <label class="form-check-label fw-bold" for="attr-@(attribute.IdАтрибута)">
                                                                        @(attribute.Название)
                                                                    </label>
                                                                </div>

                                                                @if (searchModel.SelectedAttributes.ContainsKey(attribute.IdАтрибута))
                                                                {
                                                                    <div class="mt-2">
                                                                        <select class="form-select form-select-sm"
                                                                                @onchange="@((e) => UpdateAttributeValue(attribute.IdАтрибута, e.Value?.ToString()))">
                                                                            <option value="">Выберите значение</option>
                                                                            @foreach (var value in searchModel.AttributeValues.FirstOrDefault(av => av.IdАтрибута == attribute.IdАтрибута)?.Данные ?? [])
                                                                            {
                                                                                <option selected="@(searchModel.SelectedAttributes[attribute.IdАтрибута] == value ? true : false)"
                                                                                        value="@value">@value</option>
                                                                            }
                                                                        </select>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Результаты поиска -->
        @if (isLoading)
        {
            <div class="text-center mt-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Загрузка...</span>
                </div>
                <p class="mt-2">Поиск работ...</p>
            </div>
        }
        else if (result?.Items == null || !result.Items.Any())
        {
            <div class="alert alert-info mt-4">
                <i class="bi bi-info-circle"></i> Работы не найдены
            </div>
        }
        else if (FilteredResult?.Items == null || !FilteredResult.Items.Any())
        {
            <div class="alert alert-info mt-4">
                <i class="bi bi-info-circle"></i> Ни одна работа Вам недоступна
            </div>
        }
        else
        {
            <!-- Информация о результатах -->
            <div class="row mb-3">
                <div class="col">
                    <p class="text-muted">
                        Найдено работ: @FilteredResult.TotalCount
                    </p>
                </div>
            </div>

            <!-- Список работ -->
            <div class="row">
                @foreach (var work in FilteredResult!.Items!.Skip((searchModel.Page - 1) * searchModel.PageSize).Take(searchModel.PageSize))
                {
                    <div class="col-lg-6 mb-4">
                        <div class="card h-100 shadow-sm hover-shadow" style="cursor: pointer;"
                             @onclick="@(() => NavigateToWork(work.IdРаботы))">
                            <div class="row g-0 h-100">
                                <div class="col-md-4 d-flex align-items-center justify-content-center bg-light">
                                    <div class="text-center p-3">
                                        <i class="bi bi-file-earmark-text display-4 text-primary"></i>
                                        <p class="small mt-2 mb-0">
                                            @(work.ТипРаботы.Название)
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <div class="card-body">
                                        <h5 class="card-title">@work.Тема</h5>

                                        <div class="mb-2">
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-person"></i>
                                                @(work.Студент.Пользователь.ФИО)
                                            </span>
                                            <span class="badge bg-info">
                                                <i class="bi bi-mortarboard"></i>
                                                @(work.Руководитель.Пользователь.ФИО)
                                            </span>
                                        </div>

                                        <div class="mb-2">
                                            <span class="small ms-2">
                                                <i class="bi bi-calendar"></i>
                                                @(WorkService.PickDateWork(work)) г.
                                            </span>
                                            @if (showWorkStatus)
                                            {
                                                <span class="badge @GetStatusBadgeClass(work.СтатусРаботы.Название) ms-2">
                                                    @work.СтатусРаботы.Название
                                                </span>
                                            }
                                        </div>

                                        @{
                                            var filtered = work.Атрибуты
                                                ?.Where(x => !Settings.AttributesAbandonedValues.Contains(x.Данные)).ToList();
                                        }
                                        <!-- Атрибуты работы -->
                                        @if (filtered != null && filtered.Count != 0)
                                        {
                                            <div class="mt-2">
                                                @foreach (var атр in filtered.Take(3))
                                                {
                                                    <span class="badge bg-light text-dark border me-1 mb-1">
                                                        @атр.Название: @атр.Данные
                                                    </span>
                                                }
                                                @if (filtered.Count > 3)
                                                {
                                                    <span class="badge bg-light text-dark border">
                                                        +@(filtered.Count - 3)
                                                    </span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Пагинация -->
            <nav aria-label="Навигация по страницам" class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(FilteredResult.CurrentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="@(() => ChangePage(1))">
                            <i class="bi bi-chevron-double-left"></i>
                        </button>
                    </li>
                    <li class="page-item @(FilteredResult.CurrentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="@(() => ChangePage(FilteredResult.CurrentPage - 1))">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </li>

                    @for (int i = Math.Max(1, FilteredResult.CurrentPage - 2); i <= Math.Min(FilteredResult.TotalPages, FilteredResult.CurrentPage + 2); i++)
                    {
                        int page = i;
                        <li class="page-item @(i == FilteredResult.CurrentPage ? "active" : "")">
                            <button class="page-link" @onclick="@(() => ChangePage(page))">@i</button>
                        </li>
                    }

                    <li class="page-item @(FilteredResult.CurrentPage == FilteredResult.TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="@(() => ChangePage(FilteredResult.CurrentPage + 1))">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                    <li class="page-item @(FilteredResult.CurrentPage == FilteredResult.TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="@(() => ChangePage(FilteredResult.TotalPages))">
                            <i class="bi bi-chevron-double-right"></i>
                        </button>
                    </li>
                </ul>

                <div class="text-center mt-2">
                    <small class="text-muted">
                        Страница @FilteredResult.CurrentPage из @FilteredResult.TotalPages
                    </small>
                </div>
            </nav>
        }
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? authenticationState { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "s")]
    public string? SearchJson { get; set; }

    private ElementReference topAnchor;
    private PaginatedResult<Работа>? result;
    private PaginatedResult<WorkDisplayDto>? FilteredResult;
    private WorkSearchModel searchModel = new();
    private bool isLoading = false;
    private bool advancedSearch = false;
    private bool showWorkStatus = false;
    private bool showWorkAccess = false;
    private bool showWorkDateChanged = false;
    private bool showAllDates = false;
    private ТипРаботы? selectedWorkType;
    private int minPage, maxPage, minYear, maxYear;
    private TeacherDtoFactory? teacherDtoFactory;
    private StudentDtoFactory? studentDtoFactory;

    private ReferenceDataSnapshot snapshot = null!;
    private List<Пользователь> users = new();
    private List<Студент> workStudents = new();
    private List<Преподаватель> workTeachers = new();
    private List<Консультант> workConsultants = new();
    private List<Рецензент> workReviewers = new();
    Stopwatch watch = Stopwatch.StartNew();

    private string modalName = "workApplicationModal";
    private bool showReportGenerator = false;

    protected override async Task OnInitializedAsync()
    {
        teacherDtoFactory = new(RefDataService);
        studentDtoFactory = new(RefDataService);
        if (RendererInfo.IsInteractive)
        {
            await GetTimeOperation("Загрузка справочников", LoadReferenceData);
            await GetTimeOperation("Поиск работ", SearchWorks);

            if (FilteredResult?.Items != null && FilteredResult.Items.Count > 0)
            {
                minPage = FilteredResult?.Items.Min(w => w.КоличСтраниц) ?? 1;
                maxPage = FilteredResult?.Items.Max(w => w.КоличСтраниц) ?? 200;
                minYear = FilteredResult?.Items.Min(w => WorkService.PickDateWork(w)) ?? 2000;
                maxYear = FilteredResult?.Items.Max(w => WorkService.PickDateWork(w)) ?? 2050;
            }
        }

    }

    /// <summary>
    /// Загрузка данных для многоритериального поиска
    /// </summary>
    /// <returns></returns>
    private async Task LoadReferenceData()
    {
        snapshot = await RefDataService.GetSnapshotAsync();
        users = await RefDataService.GetAsync<Пользователь>();
        workConsultants = (await WorkService.GetConsultantsAsync()).DistinctBy(c => c.IdПреподавателя).ToList();
        workReviewers = (await WorkService.GetReviewersAsync()).DistinctBy(c => c.IdПреподавателя).ToList();
        searchModel.AllAttributes = await WorkService.GetAllAttributesAsync();
        searchModel.AttributeValues = await WorkService.GetAttributeValuesAsync(searchModel.AllAttributes);
        workStudents = [.. (await WorkService.GetStudentsAsync()).OrderBy(s => users.First(u => u.IdПользователя == s.IdПользователя).Фамилия)];
        workTeachers = [.. (await WorkService.GetTeachersAsync()).OrderBy(s => users.First(u => u.IdПользователя == s.IdПользователя).Фамилия)];
    }

    private async Task SearchWorks()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            result = await WorkService.FindWorksAsync(searchModel);

            if (result.Items.Count != 0)
            {
                FilteredResult = new()
                {
                    CurrentPage = result.CurrentPage,
                    PageSize = result.PageSize,
                    Items = await FilterWorks(await WorkService.GetWorkDisplayAsync(result.Items, []))
                };
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task<List<WorkDisplayDto>> FilterWorks(List<WorkDisplayDto> works)
    {
        AuthenticationState? authState = await authenticationState!;
        ClaimsPrincipal? user = authState?.User;
        List<WorkDisplayDto> filtered;

        filtered = works.Where(x => x.ДоступРаботы.Название == Settings.WorkAccessAll).ToList();
        if (user == null || !user.Identity!.IsAuthenticated) return filtered;

        if (user.IsInRole(Settings.RoleAdminName))
        {
            showWorkStatus = showWorkAccess = showAllDates = showWorkDateChanged = true;
            return works;
        }

        filtered.AddRange(works.Where(x => x.ДоступРаботы.Название == Settings.WorkAccessOrganization));

        int idUser = int.Parse(user.Claims.First(x => x.Type == ClaimTypes.NameIdentifier).Value);

        List<WorkDisplayDto> temp = [];
        if (user.IsInRole(Settings.RoleInstituteResponsibleName) || user.IsInRole(Settings.RoleDepartmentHeadName)
            || user.IsInRole(Settings.RoleDepartmentResponsibleName) || user.IsInRole(Settings.RoleTeacherName))
        {
            showWorkStatus = showWorkAccess = true;

            Преподаватель? teacher = (await RefDataService.GetAsync<Преподаватель>())
                .FirstOrDefault(x => x.IdПользователя == idUser);

            if (teacher == null) return filtered;
            // Доступ внутри института
            temp.AddRange(works.Where(x => x.ДоступРаботы.Название == Settings.WorkAccessInstitute
                                        && x.Студент.Структура.Институт.IdИнститута == teacher.IdИнститута));

            // Доступ внутри кафедры
            temp.AddRange(works.Where(x => (x.ДоступРаботы.Название == Settings.WorkAccessDepartment
                                        || x.ДоступРаботы.Название == Settings.WorkAccessDirection
                                        || x.ДоступРаботы.Название == Settings.WorkAccessProfile)
                                        && x.Студент.Структура.Кафедра.IdКафедры == teacher.IdКафедры));

            // Доступ к засекреченым внутри кафедры
            if (user.IsInRole(Settings.RoleDepartmentHeadName) || user.IsInRole(Settings.RoleDepartmentResponsibleName))
            {
                temp.AddRange(works.Where(x => x.ДоступРаботы.Название == Settings.WorkAccessSecret
                                        && x.Студент.Структура.Институт.IdИнститута == teacher.IdИнститута));
            }

            // Руководитель работы
            temp.AddRange(works.Where(x => x.Руководитель.Пользователь.Пользователь.IdПользователя == idUser));
        }

        if (user.IsInRole(Settings.RoleDepartmentClerkName))
            showWorkStatus = showWorkAccess = showAllDates = showWorkDateChanged = true;

        if (user.IsInRole(Settings.RoleStudentName))
        {
            showWorkAccess = true;

            Студент? student = (await RefDataService.GetAsync<Студент>())
                .FirstOrDefault(x => x.IdПользователя == idUser);

            if (student == null) return filtered;

            temp.AddRange(works.Where(x => (x.ДоступРаботы.Название == Settings.WorkAccessInstitute
                        && x.Студент.Структура.Институт.IdИнститута == student.IdИнститута)
                        ||
                        (x.ДоступРаботы.Название == Settings.WorkAccessDepartment
                        && x.Студент.Структура.Кафедра.IdКафедры == student.IdКафедры)
                        ||
                        (x.ДоступРаботы.Название == Settings.WorkAccessDirection
                        && x.Студент.Структура.Направление.IdНаправления == student.IdНаправления)).ToList());

            // Если нет профиля, то нет смысла проверять соответствие
            if (!student.IdПрофиля.HasValue) return filtered;

            temp.AddRange(works.Where(x => x.ДоступРаботы.Название == Settings.WorkAccessProfile
                        && x.Студент.Структура?.Профиль?.IdПрофиля == null
                        || x.Студент.Структура?.Профиль?.IdПрофиля == student?.IdПрофиля).ToList());

            // Работа студента
            temp.AddRange(works.Where(x => x.Студент.Пользователь.Пользователь.IdПользователя == idUser));
        }

        filtered.AddRange(temp);
        return filtered.DistinctBy(x => x.IdРаботы).ToList();
    }


    protected override async Task OnParametersSetAsync()
    {
        // Загрузка данных поиска по параметру в ссылке
        if (!string.IsNullOrEmpty(SearchJson))
        {
            try
            {
                byte[] decodedAsBytes = Convert.FromBase64String(SearchJson);
                string decoded = Encoding.ASCII.GetString(decodedAsBytes);
                // Декодируем URL-encoded строку
                string decodedJson = HttpUtility.UrlDecode(decoded);
                // Десериализуем JSON в модель
                WorkSearchModel? loadedModel = JsonSerializer.Deserialize<WorkSearchModel>(decodedJson);
                if (loadedModel != null)
                {
                    loadedModel.AllAttributes = searchModel.AllAttributes;
                    loadedModel.AttributeValues = searchModel.AttributeValues;
                    searchModel = loadedModel;
                    await GetTimeOperation("Поиск работ", SearchWorks);
                    await ChangePage(searchModel.Page, false);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка при загрузке параметров: {ex.Message}");
            }
        }
    }

    private void UpdateUrl()
    {
        // Сериализуем модель в JSON
        string json = JsonSerializer.Serialize(searchModel);
        byte[] encodeAsBytes = ASCIIEncoding.ASCII.GetBytes(json);
        string encoded = Convert.ToBase64String(encodeAsBytes);
        // Кодируем для безопасной передачи в URL
        string encodedJson = HttpUtility.UrlEncode(encoded);

        string newUrl = $"/works/gallery?s={encodedJson}";
        // Обновляем URL без перезагрузки страницы
        Navigation.NavigateTo(newUrl, false);
    }

    // Разворот расширенного поиска
    private void ToggleAdvancedSearch()
    {
        advancedSearch = !advancedSearch;
    }

    // Разворот атрибута
    private void ToggleAttribute(int attributeId, bool isSelected)
    {
        if (isSelected && !searchModel.SelectedAttributes.ContainsKey(attributeId))
        {
            searchModel.SelectedAttributes[attributeId] = "";
        }
        else if (!isSelected)
        {
            searchModel.SelectedAttributes.Remove(attributeId);
        }
    }

    private void UpdateAttributeValue(int attributeId, string? value)
    {
        if (searchModel.SelectedAttributes.ContainsKey(attributeId))
        {
            searchModel.SelectedAttributes[attributeId] = value ?? "";
        }
    }

    private async Task ChangePage(int page, bool updateUrl = true)
    {
        if (page < 1 || page > FilteredResult?.TotalPages) return;

        if (FilteredResult != null)
        {
            FilteredResult.CurrentPage = searchModel.Page = page;
            if (updateUrl) UpdateUrl();
        }

        // Прокрутка к верху страницы
        await topAnchor.FocusAsync();
    }

    private void OnWorkTypeChanged()
    {
        selectedWorkType = snapshot.WorkTypes.FirstOrDefault(t => t.IdТипаРаботы == searchModel.IdWorkType);
        if (selectedWorkType == null)
        {
            searchModel.MinDateAdded = searchModel.MaxDateAdded = null;
            searchModel.MinYearDefense = searchModel.MaxYearDefense = null;
        }
        else if (Settings.FqpWorks.Contains(selectedWorkType!.Название))
        {
            searchModel.MinDateAdded = searchModel.MaxDateAdded = null;
        }
        else
        {
            searchModel.MinYearDefense = searchModel.MaxYearDefense = null;
        }
    }

    private void ClearSearch()
    {
        List<Атрибут> attr = searchModel.AllAttributes;
        List<AttributeValuesDto> attrVal = searchModel.AttributeValues;
        searchModel = new() { AllAttributes = attr, AttributeValues = attrVal };
        selectedWorkType = null;
    }

    private string GetStatusBadgeClass(string status)
    {
        return status.ToLower() switch
        {
            "в архиве" => "bg-success",
            "принято" => "bg-success",
            "обработка нейросетью" => "bg-warning",
            "на проверке" => "bg-info",
            "отклонено" => "bg-danger",
            "списано" => "bg-secondary",
            _ => "bg-secondary"
        };
    }

    private void NavigateToWork(int workId)
    {
        // Навигация к детальной странице работы
        Navigation.NavigateTo($"/works/{workId}");
    }

    private async Task GetTimeOperation(string operationName, Func<Task> f)
    {
        watch.Restart();
        await f.Invoke();

        watch.Stop();
        long elapsedMs = watch.ElapsedMilliseconds;
        Console.WriteLine($"[{DateTime.UtcNow.ToLocalTime()}]	Время операции {operationName}: {elapsedMs} мс\n\n");
    }
