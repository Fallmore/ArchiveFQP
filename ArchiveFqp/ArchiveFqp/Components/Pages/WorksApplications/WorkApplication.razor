@using ArchiveFqp.Components.Components
@using ArchiveFqp.Models.DTO.WorkApplication
@using ArchiveFqp.Models.Settings.SettingsArchive
@using ArchiveFqp.Interfaces.Applications
@using ArchiveFqp.Interfaces.Work
@using Microsoft.EntityFrameworkCore
@inject SettingsArchive Settings
@inject IWorkService WorkService
@inject IApplicationsService ApplicationsService
@inject IJSRuntime JS
@implements IDisposable
@rendermode @(new InteractiveServerRenderMode())

@if (RendererInfo.IsInteractive)
{
    if (errorMessage != null && successMessage == null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <EditForm EditContext="editContext" OnValidSubmit="@HandleValidSubmit" FormName="workApplicationAdd">
        <DataAnnotationsValidator />
        <ValidationSummary class="alert alert-danger" />

        <!-- Основная информация -->
        <div class="col">
            <div class="row-md-6 mb-1">
                @if (workApplictaionDto.IdРаботы.HasValue)
                {
                    string idModal = "workModal" + workApplictaionDto.IdРаботы;
                    string idModalLabel = "workModalLabel" + workApplictaionDto.IdРаботы;

                    <button type="button" class="btn btn-primary" @onclick="@(() => OpenModal(idModal))">
                        Выбранная работа
                    </button>
                    
                    <div class="modal fade" id="@idModal" tabindex="-1" aria-labelledby="@idModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-xl">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="@idModalLabel">Информация о выбранной работе</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body pt-0">
                                    <WorkDetails WorkId="workApplictaionDto.IdРаботы" ShowBackButton="false" @key="workApplictaionDto.IdРаботы" />
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <a class="btn btn-outline-primary" href="/works/gallery">
                        Выбрать работу
                    </a>
                }
            </div>

            @if (IsEditMode)
            {
                <div class="row-md-6 mb-1">
                    <!-- Цель -->
                    <label class="form-label mb-0 mx-1 fw-bold">Цель <span class="text-danger">*</span></label>
                    <InputTextArea class="form-control " @bind-Value="workApplictaionDto.Цель"
                                   disabled="@(workApplictaionDto.IdРаботы == null)"
                                   rows="3"
                                   placeholder="Укажите цель получения работы (изучение, научное исследование и т.д.)..." />
                </div>

                <div class="row-md-2">
                    <!-- Дата возврата по заявлению -->
                    <label class="form-label mb-0 mx-1 fw-bold">Дата окончания просмотра <span class="text-danger">*</span></label>
                    <div class="col-3">
                        <input type="date" class="form-control" @bind="workApplictaionDto.ДатаВозврПоЗаявл"
                               disabled="@(workApplictaionDto.IdРаботы == null)"
                               placeholder="Выберите дату"
                               min="@(DateTime.Now.AddDays(Settings.MinDayWatchWorks).ToString("yyyy-MM-dd"))" max="@(DateTime.Now.AddDays(Settings.MaxDayWatchWorks).ToString("yyyy-MM-dd"))" />
                    </div>
                </div>

                <div class="row-md-6">
                    <button type="submit" class="btn btn-success mt-3" disabled="@(workApplictaionDto.IdРаботы == null)">
                        Подать заявку
                    </button>
                </div>
            }
            else
            {
                <div class="row-md-6 mb-1">
                    <!-- Цель -->
                    <label class="form-label mb-0 mx-1 fw-bold">Цель</label>
                    <br />
                    <span class="mx-1">@(workApplictaionDto.Цель)</span>
                </div>

                <div class="row-md-6">
                    <!-- Дата поступления -->
                    <label class="form-label mb-0 mx-1 fw-bold">Дата подачи</label>
                    <br />
                    <span class="mx-1">@(workApplictaionDto.ДатаПоступления)</span>
                </div>

                <div class="row-md-6">
                    <!-- Дата возврата по заявлению -->
                    <label class="form-label mb-0 mx-1 fw-bold">Дата окончания просмотра</label>
                    <br />
                    <span class="mx-1">@(workApplictaionDto.ДатаВозврПоЗаявл)</span>
                </div>

                @if (workApplictaionDto.ДатаВозврПоФакту.HasValue && workApplictaionDto.ДатаВозврПоФакту != workApplictaionDto.ДатаВозврПоЗаявл)
                {
                    <div class="row-md-6">
                        <!-- Дата возврата по факту -->
                        <label class="form-label mb-0 mx-1 fw-bold">Дата досрочного окончания</label>
                        <br />
                        <span class="mx-1">@(workApplictaionDto.ДатаВозврПоФакту)</span>
                    </div>
                }

                // Если статус не "В обработке"
                @if (isAnswered)
                {
                    <div class="row-md-6">
                        <!-- Дата ответа -->
                        <label class="form-label mb-0 mx-1 fw-bold">Дата ответа</label>
                        <br />
                        <span class="mx-1">@(workApplictaionDto.ДатаОтвета)</span>
                    </div>

                    <div class="row-md-6">
                        <!-- Ответ -->
                        <label class="form-label mb-0 mx-1 fw-bold">Ответ</label>
                        <br />
                        <span class="mx-1">@(workApplictaionDto.Ответ)</span>
                    </div>
                }
                else if (IsReviewMode)
                {
                    <div class="row-md-6 mb-1">
                        <!-- Заявитель -->
                        @{
                            string idModal = "userInfoModal" + workApplictaionDto.IdПользователя;
                            string idModalLabel = "userInfoModalLabel" + workApplictaionDto.IdПользователя;

                            <button type="button" class="btn btn-primary" @onclick="@(() => OpenModal(idModal))">
                                Заявитель
                            </button>
                    
                            <div class="modal fade" id="@idModal" tabindex="-1" aria-labelledby="@idModalLabel" aria-hidden="true">
                                <div class="modal-dialog modal-xl">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="@idModalLabel">Информация о выбранной работе</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body pt-0">
                                            <UserInfo Student="workApplictaionDto.ПользовательСтудент"
                                                      Teacher="workApplictaionDto.ПользовательПреподаватель"
                                                      @key="workApplictaionDto.IdПользователя" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="row-md-6 mb-1">
                        <!-- Ответ -->
                        <label class="form-label mb-0 mx-1 fw-bold">Ответ <span class="text-danger">*</span></label>
                        <InputTextArea class="form-control " @bind-Value="workApplictaionDto.Ответ"
                                       disabled="@(workApplictaionDto.IdРаботы == null)"
                                       rows="3"
                                       placeholder="Опишите причину решения" />
                    </div>

                    <div class="row-md-3 mb-1">
                        <!-- Статус выдачи -->
                        <label class="form-label mb-0 mx-1 fw-bold">Вердикт <span class="text-danger">*</span></label>
                        <div class="col-md-5">
                            <InputSelect class="form-select" @bind-Value="workApplictaionDto.IdСтатуса">
                                @{
                                    int inReviewStatusId = applicationStatuses.First(w => w.Название == Settings.ApplicationsInProcessStatus).IdСтатуса;
                                    int rejectStatusId = applicationStatuses.First(w => w.Название == Settings.ApplicationsRejectStatus).IdСтатуса;
                                    int activeStatusId = applicationStatuses.First(w => w.Название == Settings.ApplicationsActiveStatus).IdСтатуса;
                                    <option value="@inReviewStatusId">Выберите вердикт</option>
                                    <option value="@rejectStatusId">Отклонить</option>
                                    <option value="@activeStatusId">Одобрить</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="row-md-6">
                        <button type="submit" class="btn btn-success mt-3" disabled="@(workApplictaionDto.IdРаботы == null)">
                            Отправить ответ
                        </button>
                    </div>
                }
            }
        </div>
    </EditForm>
}

<script>
        window.openModal = (modalId) => {
        const modalElement = document.getElementById(modalId);
        if (modalElement) {
            const modal = new bootstrap.Modal(modalElement);
            modal.show();
        }
    };
</script>

@code {
    [Parameter] public int? WorkId { get; set; }
    [Parameter] public bool IsEditMode { get; set; } = true;
    [Parameter] public bool IsReviewMode { get; set; } = false;
    [Parameter] public WorkApplicationDto? WorkApplictaionDto { get; set; }
    private WorkApplicationDto workApplictaionDto = new();
    private List<СтатусЗаявления> applicationStatuses = [];
    private int currentStatusId;
    private bool isAnswered = false;

    EditContext? editContext;
    ValidationMessageStore? messageStore;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        if (WorkApplictaionDto != null) workApplictaionDto = WorkApplictaionDto;
        else
        {
            workApplictaionDto.IdРаботы = WorkId;
            if (WorkId.HasValue)
                workApplictaionDto.Работа = await WorkService.GetWorkDisplayAsync(WorkId.Value);
        }
        applicationStatuses = await ApplicationsService.GetApplicationsStatusesAsync();
        currentStatusId = workApplictaionDto.IdСтатуса;
        isAnswered = currentStatusId != applicationStatuses
            .First(w => w.Название == Settings.ApplicationsInProcessStatus)
                .IdСтатуса;

        editContext = new(workApplictaionDto);
        messageStore = new(editContext);
        editContext.OnValidationStateChanged += HandleValidationRequested;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (WorkApplictaionDto != null) workApplictaionDto = WorkApplictaionDto;
        else
        {
            workApplictaionDto.IdРаботы = WorkId;
            if (WorkId.HasValue)
                workApplictaionDto.Работа = await WorkService.GetWorkDisplayAsync(WorkId.Value);
        }
        currentStatusId = workApplictaionDto.IdСтатуса;
        isAnswered = currentStatusId != applicationStatuses
            .First(w => w.Название == Settings.ApplicationsInProcessStatus)
                .IdСтатуса;
    }

    private async Task OpenModal(string modal)
    {
        await JS.InvokeVoidAsync("openModal", modal);
    }

    private async Task HandleValidSubmit()
    {
        errorMessage = successMessage = null;
        if (!IsReviewMode)
        {
            await AddWorkApplication();
        }
        else
        {
            await AddAnswer();
        }
    }

    void HandleValidationRequested(object? sender, ValidationStateChangedEventArgs args)
    {
        successMessage = null;
        messageStore?.Clear();

#pragma warning disable CS8603 // Возможно, возврат ссылки, допускающей значение NULL.
        if (IsReviewMode)
        {
            int inReviewStatusId = applicationStatuses.First(w => w.Название == Settings.ApplicationsInProcessStatus).IdСтатуса;
            int rejectStatusId = applicationStatuses.First(w => w.Название == Settings.ApplicationsRejectStatus).IdСтатуса;
            errorMessage = null;
            if (workApplictaionDto.IdСтатуса == inReviewStatusId)
            {
                messageStore?.Add(() => workApplictaionDto.IdСтатуса, "Выберите вердикт");
            }
            // Если происходит отказ, то необходимо объяснение отказа
            if (string.IsNullOrWhiteSpace(workApplictaionDto.Ответ)
                && workApplictaionDto.IdСтатуса == rejectStatusId)
            {
                messageStore?.Add(() => workApplictaionDto.Ответ, "Введите объяснение отказа");
            }
        }
#pragma warning restore CS8603
    }

    private async Task AddWorkApplication()
    {
        try
        {
            workApplictaionDto.IdПользователя = 10; // TODO: Получать из контекста авторизации
            workApplictaionDto.IdСтатуса = (await ApplicationsService.GetApplicationsStatusesAsync())
                    .First(ws => ws.Название == Settings.ApplicationsInProcessStatus).IdСтатуса;

            await ApplicationsService.AddWorkApplication(workApplictaionDto);

            successMessage = "Заявление успешно отправлено!";
            workApplictaionDto.IdРаботы = WorkId = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при отправке: {ex.Message}";
        }
    }

    private async Task AddAnswer()
    {
        try
        {
            if (!(await ApplicationsService.AddAnswerWorkApplication(workApplictaionDto)))
            {
                errorMessage = "Заявление не найдено, либо удалено";
            }
            else
            {
                successMessage = "Ответ успешно отправлен!";
            }

            isAnswered = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при отправке: {ex.Message}";
        }
    }

    public void Dispose()
    {
        if (!string.IsNullOrWhiteSpace(successMessage))
            WorkApplictaionDto?.IdСтатуса = currentStatusId;

        if (editContext != null)
            editContext.OnValidationStateChanged -= HandleValidationRequested;
    }
}
