@using ArchiveFqp.Components.Components
@using ArchiveFqp.Factories.DisplayDto.Teacher
@using ArchiveFqp.Interfaces.ReferenceData
@using ArchiveFqp.Interfaces.Settings
@using ArchiveFqp.Interfaces.User
@using ArchiveFqp.Models.DTO.Structure
@using ArchiveFqp.Models.DTO.Teacher
@using ArchiveFqp.Models.DTO.Work
@using ArchiveFqp.Models.DTO.WorkApplication
@using ArchiveFqp.Models.Settings.Department
@using ArchiveFqp.Models.Settings.SettingsArchive
@using ArchiveFqp.Interfaces.Applications
@using ArchiveFqp.Interfaces.Work
@using ArchiveFqp.Models.Settings.User
@using ArchiveFqp.Services.Notifications
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject SettingsArchive Settings
@inject ISettingsService SettingsService
@inject IWorkService WorkService
@inject IUserService UserService
@inject IReferenceDataService RefDataService
@inject IApplicationsService ApplicationsService
@inject NotificationService NotificationService
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode())

@if (RendererInfo.IsInteractive)
{
    if (errorMessage != null && successMessage == null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <EditForm EditContext="editContext" OnValidSubmit="@HandleValidSubmit" FormName="workApplicationAdd" @onkeydown="OnKeyDown">
        <DataAnnotationsValidator />
        <ValidationSummary class="alert alert-danger" />

        <div class="col">
            <!-- Выбранные работы -->
            <div class="row-md-6 mb-1">
                <label class="form-label mb-0 mx-1 fw-bold">Выбранные работы</label>
                @if (WorksForSend == null || WorksForSend.Count == 0)
                {
                    <h5 class="fw-semibold mb-0 align-content-center">Вы не выбрали работы</h5>
                }
                else
                {
                    <div class="overflow-auto d-flex flex-column align-items-start border rounded" style="height:200px">
                        <table class="table table-hover">
                            <thead class="table-light">
                            </thead>
                            <tbody>
                                @foreach (WorkDisplayDto work in WorksForSend)
                                {
                                    <tr role="button" @onclick="@(async () => { selectedWork = work; await OpenModal("workForSendModal"); })">
                                        <td>@work.Тема</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="modal fade" id="workForSendModal" tabindex="-1" aria-labelledby="workForSendModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-xl">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="workForSendModalLabel">Информация о выбранной работе</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body pt-0">
                                    @if (selectedWork != null)
                                    {
                                        <WorkDetails DisplayDto="selectedWork" ShowExtraButtons="false" @key="selectedWork.IdРаботы" />
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Получатель -->
            <div class="row-md-6 mb-1">
                <label class="form-label mb-0 mx-1 fw-bold">Получатель <span class="text-danger">*</span></label>
                <SearchableSelect TItem="Преподаватель"
                                  TValue="int"
                                  Items="teachers"
                                  TextSelector="@((s) => TeacherDtoFactory!.CreateDisplayDtoAsync(s).Result.Пользователь.ФИО)"
                                  ValueSelector="@(s => s.IdПользователя)"
                                  Placeholder="Выберите или введите руководителя..."
                                  @bind-SelectedValue="@workApplicationDto.IdПользователя"
                                  OnCustomValue="@(() => workApplicationDto.IdПользователя = 0)" />
            </div>

            <!-- Цель -->
            <div class="row-md-6 mb-1">
                <label class="form-label mb-0 mx-1 fw-bold">Цель <span class="text-danger">*</span></label>
                <InputTextArea class="form-control " @bind-Value="workApplicationDto.Цель"
                               disabled="@(WorksForSend == null || WorksForSend.Count == 0)"
                               rows="3"
                               placeholder="Укажите цель выдачи работы (изучение, научное исследование и т.д.)..." />
            </div>

            <!-- Дата возврата по заявлению -->
            <div class="row">
                <label class="form-label mb-0 mx-1 fw-bold">Дата окончания просмотра <span class="text-danger">*</span></label>
                <div class="col-auto">
                    <input type="date" class="form-control" @bind="workApplicationDto.ДатаВозврПоЗаявл"
                           disabled="@(WorksForSend == null || WorksForSend.Count == 0)"
                           placeholder="Выберите дату"
                           min="@(DateTime.Now.AddDays(1).ToString("yyyy-MM-dd"))" max="@(DateTime.Now.AddDays(Settings.MaxDayWatchWorks).ToString("yyyy-MM-dd"))" />
                </div>
            </div>

            <div class="row-md-6">
                <button type="submit" class="btn btn-success mt-3"
                        disabled="@(WorksForSend == null || WorksForSend.Count == 0 || workApplicationDto.IdПользователя == 0 || successMessage != null || isSubmitting)">
                    Выдать работы
                </button>
            </div>
        </div>
    </EditForm>
}

<script>
        window.openModal = (modalId) => {
        const modalElement = document.getElementById(modalId);
        if (modalElement) {
            const modal = new bootstrap.Modal(modalElement);
            modal.show();
        }
    };
</script>

@code {
    [Parameter] public List<WorkDisplayDto>? WorksForSend { get; set; }
    [Parameter] public TeacherDisplayDto Responsible { get; set; } = null!;
    [Parameter] public TeacherDtoFactory TeacherDtoFactory { get; set; } = null!;

    private WorkApplicationDto workApplicationDto = new();
    private WorkDisplayDto? selectedWork;
    private List<СтатусЗаявления> applicationStatuses = [];
    private List<Преподаватель> teachers = [];
    private bool isSubmitting = false;

    EditContext? editContext;
    ValidationMessageStore? messageStore;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        applicationStatuses = await ApplicationsService.GetApplicationsStatusesAsync();
        teachers = await WorkService.GetTeachersAsync();
        workApplicationDto.IdРаботы = 0;

        editContext = new(workApplicationDto);
        messageStore = new(editContext);
    }

    private async Task OpenModal(string modal)
    {
        await JS.InvokeVoidAsync("openModal", modal);
    }

    private async Task HandleValidSubmit()
    {
        errorMessage = successMessage = null;
        isSubmitting = true;
        StateHasChanged();

        await SendWorks();

        isSubmitting = false;
        StateHasChanged();
    }

    private async Task SendWorks()
    {
        try
        {
            workApplicationDto.IdСтатуса = (await ApplicationsService.GetApplicationsStatusesAsync())
                .First(ws => ws.Название == Settings.ApplicationsActiveStatus).IdСтатуса;
            workApplicationDto.Ответ = $"{Responsible.Пользователь.ФИО} выдает вам работы кафедры {Responsible.Структура.Кафедра.Название}";
            workApplicationDto.Выдано = true;

            foreach (var work in WorksForSend!)
            {
                WorkApplicationDto applicationDto = new(workApplicationDto)
                {
                    IdРаботы = work.IdРаботы,
                };
                await ApplicationsService.SendWorkApplication(applicationDto);
            }
            
            successMessage = "Работы успешно отправлены!";
            await SendNotificationToSenderAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при отправке: {ex.Message}";
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            return;
        }
    }

    private async Task SendNotificationToSenderAsync(string? message = null)
    {
        string title = "Выдача работ";
        СтатусЗаявления status = (await ApplicationsService.GetApplicationsStatusesAsync()).First(x => x.IdСтатуса == workApplicationDto.IdСтатуса);
        message ??= (WorksForSend!.Count > 1 ? "Вам были выданы работы " : $"Вам была выдана работа {WorksForSend[0].Тема} ")
            + $"от кафедры {Responsible.Структура.Кафедра.Название} "
            + $"на срок до {workApplicationDto.ДатаВозврПоЗаявл}";

        await NotificationService.SendToUserAsync(workApplicationDto!.IdПользователя.ToString(), title, message, "works/applications/send");
    }
}
