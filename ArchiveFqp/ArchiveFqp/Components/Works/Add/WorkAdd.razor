@page "/works/add"
@using ArchiveFqp.Models.DTO.Work
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedLocalStorage ProtectedSessionStore
@* @rendermode @(new InteractiveServerRenderMode(prerender: false)) *@

<PageTitle>АГТУ - Добавление работы</PageTitle>

<WorkAddOne UpdateSessionStore="false"
            SessionStoreNameWorkDTO="@sessionStoreNameWorkDTOSingle"
            @bind-WorkDto="@workDto" 
            @bind-WorkDto:after="OnWorkDTOChanged" />

@code {
    private WorkCreateDto workDto = new();
    private string sessionStoreNameWorkDTO = "workDTO";
    private string sessionStoreNameWorkDTOSingle = "workDTOSingle";

    private async Task OnWorkDTOChanged()
    {
        if (workDto.AttributesValuesAdded)
        {
            await ProtectedSessionStore.DeleteAsync(sessionStoreNameWorkDTOSingle);
        }

    }
}
